<UserControl x:Class="PDV.Views.PdvFeatureView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#ECEFF1">

    <UserControl.InputBindings>
        <KeyBinding Key="Insert" Command="{Binding NovoCommand}"/>
        <KeyBinding Key="F9" Command="{Binding AtualizarCommand}"/>
        <KeyBinding Key="F10" Command="{Binding ExcluirCommand}"/>
    </UserControl.InputBindings>

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <Style x:Key="HeaderStyle" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#F7FAFC"/>
            <Setter Property="Foreground" Value="#4A5568"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
        </Style>
        <Style x:Key="CellStyle" TargetType="DataGridCell">
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#2D3748"/>
        </Style>
        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Background" Value="#1C3E72"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Background="White" CornerRadius="12" Padding="20,14" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0"
                        Background="Transparent"
                        BorderThickness="0"
                        Command="{Binding VoltarCommand}"
                        Cursor="Hand"
                        Margin="0,0,12,0"
                        Padding="6,4">
                    <TextBlock Text="← Voltar" FontSize="13" Foreground="#1C3E72" FontWeight="SemiBold"/>
                </Button>
                <StackPanel Grid.Column="1">
                    <TextBlock Text="{Binding ModuloTitulo}" FontSize="18" FontWeight="SemiBold" Foreground="#000000"/>
                    <TextBlock Text="{Binding TotalTelas}" FontSize="11" Foreground="#8A94A6"/>
                </StackPanel>
                <TextBlock Grid.Column="2"
                           Text="{Binding TotalRegistros}"
                           Foreground="#1C3E72"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"
                           Margin="0,0,16,0"/>
                <!-- Botao Atualizar removido visualmente das sessoes Cadastro +, Tributacao e Fiscal/NFC-e.
                <Button Grid.Column="3"
                        Content="Atualizar"
                        Style="{StaticResource ActionButton}"
                        Command="{Binding RecarregarCommand}"/>
                -->
                <Button Grid.Column="3"
                        Content="Atualizar"
                        Style="{StaticResource ActionButton}"
                        Command="{Binding RecarregarCommand}"
                        Visibility="{Binding MostrarBotaoRecarregar, Converter={StaticResource BoolToVisibilityConverter}}"/>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="White" CornerRadius="12" Padding="10">
                <ListBox ItemsSource="{Binding Telas}"
                         SelectedItem="{Binding TelaSelecionada}"
                         BorderThickness="0"
                         Background="Transparent">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="10" Margin="0,0,0,6" BorderBrush="#E5E7EB" BorderThickness="0,0,0,1">
                                <StackPanel>
                                    <TextBlock Text="{Binding Titulo}" FontSize="13" FontWeight="SemiBold" Foreground="#1C3E72"/>
                                    <TextBlock Text="{Binding Status}" FontSize="11" Foreground="#6B7280"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Border>

            <Border Grid.Column="2" Background="White" CornerRadius="12" Padding="16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Margin="0,0,0,12">
                        <TextBlock Text="{Binding TelaSelecionada.Titulo}" FontSize="18" FontWeight="SemiBold" Foreground="#000000"/>
                        <TextBlock Text="{Binding TelaSelecionada.Descricao}" FontSize="12" Foreground="#6B7280" Margin="0,4,0,0"/>
                    </StackPanel>

                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding Linhas}"
                              SelectedItem="{Binding LinhaSelecionada, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              IsReadOnly="True"
                              ColumnHeaderStyle="{StaticResource HeaderStyle}"
                              CellStyle="{StaticResource CellStyle}"
                              GridLinesVisibility="Horizontal"
                              HorizontalGridLinesBrush="#F0F0F0"
                              BorderThickness="0"
                              Background="White"
                              RowBackground="White"
                              AlternatingRowBackground="#FAFAFA">
                        <DataGrid.InputBindings>
                            <KeyBinding Key="Insert" Command="{Binding DataContext.NovoCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                            <KeyBinding Key="F9" Command="{Binding DataContext.AtualizarCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                            <KeyBinding Key="F10" Command="{Binding DataContext.ExcluirCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                            <MouseBinding Gesture="LeftDoubleClick" Command="{Binding DataContext.AtualizarCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                        </DataGrid.InputBindings>
                        <DataGrid.Columns>
                            <DataGridTextColumn x:Name="IdColumn" Header="Id" Binding="{Binding Id}" Width="70"/>
                            <DataGridTextColumn x:Name="CodigoColumn" Header="Código" Binding="{Binding Codigo}" Width="150"/>
                            <DataGridTextColumn x:Name="NomeColumn" Header="Nome" Binding="{Binding Nome}" Width="220"/>
                            <DataGridTextColumn x:Name="DescricaoColumn" Header="Descrição" Binding="{Binding Descricao}" Width="*"/>
                            <DataGridTextColumn x:Name="StatusColumn" Header="Status" Binding="{Binding Status}" Width="120"/>
                            <DataGridTextColumn x:Name="ValorColumn" Header="Valor" Binding="{Binding Valor, StringFormat=R$ {0:N2}}" Width="120"/>
                            <DataGridTextColumn x:Name="DataColumn" Header="Data" Binding="{Binding Data, StringFormat=dd/MM/yyyy}" Width="120"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="2" Background="White" CornerRadius="12" Padding="14" Margin="0,12,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Novo [Insert]" Style="{StaticResource ActionButton}" Margin="0,0,10,0" Command="{Binding NovoCommand}" ToolTip="Novo registro (Insert)"/>
                <Button Content="Editar [F9]" Style="{StaticResource ActionButton}" Margin="0,0,10,0" Command="{Binding AtualizarCommand}" ToolTip="Editar registro selecionado (F9)"/>
                <Button Content="Excluir [F10]" Style="{StaticResource ActionButton}" Command="{Binding ExcluirCommand}" ToolTip="Excluir registro selecionado (F10)"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
