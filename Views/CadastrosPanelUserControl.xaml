<UserControl x:Class="PDV.Views.CadastrosPanelUserControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vm="clr-namespace:PDV.ViewModels"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:CadastrosPanelViewModel}"
             d:DesignHeight="800" d:DesignWidth="1000"
             Background="{StaticResource BackgroundDefaulBrush}">

    <UserControl.Resources>
        <SolidColorBrush x:Key="IconBgBlue"   Color="#E3F2FD"/>
        <SolidColorBrush x:Key="IconBgPink"   Color="#FCE4EC"/>
        <SolidColorBrush x:Key="IconBgYellow" Color="#FFF8E1"/>
        <SolidColorBrush x:Key="IconBgIndigo" Color="#E8EAF6"/>
        <SolidColorBrush x:Key="IconBgCoral"  Color="#FBE9E7"/>
        <SolidColorBrush x:Key="IconBgMint"   Color="#E0F2F1"/>

        <!-- Estilo de card: borda, hover e sombra. ContentPresenter mostra o conteúdo definido no botão. -->
        <Style x:Key="CardStyle" TargetType="Button">
            <Setter Property="Background"    Value="White"/>
            <Setter Property="BorderBrush"   Value="#F1F5F9"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"       Value="16"/>
            <Setter Property="Margin"        Value="10"/>
            <Setter Property="Cursor"        Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12"
                                Padding="{TemplateBinding Padding}">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="10" Color="#000000" Opacity="0.03" ShadowDepth="2"/>
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/>
                                <Setter TargetName="border" Property="Background"  Value="#F8FAFD"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SectionHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="17"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#2D3748"/>
            <Setter Property="Margin"     Value="10,30,0,15"/>
        </Style>

        <!-- Template reutilizável para o conteúdo de cada card -->
        <DataTemplate x:Key="CardContentTemplate">
            <!-- não usado diretamente; cards são inline -->
        </DataTemplate>
    </UserControl.Resources>

    <Grid>
        <!-- PAINEL COM BOTÕES (inicial) -->
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      Background="{StaticResource BackgroundDefaulBrush}"
                      Name="BotoesScroller">
            <StackPanel Margin="40,30,40,40">

                <TextBlock Text="Painel de Cadastros"
                           FontSize="28" FontWeight="Bold"
                           Foreground="{StaticResource TitleBrush}"/>
                <TextBlock Text="Selecione o módulo de cadastro que deseja gerenciar."
                           FontSize="14" Foreground="#718096"
                           Margin="0,8,0,20" TextWrapping="Wrap"/>

            <!-- ── Pessoas e Geral ── -->
            <TextBlock Text="Pessoas e Geral" Style="{StaticResource SectionHeaderStyle}"/>
            <WrapPanel>

                <Button Style="{StaticResource CardStyle}" Width="240" Height="52"
                        Command="{Binding NavigateCommand}" CommandParameter="ClienteList">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Image Source="{StaticResource UserIcon}"     Width="20" Height="20" Margin="0,0,10,0" Stretch="Uniform"/>
                        <TextBlock Text="Clientes"            FontSize="14" FontWeight="SemiBold" Foreground="#2D3748" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Button Style="{StaticResource CardStyle}" Width="240" Height="52"
                        Command="{Binding NavigateCommand}" CommandParameter="FornecedorList">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Image Source="{StaticResource FornecedorIcon}" Width="20" Height="20" Margin="0,0,10,0" Stretch="Uniform"/>
                        <TextBlock Text="Fornecedores"        FontSize="14" FontWeight="SemiBold" Foreground="#2D3748" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Button Style="{StaticResource CardStyle}" Width="240" Height="52"
                        Command="{Binding NavigateCommand}" CommandParameter="ColaboradorList">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Image Source="{StaticResource ColaboradorIcon}" Width="20" Height="20" Margin="0,0,10,0" Stretch="Uniform"/>
                        <TextBlock Text="Colaboradores"       FontSize="14" FontWeight="SemiBold" Foreground="#2D3748" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Button Style="{StaticResource CardStyle}" Width="240" Height="52"
                        Command="{Binding NavigateCommand}" CommandParameter="EmpresaList">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Image Source="{StaticResource EmpresaIcon}"  Width="20" Height="20" Margin="0,0,10,0" Stretch="Uniform"/>
                        <TextBlock Text="Empresa"             FontSize="14" FontWeight="SemiBold" Foreground="#2D3748" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Button Style="{StaticResource CardStyle}" Width="240" Height="52"
                        Command="{Binding NavigateCommand}" CommandParameter="FormaPagamentoList">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Image Source="{StaticResource FormaPagamentoIcon}" Width="20" Height="20" Margin="0,0,10,0" Stretch="Uniform"/>
                        <TextBlock Text="Formas de Pagamento" FontSize="14" FontWeight="SemiBold" Foreground="#2D3748" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

            </WrapPanel>

            <!-- ── Estoque e Produtos ── -->
            <TextBlock Text="Estoque e Produtos" Style="{StaticResource SectionHeaderStyle}"/>
            <WrapPanel>

                <Button Style="{StaticResource CardStyle}" Width="240" Height="52"
                        Command="{Binding NavigateCommand}" CommandParameter="ProdutoList">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Image Source="{StaticResource ProdutoIcon}"  Width="20" Height="20" Margin="0,0,10,0" Stretch="Uniform"/>
                        <TextBlock Text="Produtos"            FontSize="14" FontWeight="SemiBold" Foreground="#2D3748" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Button Style="{StaticResource CardStyle}" Width="240" Height="52"
                        Command="{Binding NavigateCommand}" CommandParameter="UnidadeList">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Image Source="{StaticResource UnidadeIcon}"  Width="20" Height="20" Margin="0,0,10,0" Stretch="Uniform"/>
                        <TextBlock Text="Unidades"            FontSize="14" FontWeight="SemiBold" Foreground="#2D3748" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

            </WrapPanel>

        </StackPanel>
    </ScrollViewer>

    <!-- RENDERIZA CONTEÚDO NAVEGADO (Lista/Formulário) - Sobrepõe painel inicial -->
    <ContentControl Content="{Binding CurrentContentView}"/>
    </Grid>

</UserControl>
