<UserControl x:Class="PDV.Views.NovoProduto.ProdutoInserindoView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:PDV.Views.NovoProduto"
             xmlns:utilities="clr-namespace:PDV.Utilities"
             mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="981"
             Background="#ECEFF1">

    <UserControl.Resources>

        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>

        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="#8A94A6"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>

        <Style x:Key="TextBoxFieldStyle" TargetType="TextBox">
            <Setter Property="Height" Value="36"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#1A202C"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#D0D5DD"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Padding="{TemplateBinding Padding}"
                                          VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#1C3E72"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#9CA3AF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TextBoxMultilineStyle" TargetType="TextBox" BasedOn="{StaticResource TextBoxFieldStyle}">
            <Setter Property="Height" Value="Auto"/>
            <Setter Property="MinHeight" Value="72"/>
            <Setter Property="AcceptsReturn" Value="False"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="VerticalContentAlignment" Value="Top"/>
            <Setter Property="Padding" Value="10,8"/>
        </Style>

        <Style x:Key="ComboBoxFieldStyle" TargetType="ComboBox">
            <Setter Property="Height" Value="36"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#1A202C"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="border"
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="6" BorderBrush="#D0D5DD" BorderThickness="1"
                                    Padding="10,0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <ContentPresenter Grid.Column="0"
                                                      Content="{TemplateBinding SelectionBoxItem}"
                                                      ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                      VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="∨" FontSize="10"
                                               Foreground="#6B7280" VerticalAlignment="Center" Margin="8,0,0,0"/>
                                </Grid>
                            </Border>
                            <ToggleButton Opacity="0"
                                          IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                          Focusable="False"/>
                            <Popup IsOpen="{TemplateBinding IsDropDownOpen}"
                                   Placement="Bottom" AllowsTransparency="True" Focusable="False">
                                <Border Background="White" CornerRadius="8"
                                        BorderBrush="#E5E7EB" BorderThickness="1" Margin="0,4,0,0">
                                    <ScrollViewer>
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#9CA3AF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="FontSize" Value="13"/>
                        <Setter Property="Foreground" Value="#111827"/>
                        <Setter Property="Padding" Value="14,8"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ComboBoxItem">
                                    <Border x:Name="itemBorder" Background="Transparent" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="itemBorder" Property="Background" Value="#F3F4F6"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="itemBorder" Property="Background" Value="#F3F4F6"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SectionCardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="24,20"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#1C3E72"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="20,0"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#2A52A0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#1C3E72"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                CornerRadius="8" BorderBrush="#D0D5DD" BorderThickness="1"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              TextElement.Foreground="{TemplateBinding Foreground}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#F7FAFC"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SearchButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="30"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

    </UserControl.Resources>

    <!-- DockPanel garante que header/tab ficam fixos
         e o ScrollViewer ocupa o restante -->
    <DockPanel>

        <!-- ===== HEADER BRANCO ===== -->
        <Border DockPanel.Dock="Top" Background="White" Padding="16,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                        Background="Transparent" BorderThickness="0" Cursor="Hand"
                        Command="{Binding FecharCommand}"
                        Margin="0,0,12,0" ToolTip="Voltar">
                    <TextBlock Text="←" FontSize="18" FontWeight="Bold" Foreground="#6B7280"
                               VerticalAlignment="Center"/>
                </Button>

                <TextBlock Grid.Column="1"
                           Text="Produto - Inserindo"
                           FontSize="16" FontWeight="SemiBold" Foreground="#1A202C"
                           VerticalAlignment="Center"/>

                <Button Grid.Column="2"
                        Command="{Binding SalvarCommand}"
                        Background="#1C3E72" Foreground="White"
                        BorderThickness="0" Cursor="Hand"
                        Padding="16,0" Height="36" Margin="0,0,8,0">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="border" Background="{TemplateBinding Background}"
                                    CornerRadius="6" Padding="{TemplateBinding Padding}">
                                <StackPanel Orientation="Horizontal">
                                    <Path Data="M17,3 H5 C3.9,3 3,3.9 3,5 V19 C3,20.1 3.9,21 5,21 H19 C20.1,21 21,20.1 21,19 V7 L17,3 Z M12,19 A3,3 0 0 1 9,16 A3,3 0 0 1 15,16 A3,3 0 0 1 12,19 Z M15,9 H7 V5 H15 V9 Z"
                                          Fill="White" Width="14" Height="14"
                                          Stretch="Uniform" Margin="0,0,8,0"/>
                                    <TextBlock Text="Salvar [F12]" FontSize="13" FontWeight="SemiBold"
                                               Foreground="White" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="border" Property="Background" Value="#0D47A1"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <Button Grid.Column="3"
                        Background="Transparent" BorderThickness="0" Cursor="Hand"
                        Width="36" Height="36" ToolTip="Mais opções">
                    <TextBlock Text="⋮" FontSize="18" Foreground="#6B7280"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Button>
            </Grid>
        </Border>

        <!-- ===== TAB BAR ===== -->
        <Border DockPanel.Dock="Top" Background="White">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Border Background="#1C3E72" Padding="30,12" Cursor="Hand">
                    <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                        <Path Data="M4,2 H12 L16,6 V20 H4 Z M12,2 V6 H16 M7,9 H13 M7,12 H13 M7,15 H10"
                              Stroke="White" StrokeThickness="1.4" Width="18" Height="18"
                              Stretch="Uniform" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                        <TextBlock Text="Detalhes" FontSize="12" FontWeight="SemiBold"
                                   Foreground="White" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>

        <!-- ===== CONTEÚDO COM SCROLL ===== -->
        <!-- ScrollViewer ocupa todo o espaço restante do DockPanel -->
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Background="#ECEFF1">
            <StackPanel Margin="24,20,24,24">

                <!-- ── SEÇÃO 1: UNIDADE / TIPO / SUBGRUPO ── -->
                <Border Style="{StaticResource SectionCardStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="24"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="24"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <TextBlock Text="Unidade" Style="{StaticResource FieldLabelStyle}" Margin="0"/>
                                <TextBlock Text=" *" FontSize="11" Foreground="#E53E3E"/>
                            </StackPanel>
                            <Grid>
                                <TextBox Style="{StaticResource TextBoxFieldStyle}"
                                         Text="{Binding Unidade, UpdateSourceTrigger=PropertyChanged}"
                                         Padding="10,0,40,0"/>
                                <Button Style="{StaticResource SearchButtonStyle}"
                                        HorizontalAlignment="Right" Margin="0,3,3,3"
                                        Command="{Binding BuscarUnidadeCommand}" ToolTip="Buscar unidade">
                                    <Path Data="M11,11 m-4,0 a4,4 0 1 0 8,0 a4,4 0 0 0 -8,0 M14.5,14.5 L19,19"
                                          Stroke="#8A94A6" StrokeThickness="1.8" Width="16" Height="16" Stretch="Uniform"/>
                                </Button>
                            </Grid>
                            <TextBlock Text="Obrigatório informar esse campo." FontSize="11" Foreground="#E53E3E" Margin="0,4,0,0"
                                       Visibility="{Binding HasUnidadeError, Converter={StaticResource BoolToVisibilityConverter}}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <TextBlock Text="Tipo" Style="{StaticResource FieldLabelStyle}" Margin="0"/>
                                <TextBlock Text=" *" FontSize="11" Foreground="#E53E3E"/>
                            </StackPanel>
                            <Grid>
                                <TextBox Style="{StaticResource TextBoxFieldStyle}"
                                         Text="{Binding Tipo, UpdateSourceTrigger=PropertyChanged}"
                                         Padding="10,0,40,0"/>
                                <Button Style="{StaticResource SearchButtonStyle}"
                                        HorizontalAlignment="Right" Margin="0,3,3,3"
                                        Command="{Binding BuscarTipoCommand}" ToolTip="Buscar tipo">
                                    <Path Data="M11,11 m-4,0 a4,4 0 1 0 8,0 a4,4 0 0 0 -8,0 M14.5,14.5 L19,19"
                                          Stroke="#8A94A6" StrokeThickness="1.8" Width="16" Height="16" Stretch="Uniform"/>
                                </Button>
                            </Grid>
                            <TextBlock Text="Obrigatório informar esse campo." FontSize="11" Foreground="#E53E3E" Margin="0,4,0,0"
                                       Visibility="{Binding HasTipoError, Converter={StaticResource BoolToVisibilityConverter}}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="4">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <TextBlock Text="SubGrupo" Style="{StaticResource FieldLabelStyle}" Margin="0"/>
                                <TextBlock Text=" *" FontSize="11" Foreground="#E53E3E"/>
                            </StackPanel>
                            <Grid>
                                <TextBox Style="{StaticResource TextBoxFieldStyle}"
                                         Text="{Binding SubGrupo, UpdateSourceTrigger=PropertyChanged}"
                                         Padding="10,0,40,0"/>
                                <Button Style="{StaticResource SearchButtonStyle}"
                                        HorizontalAlignment="Right" Margin="0,3,3,3"
                                        Command="{Binding BuscarSubGrupoCommand}" ToolTip="Buscar subgrupo">
                                    <Path Data="M11,11 m-4,0 a4,4 0 1 0 8,0 a4,4 0 0 0 -8,0 M14.5,14.5 L19,19"
                                          Stroke="#8A94A6" StrokeThickness="1.8" Width="16" Height="16" Stretch="Uniform"/>
                                </Button>
                            </Grid>
                            <TextBlock Text="Obrigatório informar esse campo." FontSize="11" Foreground="#E53E3E" Margin="0,4,0,0"
                                       Visibility="{Binding HasSubGrupoError, Converter={StaticResource BoolToVisibilityConverter}}"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- ── SEÇÃO 2: GTIN / CÓDIGO INTERNO / NOME ── -->
                <Border Style="{StaticResource SectionCardStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="24"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="24"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <TextBlock Text="Código de Barras (GTIN)" Style="{StaticResource FieldLabelStyle}" Margin="0"/>
                                <TextBlock Text=" *" FontSize="11" Foreground="#E53E3E"/>
                            </StackPanel>
                            <Grid>
                                <TextBox Style="{StaticResource TextBoxFieldStyle}"
                                         Text="{Binding Gtin, UpdateSourceTrigger=PropertyChanged}"
                                         MaxLength="14" Padding="10,0,50,0"/>
                                <TextBlock HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                           Text="{Binding Gtin.Length, StringFormat={}{0}/14}"
                                           FontSize="10" Foreground="#8A94A6" Margin="0,0,6,4" IsHitTestVisible="False"/>
                            </Grid>
                            <TextBlock Text="Obrigatório informar esse campo." FontSize="11" Foreground="#E53E3E" Margin="0,4,0,0"
                                       Visibility="{Binding HasGtinError, Converter={StaticResource BoolToVisibilityConverter}}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Código Interno" Style="{StaticResource FieldLabelStyle}"/>
                            <Grid>
                                <TextBox Style="{StaticResource TextBoxFieldStyle}"
                                         Text="{Binding CodigoInterno, UpdateSourceTrigger=PropertyChanged}"
                                         MaxLength="50" Padding="10,0,50,0"/>
                                <TextBlock HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                           Text="{Binding CodigoInterno.Length, StringFormat={}{0}/50}"
                                           FontSize="10" Foreground="#8A94A6" Margin="0,0,6,4" IsHitTestVisible="False"/>
                            </Grid>
                        </StackPanel>

                        <StackPanel Grid.Column="4">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <TextBlock Text="Nome" Style="{StaticResource FieldLabelStyle}" Margin="0"/>
                                <TextBlock Text=" *" FontSize="11" Foreground="#E53E3E"/>
                            </StackPanel>
                            <Grid>
                                <TextBox Style="{StaticResource TextBoxFieldStyle}"
                                         Text="{Binding Nome, UpdateSourceTrigger=PropertyChanged}"
                                         MaxLength="100" Padding="10,0,60,0"/>
                                <TextBlock HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                           Text="{Binding Nome.Length, StringFormat={}{0}/100}"
                                           FontSize="10" Foreground="#8A94A6" Margin="0,0,6,4" IsHitTestVisible="False"/>
                            </Grid>
                            <TextBlock Text="Obrigatório informar esse campo." FontSize="11" Foreground="#E53E3E" Margin="0,4,0,0"
                                       Visibility="{Binding HasNomeError, Converter={StaticResource BoolToVisibilityConverter}}"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- ── SEÇÃO 3: DESCRIÇÃO ── -->
                <Border Style="{StaticResource SectionCardStyle}">
                    <StackPanel>
                        <TextBlock Text="Descrição" Style="{StaticResource FieldLabelStyle}"/>
                        <Grid>
                            <TextBox Style="{StaticResource TextBoxMultilineStyle}"
                                     Text="{Binding Descricao, UpdateSourceTrigger=PropertyChanged}"
                                     MaxLength="250" Padding="10,8,60,8"/>
                            <TextBlock HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                       Text="{Binding Descricao.Length, StringFormat={}{0}/250}"
                                       FontSize="10" Foreground="#8A94A6" Margin="0,0,6,6" IsHitTestVisible="False"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- ── SEÇÃO 4: NCM / CEST / IPPT ── -->
                <Border Style="{StaticResource SectionCardStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="24"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="24"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <TextBlock Text="Código NCM (Nomenclatura Comum do Mercosul)"
                                           Style="{StaticResource FieldLabelStyle}" Margin="0"/>
                                <TextBlock Text=" *" FontSize="11" Foreground="#E53E3E"/>
                            </StackPanel>
                            <TextBox Style="{StaticResource TextBoxFieldStyle}"
                                     Text="{Binding CodigoNcm, UpdateSourceTrigger=PropertyChanged}"
                                     MaxLength="8"/>
                            <TextBlock Text="Obrigatório informar esse campo." FontSize="11" Foreground="#E53E3E" Margin="0,4,0,0"
                                       Visibility="{Binding HasCodigoNcmError, Converter={StaticResource BoolToVisibilityConverter}}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Código CEST (Código Especificador da Substituição Tributária)"
                                       Style="{StaticResource FieldLabelStyle}"/>
                            <TextBox Style="{StaticResource TextBoxFieldStyle}"
                                     Text="{Binding CodigoCest, UpdateSourceTrigger=PropertyChanged}"
                                     MaxLength="7"/>
                        </StackPanel>

                        <StackPanel Grid.Column="4">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <TextBlock Text="Produção [P]rópria ou [T]erceiros"
                                           Style="{StaticResource FieldLabelStyle}" Margin="0"/>
                                <TextBlock Text=" *" FontSize="11" Foreground="#E53E3E"/>
                            </StackPanel>
                            <ComboBox Style="{StaticResource ComboBoxFieldStyle}"
                                      ItemsSource="{Binding OpcoesIppt}"
                                      SelectedItem="{Binding Ippt}"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- ── SEÇÃO 5: VALORES ── -->
                <Border Style="{StaticResource SectionCardStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="24"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="24"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Valor de Compra" Style="{StaticResource FieldLabelStyle}"/>
                            <TextBox Style="{StaticResource TextBoxFieldStyle}"
                                     Text="{Binding ValorCompra, UpdateSourceTrigger=PropertyChanged}"
                                     utilities:DecimalTextBoxBehavior.Format="N2"
                                     HorizontalContentAlignment="Right"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <TextBlock Text="Valor de Venda" Style="{StaticResource FieldLabelStyle}" Margin="0"/>
                                <TextBlock Text=" *" FontSize="11" Foreground="#E53E3E"/>
                            </StackPanel>
                            <TextBox Style="{StaticResource TextBoxFieldStyle}"
                                     Text="{Binding ValorVenda, UpdateSourceTrigger=PropertyChanged}"
                                     utilities:DecimalTextBoxBehavior.Format="N2"
                                     HorizontalContentAlignment="Right"/>
                            <TextBlock Text="Obrigatório informar esse campo." FontSize="11" Foreground="#E53E3E" Margin="0,4,0,0"
                                       Visibility="{Binding HasValorVendaError, Converter={StaticResource BoolToVisibilityConverter}}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="4">
                            <TextBlock Text="Valor de Custo" Style="{StaticResource FieldLabelStyle}"/>
                            <TextBox Style="{StaticResource TextBoxFieldStyle}"
                                     Text="{Binding ValorCusto, UpdateSourceTrigger=PropertyChanged}"
                                     utilities:DecimalTextBoxBehavior.Format="N2"
                                     HorizontalContentAlignment="Right"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- ── SEÇÃO 6: ESTOQUES ── -->
                <Border Style="{StaticResource SectionCardStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="24"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="24"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Quantidade Estoque" Style="{StaticResource FieldLabelStyle}"/>
                            <TextBox Style="{StaticResource TextBoxFieldStyle}"
                                     Text="{Binding QuantidadeEstoque, UpdateSourceTrigger=PropertyChanged}"
                                     HorizontalContentAlignment="Right"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Estoque Mínimo" Style="{StaticResource FieldLabelStyle}"/>
                            <TextBox Style="{StaticResource TextBoxFieldStyle}"
                                     Text="{Binding EstoqueMinimo, UpdateSourceTrigger=PropertyChanged}"
                                     HorizontalContentAlignment="Right"/>
                        </StackPanel>

                        <StackPanel Grid.Column="4">
                            <TextBlock Text="Estoque Máximo" Style="{StaticResource FieldLabelStyle}"/>
                            <TextBox Style="{StaticResource TextBoxFieldStyle}"
                                     Text="{Binding EstoqueMaximo, UpdateSourceTrigger=PropertyChanged}"
                                     HorizontalContentAlignment="Right"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- ── RODAPÉ ── -->
                <Grid Margin="0,4,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               Text="* Indica que o campo é obrigatório"
                               FontSize="11" Foreground="#8A94A6"
                               VerticalAlignment="Center"/>

                    <StackPanel Grid.Column="1" Orientation="Horizontal"/>
                </Grid>

            </StackPanel>
        </ScrollViewer>

    </DockPanel>

</UserControl>
