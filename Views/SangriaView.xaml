<UserControl x:Class="PDV.Views.SangriaView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#ECEFF1">

    <Grid Margin="20">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Grid.Row="0" Background="White" CornerRadius="12" Padding="20,14" Margin="0,0,0,15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Background="Transparent" BorderThickness="0"
                        Command="{Binding VoltarCommand}" Cursor="Hand" Margin="0,0,12,0" Padding="6,4">
                    <TextBlock Text="← Voltar" FontSize="13" Foreground="#1C3E72" FontWeight="SemiBold"/>
                </Button>
                <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                    <TextBlock Text="Sangria"
                               FontSize="22" FontWeight="SemiBold" Foreground="#000000"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="Informe o valor e a observação"
                               FontSize="11" Foreground="#999999"
                               HorizontalAlignment="Center" Margin="0,5,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- FORM -->
        <Border Grid.Row="1"
                Background="White"
                CornerRadius="12"
                Padding="25"
                Margin="0,0,0,15">
            <StackPanel>

                <TextBlock Text="Informe os dados da sangria"
                           FontWeight="SemiBold"
                           Foreground="#000000"
                           Margin="0,0,0,15"
                           HorizontalAlignment="Center"/>

                <!-- CAMPO VALOR -->
                <Grid Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.ColumnSpan="2"
                            CornerRadius="8"
                            BorderBrush="#D0D5DD"
                            BorderThickness="1"
                            Background="White">
                        <TextBox x:Name="txtValor"
                                 Height="35"
                                 FontSize="14"
                                 Padding="10,0,10,0"
                                 HorizontalContentAlignment="Right"
                                 VerticalContentAlignment="Center"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Text="{Binding ValorTexto, UpdateSourceTrigger=PropertyChanged}"
                                 PreviewTextInput="ApenasNumeros"
                                 TextChanged="txtValor_TextChanged"/>
                    </Border>

                    <TextBlock Text="Valor"
                               Grid.ColumnSpan="2"
                               Foreground="#8A94A6"
                               Margin="10,0,0,0"
                               VerticalAlignment="Center"
                               IsHitTestVisible="False">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Text, ElementName=txtValor}" Value="">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>

                <!-- CAMPO OBSERVAÇÃO -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.ColumnSpan="2"
                            CornerRadius="8"
                            BorderBrush="#D0D5DD"
                            BorderThickness="1"
                            Background="White">
                        <TextBox x:Name="txtObservacao"
                                 Height="80"
                                 FontSize="14"
                                 Padding="10,8,10,8"
                                 VerticalContentAlignment="Top"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Text="{Binding Observacao, UpdateSourceTrigger=PropertyChanged}"/>
                    </Border>

                    <TextBlock Text="Observação"
                               Grid.ColumnSpan="2"
                               Foreground="#8A94A6"
                               Margin="10,8,0,0"
                               VerticalAlignment="Top"
                               IsHitTestVisible="False">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Text, ElementName=txtObservacao}" Value="">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>

            </StackPanel>
        </Border>

        <!-- BOTÕES FINAIS -->
        <StackPanel Grid.Row="3"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Margin="0,20,0,0">

            <Button Content="Cancelar"
                    Background="#1C3E72"
                    Foreground="White"
                    Margin="12"
                    Padding="12,6"
                    BorderThickness="0"
                    Cursor="Hand"
                    Command="{Binding CancelarCommand}">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              TextElement.Foreground="{TemplateBinding Foreground}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#2A52A0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <Button Content="Confirmar"
                    Background="#1C3E72"
                    Foreground="White"
                    Margin="12"
                    Padding="12,6"
                    BorderThickness="0"
                    Cursor="Hand"
                    Command="{Binding ConfirmarCommand}">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              TextElement.Foreground="{TemplateBinding Foreground}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#2A52A0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>

        </StackPanel>

    </Grid>
</UserControl>
