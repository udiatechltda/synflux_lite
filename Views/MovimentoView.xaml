<UserControl x:Class="PDV.Views.MovimentoView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#ECEFF1">

    <UserControl.Resources>
        <Style x:Key="ResumoCardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="18"/>
            <Setter Property="Margin" Value="0,0,12,0"/>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#1C3E72"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              TextElement.Foreground="{TemplateBinding Foreground}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#2A52A0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="White"
                CornerRadius="12"
                Padding="20,14"
                Margin="0,0,0,15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                        Background="Transparent"
                        BorderThickness="0"
                        Command="{Binding VoltarCommand}"
                        Cursor="Hand"
                        Margin="0,0,12,0"
                        Padding="6,4">
                    <TextBlock Text="← Voltar"
                               FontSize="13"
                               Foreground="#1C3E72"
                               FontWeight="SemiBold"/>
                </Button>

                <StackPanel Grid.Column="1">
                    <TextBlock Text="{Binding TituloMovimento}"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="#1A202C"/>
                    <TextBlock Text="{Binding TotalRegistrosTexto}"
                               FontSize="12"
                               Foreground="#8A94A6"
                               Margin="0,3,0,0"/>
                </StackPanel>

                <Button Grid.Column="2"
                        Content="Atualizar"
                        Command="{Binding AtualizarCommand}"
                        Style="{StaticResource PrimaryButtonStyle}"/>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="0,0,0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource ResumoCardStyle}">
                <StackPanel>
                    <TextBlock Text="Status" Foreground="#8A94A6" FontSize="12"/>
                    <TextBlock Text="{Binding StatusMovimento}" Foreground="#1A202C" FontSize="20" FontWeight="Bold"/>
                    <TextBlock Text="{Binding DataAberturaTexto}" Foreground="#64748B" FontSize="12" Margin="0,6,0,0"/>
                    <TextBlock Text="{Binding HoraAbertura}" Foreground="#64748B" FontSize="12"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Style="{StaticResource ResumoCardStyle}">
                <StackPanel>
                    <TextBlock Text="Vendas" Foreground="#8A94A6" FontSize="12"/>
                    <TextBlock Text="{Binding TotalVendasTexto}" Foreground="#1C3E72" FontSize="22" FontWeight="Bold"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource ResumoCardStyle}">
                <StackPanel>
                    <TextBlock Text="Suprimentos" Foreground="#8A94A6" FontSize="12"/>
                    <TextBlock Text="{Binding TotalSuprimentosTexto}" Foreground="#047857" FontSize="22" FontWeight="Bold"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="3" Style="{StaticResource ResumoCardStyle}">
                <StackPanel>
                    <TextBlock Text="Sangrias" Foreground="#8A94A6" FontSize="12"/>
                    <TextBlock Text="{Binding TotalSangriasTexto}" Foreground="#B91C1C" FontSize="22" FontWeight="Bold"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="4"
                    Background="White"
                    CornerRadius="10"
                    Padding="18">
                <StackPanel>
                    <TextBlock Text="Saldo previsto" Foreground="#8A94A6" FontSize="12"/>
                    <TextBlock Text="{Binding SaldoPrevistoTexto}" Foreground="#1A202C" FontSize="22" FontWeight="Bold"/>
                </StackPanel>
            </Border>
        </Grid>

        <Border Grid.Row="2"
                Background="White"
                CornerRadius="12"
                Padding="10">
            <DataGrid ItemsSource="{Binding Linhas}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      HeadersVisibility="Column"
                      GridLinesVisibility="Horizontal"
                      BorderThickness="0"
                      RowHeight="38"
                      FontSize="13"
                      Foreground="#1A202C"
                      Background="White"
                      AlternatingRowBackground="#F8FAFC">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Data" Binding="{Binding DataTexto}" Width="100"/>
                    <DataGridTextColumn Header="Hora" Binding="{Binding HoraTexto}" Width="90"/>
                    <DataGridTextColumn Header="Tipo" Binding="{Binding Tipo}" Width="120"/>
                    <DataGridTextColumn Header="Documento" Binding="{Binding Documento}" Width="140"/>
                    <DataGridTextColumn Header="Descrição" Binding="{Binding Descricao}" Width="*"/>
                    <DataGridTextColumn Header="Forma" Binding="{Binding FormaPagamento}" Width="160"/>
                    <DataGridTextColumn Header="Natureza" Binding="{Binding Natureza}" Width="110"/>
                    <DataGridTextColumn Header="Valor" Binding="{Binding ValorTexto}" Width="120"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>
