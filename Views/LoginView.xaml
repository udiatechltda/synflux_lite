            </Grid>-->

        </Grid>

        <Border Grid.Row="1" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0" Background="{StaticResource BackgroundWhiteBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" Margin="20,0" VerticalAlignment="Center">

                    <Ellipse Width="8" Height="8" Fill="{StaticResource SuccessBrush}"/>

                    <TextBlock Text="Online" Margin="6,0" Foreground="{StaticResource TextSecondaryBrush}" FontFamily="Inter" FontSize="12" Height="12" RenderTransformOrigin="0.5,0.5">
                        <TextBlock.RenderTransform>
                            <TransformGroup>
                                <ScaleTransform/>
                                <SkewTransform AngleX="0.367"/>
                                <RotateTransform/>
                                <TranslateTransform X="0.035"/>
                            </TransformGroup>
                        </TextBlock.RenderTransform>
                    </TextBlock>
                    <TextBlock Text="v1.0.0" Margin="24,0" Foreground="{StaticResource TextTertiaryBrush}" FontFamily="Inter" FontSize="12" Height="12"/>
                </StackPanel>

                <TextBlock Grid.Column="1" Text="© 2026 Synflux. Todos os direitos reservados." HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{StaticResource TextTertiaryBrush}" FontFamily="Inter" FontSize="14"/>

                <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,20,0">

                    <TextBlock Text="Suporte"
                   Margin="0,0,20,0"/>

                    <TextBlock Text="Configurações"/>
                </StackPanel>

            </Grid>
        </Border>
        <!--<local:LoadingView x:Name="LoadingOverlay" Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}" Loaded="LoadingOverlay_Loaded"/>-->
    </Grid>
</UserControl>
