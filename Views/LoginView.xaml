<UserControl x:Class="PDV.Views.LoginView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:PDV.Views"
             xmlns:vm="clr-namespace:PDV.ViewModels"
             xmlns:behaviors="clr-namespace:PDV.Utilities.Behaviors"
             mc:Ignorable="d" 
             d:DesignWidth="1024"
             d:DesignHeight="600"
             Loaded="UserControl_Loaded">
    <Grid Background="{StaticResource BackgroundDefaulBrush}">

        <Grid x:Name="MainContent" Background="{StaticResource BackgroundDefaulBrush}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="3*"/>
            </Grid.ColumnDefinitions>

            <!-- Painel Azul com Título -->
            <Grid Grid.Column="0">
                <Grid.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#1DB8FF" Offset="0"/>
                        <GradientStop Color="#0089E0" Offset="0.6"/>
                        <GradientStop Color="#0055A4" Offset="1"/>
                    </LinearGradientBrush>
                </Grid.Background>

                <Image Source="/Assets/Images/Png/bg_login.png" Stretch="Uniform" VerticalAlignment="Bottom" HorizontalAlignment="Center" Width="554" Height="588" Margin="0,45,0,0"/>

                <StackPanel Margin="20" VerticalAlignment="Top">
                    <TextBlock Text="Sistema PDV" FontSize="35" FontWeight="Bold" Foreground="White" Margin="0,20,0,0"/>
                    <TextBlock Text="Para gerenciar seu negócio" FontSize="16" Foreground="White" />
                </StackPanel>
            </Grid>

            <!-- Painel Branco para Login -->
            <Grid Grid.Column="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition Width="24*"/>
                    <ColumnDefinition Width="520" />
                    <ColumnDefinition Width="25*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="2" Background="White" CornerRadius="12" Padding="36" VerticalAlignment="Center" HorizontalAlignment="Center" Width="520" MinHeight="560">
                    <Border.Effect>
                        <DropShadowEffect Color="Black" BlurRadius="16" ShadowDepth="2" Opacity="0.08"/>
                    </Border.Effect>

                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Conecte-se" FontSize="28" FontWeight="SemiBold" Foreground="#1A202C" Margin="0,0,0,6" HorizontalAlignment="Center"/>
                        <TextBlock Text="PDV - Acesso ao Sistema" FontSize="13" Foreground="#999999" HorizontalAlignment="Center" Margin="0,0,0,34"/>

                        <!-- Campo E-mail -->
                        <TextBlock Text="E-mail" FontSize="13" Foreground="#8A94A6" Margin="0,0,0,6"/>
                        <Border CornerRadius="8" BorderThickness="1" BorderBrush="#D0D5DD" Background="White" Height="48" Margin="0,0,0,18">
                            <TextBox x:Name="UsuarioInput"
                                     Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"
                                     BorderThickness="0"
                                     Background="Transparent"
                                     Padding="14,0"
                                     FontSize="15"
                                     Foreground="#111827"
                                     VerticalContentAlignment="Center"
                                     KeyDown="UsuarioInput_KeyDown"/>
                        </Border>

                        <!-- Campo Senha -->
                        <TextBlock Text="Senha" FontSize="13" Foreground="#8A94A6" Margin="0,0,0,6"/>
                        <Border CornerRadius="8" BorderThickness="1" BorderBrush="#D0D5DD" Background="White" Height="48" Margin="0,0,0,8">
                            <PasswordBox x:Name="PasswordInput"
                                         BorderThickness="0"
                                         Background="Transparent"
                                         Padding="14,0"
                                         FontSize="15"
                                         Foreground="#111827"
                                         VerticalContentAlignment="Center"
                                         PasswordChanged="PasswordBox_PasswordChanged"
                                         KeyDown="PasswordInput_KeyDown"/>
                        </Border>

                        <!-- Link Esqueci a senha -->
                        <TextBlock Text="Esqueceu sua senha?" 
                               FontSize="13"
                               Foreground="#1C3E72" 
                               HorizontalAlignment="Right" 
                               Margin="0,0,0,22" 
                               Cursor="Hand"
                               MouseLeftButtonUp="EsqueceuSenha_Click">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="TextDecorations" Value="None"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="TextDecorations" Value="Underline"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <Button Command="{Binding LoginCommand}"
                                behaviors:ButtonLoading.IsEnabled="True"
                                IsEnabled="{Binding IsNotLoading}"
                                Height="48"
                                BorderThickness="0"
                                Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="border"
                                            Background="#1C3E72"
                                            CornerRadius="8">
                                        <ContentPresenter HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="border" Property="Background" Value="#2A52A0"/>
                                        </Trigger>
                                        <Trigger Property="IsEnabled" Value="False">
                                            <Setter TargetName="border" Property="Background" Value="#9CA3AF"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                            <TextBlock Text="Entrar"
                                       FontSize="15"
                                       FontWeight="SemiBold"
                                       Foreground="White"/>
                        </Button>

                        <Button Height="48"
                                Margin="0,12,0,0"
                                BorderThickness="0"
                                Cursor="Hand"
                                Click="Cadastrar_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="border"
                                            Background="White"
                                            BorderBrush="#1C3E72"
                                            BorderThickness="1"
                                            CornerRadius="8">
                                        <ContentPresenter HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="border" Property="Background" Value="#EEF3FA"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                            <TextBlock Text="Cadastrar"
                                       FontSize="15"
                                       FontWeight="SemiBold"
                                       Foreground="#1C3E72"/>
                        </Button>
                    </StackPanel>
                </Border>
            </Grid>

        </Grid>
        <local:LoadingView x:Name="LoadingOverlay" 
                          Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}" Loaded="LoadingOverlay_Loaded"/>
    </Grid>
</UserControl>
