<UserControl x:Class="PDV.Views.ComprasFormView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:utilities="clr-namespace:PDV.Utilities"
             mc:Ignorable="d"
             Background="#ECEFF1">

    <UserControl.Resources>

        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>

        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="#8A94A6"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>

        <Style x:Key="TextBoxFieldStyle" TargetType="TextBox">
            <Setter Property="Height" Value="36"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#1A202C"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#D0D5DD"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Padding="{TemplateBinding Padding}"
                                          VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#1C3E72"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#9CA3AF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TextBoxMultilineStyle" TargetType="TextBox" BasedOn="{StaticResource TextBoxFieldStyle}">
            <Setter Property="Height" Value="Auto"/>
            <Setter Property="MinHeight" Value="36"/>
            <Setter Property="AcceptsReturn" Value="False"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="VerticalContentAlignment" Value="Top"/>
            <Setter Property="Padding" Value="10,8"/>
        </Style>

        <Style x:Key="ComboBoxFieldStyle" TargetType="ComboBox">
            <Setter Property="Height" Value="36"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#1A202C"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="border"
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="6"
                                    BorderBrush="#D0D5DD"
                                    BorderThickness="1"
                                    Padding="10,0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <ContentPresenter Grid.Column="0"
                                                      Content="{TemplateBinding SelectionBoxItem}"
                                                      ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                      VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="∨" FontSize="10"
                                               Foreground="#6B7280" VerticalAlignment="Center" Margin="8,0,0,0"/>
                                </Grid>
                            </Border>
                            <ToggleButton Opacity="0"
                                          IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                          Focusable="False"/>
                            <Popup IsOpen="{TemplateBinding IsDropDownOpen}"
                                   Placement="Bottom" AllowsTransparency="True" Focusable="False">
                                <Border Background="White" CornerRadius="8"
                                        BorderBrush="#E5E7EB" BorderThickness="1" Margin="0,4,0,0">
                                    <ScrollViewer>
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#9CA3AF"/>
                            </Trigger>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#1C3E72"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="FontSize" Value="13"/>
                        <Setter Property="Foreground" Value="#111827"/>
                        <Setter Property="Padding" Value="14,8"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ComboBoxItem">
                                    <Border x:Name="itemBorder" Background="Transparent" Padding="{TemplateBinding Padding}">
                                        <DockPanel>
                                            <TextBlock x:Name="checkMark" Text="✓" FontSize="12"
                                                       Foreground="#111827" VerticalAlignment="Center"
                                                       Margin="0,0,8,0" Visibility="Hidden" Width="14"/>
                                            <ContentPresenter VerticalAlignment="Center"/>
                                        </DockPanel>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="itemBorder" Property="Background" Value="#F3F4F6"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="itemBorder" Property="Background" Value="#F3F4F6"/>
                                            <Setter TargetName="checkMark" Property="Visibility" Value="Visible"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DatePickerFieldStyle" TargetType="DatePicker">
            <Setter Property="Height" Value="36"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#1A202C"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#D0D5DD"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="SectionCardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="24,20"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>

        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#1A202C"/>
            <Setter Property="Margin" Value="0,0,0,16"/>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#1C3E72"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="20,0"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#2A52A0"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#163060"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#1C3E72"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                CornerRadius="8" BorderBrush="#D0D5DD" BorderThickness="1"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              TextElement.Foreground="{TemplateBinding Foreground}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#F7FAFC"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TotalCardStyle" TargetType="Border">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="16,12"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- ===== TAB BAR ===== -->
            <Border Grid.Row="0" Background="#ffffff" Padding="0,0,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- BOTÃO VOLTAR -->
                    <Button Grid.Column="0"
                            Width="34" Height="34"
                            Margin="12,0"
                            Cursor="Hand"
                            BorderThickness="0"
                            Command="{Binding VoltarCommand}"
                            ToolTip="Voltar">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="border"
                                        Background="Transparent"
                                        CornerRadius="8"
                                        Width="{TemplateBinding Width}"
                                        Height="{TemplateBinding Height}">
                                    <TextBlock Text="←"
                                               FontSize="20"
                                               FontWeight="Bold"
                                               Foreground="#6B7280"
                                               VerticalAlignment="Center"
                                               HorizontalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="border" Property="Background" Value="#E5E7EB"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <!-- ABAS -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center">

                        <!-- Aba Detalhes (ativa) -->
                        <Border x:Name="TabDetalhes" Background="#ffffff" Padding="30,14" Cursor="Hand">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="BorderBrush" Value="Transparent"/>
                                    <Setter Property="BorderThickness" Value="0,0,0,3"/>
                                </Style>
                            </Border.Style>
                            <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                                <Path Data="M4,2 H12 L16,6 V20 H4 Z M12,2 V6 H16 M7,9 H13 M7,12 H13 M7,15 H10"
                                      Stroke="black" StrokeThickness="1.4" Width="18" Height="18"
                                      Stretch="Uniform" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                                <TextBlock Text="Detalhes" FontSize="12" FontWeight="SemiBold"
                                           Foreground="black" HorizontalAlignment="Center"/>
                                <Border Height="2" Background="black" CornerRadius="1" Margin="0,6,0,-14"/>
                            </StackPanel>
                        </Border>

                        <!-- Aba Itens do Pedido (inativa) -->
                        <Button Background="Transparent"
                                BorderThickness="0"
                                Padding="30,14"
                                Cursor="Hand"
                                Command="{Binding IrParaItensCommand}">
                            <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                                <Path Data="M9,12 A3,3 0 1 0 9,6 A3,3 0 0 0 9,12 Z M3,20 C3,17 6,15 9,15 C12,15 15,17 15,20 M13,8 A2,2 0 1 1 17,8 M15,20 C15,17.5 16.5,16 19,16"
                                      Stroke="black" StrokeThickness="1.4"
                                      Width="18" Height="18"
                                      Stretch="Uniform" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                                <TextBlock Text="Itens do Pedido"
                                           FontSize="12" FontWeight="SemiBold"
                                           Foreground="black" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                    </StackPanel>
                </Grid>
            </Border>

            <!-- ===== CONTEÚDO ===== -->
            <StackPanel Grid.Row="1" Margin="24,20,24,24">

                <!-- SEÇÃO 1: COLABORADOR / FORNECEDOR / CONTATO -->
                <Border Style="{StaticResource SectionCardStyle}">
                    <StackPanel>
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="24"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                    <TextBlock Text="Colaborador" Style="{StaticResource FieldLabelStyle}" Margin="0"/>
                                    <TextBlock Text=" *" FontSize="11" Foreground="#E53E3E"/>
                                </StackPanel>
                                <Grid>
                                    <TextBox Style="{StaticResource TextBoxFieldStyle}"
                                             Text="{Binding Colaborador, UpdateSourceTrigger=PropertyChanged}"
                                             Padding="10,0,40,0"/>
                                    <Button Width="30" Height="30" HorizontalAlignment="Right" Margin="0,3,3,3"
                                            Background="Transparent" BorderThickness="0" Cursor="Hand"
                                            Command="{Binding BuscarColaboradorCommand}" ToolTip="Buscar colaborador">
                                        <Path Data="M11,11 m-4,0 a4,4 0 1 0 8,0 a4,4 0 0 0 -8,0 M14.5,14.5 L19,19"
                                              Stroke="#8A94A6" StrokeThickness="1.8"
                                              Width="16" Height="16" Stretch="Uniform"/>
                                    </Button>
                                </Grid>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                    <TextBlock Text="Fornecedor" Style="{StaticResource FieldLabelStyle}" Margin="0"/>
                                    <TextBlock Text=" *" FontSize="11" Foreground="#E53E3E"/>
                                </StackPanel>
                                <Grid>
                                    <TextBox Style="{StaticResource TextBoxFieldStyle}"
                                             Text="{Binding Fornecedor, UpdateSourceTrigger=PropertyChanged}"
                                             Padding="10,0,40,0"/>
                                    <Button Width="30" Height="30" HorizontalAlignment="Right" Margin="0,3,3,3"
                                            Background="Transparent" BorderThickness="0" Cursor="Hand"
                                            Command="{Binding BuscarFornecedorCommand}" ToolTip="Buscar fornecedor">
                                        <Path Data="M11,11 m-4,0 a4,4 0 1 0 8,0 a4,4 0 0 0 -8,0 M14.5,14.5 L19,19"
                                              Stroke="#8A94A6" StrokeThickness="1.8"
                                              Width="16" Height="16" Stretch="Uniform"/>
                                    </Button>
                                </Grid>
                                <TextBlock Text="Obrigatório informar esse campo."
                                           FontSize="11" Foreground="#E53E3E" Margin="0,4,0,0"
                                           Visibility="{Binding HasFornecedorError, Converter={StaticResource BoolToVisibilityConverter}}"/>
                            </StackPanel>
                        </Grid>

                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <TextBlock Text="Pedido Negociado com (Nome do Contato)"
                                           Style="{StaticResource FieldLabelStyle}" Margin="0"/>
                            </StackPanel>
                            <Grid>
                                <TextBox Style="{StaticResource TextBoxFieldStyle}"
                                         Text="{Binding NomeContato, UpdateSourceTrigger=PropertyChanged}"
                                         MaxLength="50"/>
                                <TextBlock HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                           Text="{Binding NomeContato.Length, StringFormat={}{0}/50}"
                                           FontSize="10" Foreground="#8A94A6" Margin="0,0,6,4"
                                           IsHitTestVisible="False"/>
                            </Grid>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- SEÇÃO 2: DATAS -->
                <Border Style="{StaticResource SectionCardStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="24"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="24"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <TextBlock Text="Data do Pedido" Style="{StaticResource FieldLabelStyle}" Margin="0"/>
                                <TextBlock Text=" *" FontSize="11" Foreground="#E53E3E"/>
                            </StackPanel>
                            <DatePicker Style="{StaticResource DatePickerFieldStyle}"
                                        SelectedDate="{Binding DataPedido}"
                                        SelectedDateFormat="Short"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Data Prevista para Entrega" Style="{StaticResource FieldLabelStyle}"/>
                            <DatePicker Style="{StaticResource DatePickerFieldStyle}"
                                        SelectedDate="{Binding DataPrevistaEntrega}"
                                        SelectedDateFormat="Short"/>
                        </StackPanel>

                        <StackPanel Grid.Column="4">
                            <TextBlock Text="Data Previsão Pagamento" Style="{StaticResource FieldLabelStyle}"/>
                            <DatePicker Style="{StaticResource DatePickerFieldStyle}"
                                        SelectedDate="{Binding DataPrevisaoPagamento}"
                                        SelectedDateFormat="Short"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- SEÇÃO 3: CONDIÇÃO / DATA RECEBIMENTO / HORA -->
                <Border Style="{StaticResource SectionCardStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="24"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="24"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Condição de Pagamento" Style="{StaticResource FieldLabelStyle}"/>
                            <ComboBox Style="{StaticResource ComboBoxFieldStyle}"
                                      ItemsSource="{Binding CondicoesPagamento}"
                                      SelectedItem="{Binding CondicaoPagamento}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Data Recebimento Itens" Style="{StaticResource FieldLabelStyle}"/>
                            <DatePicker Style="{StaticResource DatePickerFieldStyle}"
                                        SelectedDate="{Binding DataRecebimentoItens}"
                                        SelectedDateFormat="Short"/>
                        </StackPanel>

                        <StackPanel Grid.Column="4">
                            <TextBlock Text="Hora Recebimento Itens" Style="{StaticResource FieldLabelStyle}"/>
                            <TextBox Style="{StaticResource TextBoxFieldStyle}"
                                     Text="{Binding HoraRecebimentoItens, UpdateSourceTrigger=PropertyChanged}"
                                     MaxLength="5"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- SEÇÃO 4: LOCAL ENTREGA / COBRANÇA + DOC + DESCONTO -->
                <Border Style="{StaticResource SectionCardStyle}">
                    <StackPanel>
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="24"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Local de Entrega" Style="{StaticResource FieldLabelStyle}"/>
                                <Grid>
                                    <TextBox Style="{StaticResource TextBoxFieldStyle}"
                                             Text="{Binding LocalEntrega, UpdateSourceTrigger=PropertyChanged}"
                                             MaxLength="100" Padding="10,0,50,0"/>
                                    <TextBlock HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                               Text="{Binding LocalEntrega.Length, StringFormat={}{0}/100}"
                                               FontSize="10" Foreground="#8A94A6" Margin="0,0,6,4"
                                               IsHitTestVisible="False"/>
                                </Grid>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Local de Cobrança" Style="{StaticResource FieldLabelStyle}"/>
                                <Grid>
                                    <TextBox Style="{StaticResource TextBoxFieldStyle}"
                                             Text="{Binding LocalCobranca, UpdateSourceTrigger=PropertyChanged}"
                                             MaxLength="100" Padding="10,0,50,0"/>
                                    <TextBlock HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                               Text="{Binding LocalCobranca.Length, StringFormat={}{0}/100}"
                                               FontSize="10" Foreground="#8A94A6" Margin="0,0,6,4"
                                               IsHitTestVisible="False"/>
                                </Grid>
                            </StackPanel>
                        </Grid>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="24"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Número Documento Entrada" Style="{StaticResource FieldLabelStyle}"/>
                                <Grid>
                                    <TextBox Style="{StaticResource TextBoxFieldStyle}"
                                             Text="{Binding NumeroDocumentoEntrada, UpdateSourceTrigger=PropertyChanged}"
                                             MaxLength="50" Padding="10,0,50,0"/>
                                    <TextBlock HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                               Text="{Binding NumeroDocumentoEntrada.Length, StringFormat={}{0}/50}"
                                               FontSize="10" Foreground="#8A94A6" Margin="0,0,6,4"
                                               IsHitTestVisible="False"/>
                                </Grid>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Taxa Desconto (%)" Style="{StaticResource FieldLabelStyle}"/>
                                 <TextBox Style="{StaticResource TextBoxFieldStyle}"
                                         Text="{Binding TaxaDesconto, UpdateSourceTrigger=PropertyChanged}"
                                         utilities:DecimalTextBoxBehavior.Format="N2"
                                         HorizontalContentAlignment="Right"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- TOTAIS DO PEDIDO -->
                <Border Style="{StaticResource SectionCardStyle}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionTitleStyle}"
                                   Text="Totais do Pedido - Clique para Inserir Itens"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" Style="{StaticResource TotalCardStyle}">
                                <StackPanel>
                                    <TextBlock Text="Valor Subtotal" FontSize="11" Foreground="#718096" Margin="0,0,0,6"/>
                                    <TextBlock Text="{Binding ValorSubtotal, StringFormat={}{0:N2}}"
                                               FontSize="18" FontWeight="Bold" Foreground="#2D3748"
                                               HorizontalAlignment="Right"/>
                                    <TextBlock Text="Calculado ao inserir os itens"
                                               FontSize="10" Foreground="#A0AEC0" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="2" Style="{StaticResource TotalCardStyle}">
                                <StackPanel>
                                    <TextBlock Text="Valor Desconto" FontSize="11" Foreground="#718096" Margin="0,0,0,6"/>
                                    <TextBlock Text="{Binding ValorDesconto, StringFormat={}{0:N2}}"
                                               FontSize="18" FontWeight="Bold" Foreground="#2D3748"
                                               HorizontalAlignment="Right"/>
                                    <TextBlock Text="Calculado ao inserir os itens"
                                               FontSize="10" Foreground="#A0AEC0" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="4" Style="{StaticResource TotalCardStyle}">
                                <StackPanel>
                                    <TextBlock Text="Valor Total" FontSize="11" Foreground="#718096" Margin="0,0,0,6"/>
                                    <TextBlock Text="{Binding ValorTotal, StringFormat={}{0:N2}}"
                                               FontSize="18" FontWeight="Bold" Foreground="#2D3748"
                                               HorizontalAlignment="Right"/>
                                    <TextBlock Text="Calculado ao inserir os itens"
                                               FontSize="10" Foreground="#A0AEC0" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- DADOS FINANCEIROS -->
                <Border Style="{StaticResource SectionCardStyle}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionTitleStyle}"
                                   Text="Dados para o Sistema Financeiro - Contas a Pagar"/>

                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="24"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Quantidade de Parcelas" Style="{StaticResource FieldLabelStyle}"/>
                                <Grid>
                                    <TextBox Style="{StaticResource TextBoxFieldStyle}"
                                             Text="{Binding QuantidadeParcelas, UpdateSourceTrigger=PropertyChanged}"
                                             MaxLength="10" Padding="10,0,50,0"/>
                                    <TextBlock HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                               Text="{Binding QuantidadeParcelas.Length, StringFormat={}{0}/10}"
                                               FontSize="10" Foreground="#8A94A6" Margin="0,0,6,4"
                                               IsHitTestVisible="False"/>
                                </Grid>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Intervalo entre Parcelas (dias)" Style="{StaticResource FieldLabelStyle}"/>
                                <Grid>
                                    <TextBox Style="{StaticResource TextBoxFieldStyle}"
                                             Text="{Binding IntervaloParcelas, UpdateSourceTrigger=PropertyChanged}"
                                             MaxLength="2" Padding="10,0,30,0"/>
                                    <TextBlock HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                               Text="{Binding IntervaloParcelas.Length, StringFormat={}{0}/2}"
                                               FontSize="10" Foreground="#8A94A6" Margin="0,0,6,4"
                                               IsHitTestVisible="False"/>
                                </Grid>
                            </StackPanel>
                        </Grid>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="24"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Dia Primeiro Vencimento" Style="{StaticResource FieldLabelStyle}"/>
                                <DatePicker Style="{StaticResource DatePickerFieldStyle}"
                                            SelectedDate="{Binding DiaPrimeiroVencimento}"
                                            SelectedDateFormat="Short"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Dia Fixo da Parcela" Style="{StaticResource FieldLabelStyle}"/>
                                <Grid>
                                    <TextBox Style="{StaticResource TextBoxFieldStyle}"
                                             Text="{Binding DiaFixoParcela, UpdateSourceTrigger=PropertyChanged}"
                                             MaxLength="2" Padding="10,0,30,0"/>
                                    <TextBlock HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                               Text="{Binding DiaFixoParcela.Length, StringFormat={}{0}/2}"
                                               FontSize="10" Foreground="#8A94A6" Margin="0,0,6,4"
                                               IsHitTestVisible="False"/>
                                </Grid>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- RODAPÉ -->
                <Grid Margin="0,4,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               Text="* Indica que o campo é obrigatório"
                               FontSize="11" Foreground="#8A94A6"
                               VerticalAlignment="Center"/>

                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button Style="{StaticResource SecondaryButtonStyle}"
                                Content="Cancelar" Margin="0,0,12,0"
                                Command="{Binding CancelarCommand}"/>
                        <Button Style="{StaticResource PrimaryButtonStyle}"
                                Content="Salvar"
                                Command="{Binding SalvarCommand}">
                            <Button.ContentTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <Path Data="M17,3 H5 C3.9,3 3,3.9 3,5 V19 C3,20.1 3.9,21 5,21 H19 C20.1,21 21,20.1 21,19 V7 L17,3 Z M12,19 A3,3 0 0 1 9,16 A3,3 0 0 1 15,16 A3,3 0 0 1 12,19 Z M15,9 H7 V5 H15 V9 Z"
                                              Fill="White" Width="16" Height="16"
                                              Stretch="Uniform" Margin="0,0,8,0"/>
                                        <TextBlock Text="{Binding}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </DataTemplate>
                            </Button.ContentTemplate>
                        </Button>
                    </StackPanel>
                </Grid>

            </StackPanel>
        </Grid>
    </ScrollViewer>

</UserControl>
