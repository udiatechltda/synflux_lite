<UserControl x:Class="PDV.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:PDV.Views"
             mc:Ignorable="d"
             Background="#ECEFF1">

    <UserControl.Resources>

        <Style x:Key="ComboBoxDashStyle" TargetType="ComboBox">
            <Setter Property="Height" Value="32"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#111827"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="border"
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="6"
                                    BorderBrush="#D1D5DB"
                                    BorderThickness="1"
                                    Padding="10,0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <ContentPresenter Grid.Column="0"
                                                      Content="{TemplateBinding SelectionBoxItem}"
                                                      ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                      VerticalAlignment="Center"
                                                      HorizontalAlignment="Left"/>
                                    <TextBlock Grid.Column="1"
                                               Text="∨"
                                               FontSize="10"
                                               Foreground="#6B7280"
                                               VerticalAlignment="Center"
                                               Margin="8,0,0,0"/>
                                </Grid>
                            </Border>
                            <ToggleButton Opacity="0"
                                          IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                          Focusable="False"/>
                            <Popup IsOpen="{TemplateBinding IsDropDownOpen}"
                                   Placement="Bottom"
                                   AllowsTransparency="True"
                                   Focusable="False">
                                <Border Background="White"
                                        CornerRadius="8"
                                        BorderBrush="#E5E7EB"
                                        BorderThickness="1"
                                        Margin="0,4,0,0">
                                    <ScrollViewer>
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#9CA3AF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="FontSize" Value="13"/>
                        <Setter Property="Foreground" Value="#111827"/>
                        <Setter Property="Padding" Value="14,8"/>
                        <Setter Property="HorizontalContentAlignment" Value="Left"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ComboBoxItem">
                                    <Border x:Name="itemBorder"
                                            Background="Transparent"
                                            Padding="{TemplateBinding Padding}">
                                        <DockPanel>
                                            <TextBlock x:Name="checkMark"
                                                       Text="✓"
                                                       FontSize="12"
                                                       Foreground="#111827"
                                                       VerticalAlignment="Center"
                                                       Margin="0,0,8,0"
                                                       Visibility="Hidden"
                                                       Width="14"/>
                                            <ContentPresenter VerticalAlignment="Center"/>
                                        </DockPanel>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="itemBorder" Property="Background" Value="#F3F4F6"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="itemBorder" Property="Background" Value="#F3F4F6"/>
                                            <Setter TargetName="checkMark" Property="Visibility" Value="Visible"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>

    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="20">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- CARD TOPO -->
            <Border Background="#ffffff"
                    CornerRadius="12"
                    Padding="25"
                    Margin="0,0,0,15">
                
                

                <StackPanel>
                    <TextBlock Text="Dashboard"
                               FontSize="22"
                               FontWeight="SemiBold"
                               Foreground="#000000"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- LINHA 1: Resumo Financeiro + Fluxo de Caixa -->
            <Grid Grid.Row="1" Margin="0,0,0,15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="15"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- RESUMO FINANCEIRO -->
                <Border Grid.Column="0"
                        Background="#ffffff"
                        CornerRadius="12"
                        Padding="25">
                    <StackPanel>

                        <DockPanel Margin="0,0,0,15">
                            <TextBlock Text="Resumo Financeiro"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Foreground="#000000"
                                       DockPanel.Dock="Left"
                                       VerticalAlignment="Center"/>
                            <ComboBox Style="{StaticResource ComboBoxDashStyle}"
                                      HorizontalAlignment="Right"
                                      SelectedIndex="0">
                                <ComboBoxItem Content="Última Semana"/>
                                <ComboBoxItem Content="Último Mês"/>
                                <ComboBoxItem Content="Último Ano"/>
                            </ComboBox>
                        </DockPanel>

                        <!-- Receitas / Despesas -->
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Receitas -->
                            <Border Grid.Column="0"
                                    CornerRadius="8"
                                    BorderBrush="#E2E8F0"
                                    BorderThickness="1"
                                    Padding="15"
                                    Margin="0,0,8,0">
                                <StackPanel>
                                    <TextBlock Text="Receitas"
                                               FontSize="12"
                                               Foreground="#1C3E72"
                                               Margin="0,8,0,4"/>
                                    <TextBlock Text="{Binding Receitas, StringFormat=R$ {0:N2}, FallbackValue='R$ 0,00'}"
                                               FontSize="18"
                                               FontWeight="SemiBold"
                                               Foreground="#000000"/>
                                </StackPanel>
                            </Border>

                            <!-- Despesas -->
                            <Border Grid.Column="1"
                                    CornerRadius="8"
                                    BorderBrush="#E2E8F0"
                                    BorderThickness="1"
                                    Padding="15"
                                    Margin="8,0,0,0">
                                <StackPanel>
                                    <TextBlock Text="Despesas"
                                               FontSize="12"
                                               Foreground="#1C3E72"
                                               Margin="0,8,0,4"/>
                                    <TextBlock Text="{Binding Despesas, StringFormat=R$ {0:N2}, FallbackValue='R$ 0,00'}"
                                               FontSize="18"
                                               FontWeight="SemiBold"
                                               Foreground="#000000"/>
                                </StackPanel>
                            </Border>

                        </Grid>

                        <!-- Saldo -->
                        <TextBlock Text="{Binding Saldo, StringFormat=Saldo: R$ {0:N2}, FallbackValue='Saldo: R$ 0,00'}"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Foreground="#1C3E72"
                                   HorizontalAlignment="Center"
                                   Margin="0,5,0,15"/>

                        <!-- Recebimentos Vencidos -->
                        <Border CornerRadius="8"
                                BorderBrush="#E2E8F0"
                                BorderThickness="1"
                                Padding="15">
                            <StackPanel>
                                <TextBlock Text="Recebimentos Vencidos"
                                           FontSize="12"
                                           Foreground="#1C3E72"/>
                                <TextBlock Text="{Binding RecebimentosVencidos, StringFormat=R$ {0:N2}, FallbackValue='R$ 0,00'}"
                                           FontSize="16"
                                           FontWeight="SemiBold"
                                           Foreground="#000000"/>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </Border>

                <!-- FLUXO DE CAIXA -->
                <Border Grid.Column="2"
                        Background="#ffffff"
                        CornerRadius="12"
                        Padding="25">
                    <StackPanel>

                        <DockPanel Margin="0,0,0,15">
                            <TextBlock Text="Fluxo de Caixa"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Foreground="#000000"
                                       DockPanel.Dock="Left"
                                       VerticalAlignment="Center"/>
                            <ComboBox Style="{StaticResource ComboBoxDashStyle}"
                                      HorizontalAlignment="Right"
                                      SelectedIndex="0">
                                <ComboBoxItem Content="Próxima Semana"/>
                                <ComboBoxItem Content="Próximo Mês"/>
                            </ComboBox>
                        </DockPanel>

                        <!-- A Receber -->
                        <Border CornerRadius="8"
                                BorderBrush="#E2E8F0"
                                BorderThickness="1"
                                Padding="15,12"
                                Margin="0,0,0,8">
                            <StackPanel>
                                <TextBlock Text="A Receber"
                                           FontSize="12"
                                           Foreground="#1C3E72"/>
                                <TextBlock Text="{Binding AReceber, StringFormat=R$ {0:N2}, FallbackValue='R$ 0,00'}"
                                           FontSize="16"
                                           FontWeight="SemiBold"
                                           Foreground="#000000"/>
                            </StackPanel>
                        </Border>

                        <!-- A Pagar -->
                        <Border CornerRadius="8"
                                BorderBrush="#E2E8F0"
                                BorderThickness="1"
                                Padding="15,12"
                                Margin="0,0,0,8">
                            <StackPanel>
                                <TextBlock Text="A Pagar"
                                           FontSize="12"
                                           Foreground="#1C3E72"/>
                                <TextBlock Text="{Binding APagar, StringFormat=R$ {0:N2}, FallbackValue='R$ 0,00'}"
                                           FontSize="16"
                                           FontWeight="SemiBold"
                                           Foreground="#000000"/>
                            </StackPanel>
                        </Border>

                        <!-- Saldo -->
                        <Border CornerRadius="8"
                                BorderBrush="#E2E8F0"
                                BorderThickness="1"
                                Padding="15,12"
                                Margin="0,0,0,8">
                            <StackPanel>
                                <TextBlock Text="Saldo"
                                           FontSize="12"
                                           Foreground="#1C3E72"/>
                                <TextBlock Text="{Binding SaldoCaixa, StringFormat=R$ {0:N2}, FallbackValue='R$ 0,00'}"
                                           FontSize="16"
                                           FontWeight="SemiBold"
                                           Foreground="#000000"/>
                            </StackPanel>
                        </Border>

                        <!-- Pagamentos Vencidos -->
                        <Border CornerRadius="8"
                                BorderBrush="#E2E8F0"
                                BorderThickness="1"
                                Padding="15,12">
                            <StackPanel>
                                <TextBlock Text="Pagamentos Vencidos"
                                           FontSize="12"
                                           Foreground="#1C3E72"/>
                                <TextBlock Text="{Binding PagamentosVencidos, StringFormat=R$ {0:N2}, FallbackValue='R$ 0,00'}"
                                           FontSize="16"
                                           FontWeight="SemiBold"
                                           Foreground="#000000"/>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </Border>

            </Grid>

            <!-- LINHA 2: Desempenho de Vendas -->
            <Border Grid.Row="2"
                    Background="#ffffff"
                    CornerRadius="12"
                    Padding="25"
                    Margin="0,0,0,15">
                <StackPanel>

                    <TextBlock Text="Desempenho de Vendas"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="#000000"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,15"/>

                    <Border CornerRadius="8"
                            BorderBrush="#E2E8F0"
                            BorderThickness="1"
                            Padding="20">
                        <DockPanel>
                            <StackPanel DockPanel.Dock="Left">
                                <TextBlock Text="Total das Vendas"
                                           FontSize="12"
                                           Foreground="#1C3E72"
                                           FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding TotalVendas, StringFormat=R$ {0:N2}, FallbackValue='R$ 0,00'}"
                                           FontSize="28"
                                           FontWeight="Bold"
                                           Foreground="#000000"
                                           Margin="0,8,0,0"/>
                            </StackPanel>
                            <ComboBox Style="{StaticResource ComboBoxDashStyle}"
                                      HorizontalAlignment="Right"
                                      VerticalAlignment="Top"
                                      SelectedIndex="0">
                                <ComboBoxItem Content="Última Semana"/>
                                <ComboBoxItem Content="Último Mês"/>
                                <ComboBoxItem Content="Último Ano"/>
                            </ComboBox>
                        </DockPanel>
                    </Border>

                </StackPanel>
            </Border>

            <!-- LINHA 3: Posição do Estoque -->
            <Border Grid.Row="3"
                    Background="#ffffff"
                    CornerRadius="12"
                    Padding="25"
                    Margin="0,0,0,15">
                <StackPanel>

                    <TextBlock Text="Posição do Estoque"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="#000000"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,15"/>

                    <Border CornerRadius="8"
                            BorderBrush="#E2E8F0"
                            BorderThickness="1"
                            Padding="20">
                        <StackPanel>
                            <TextBlock Text="Itens com Estoque Crítico"
                                       FontSize="12"
                                       Foreground="#1C3E72"
                                       FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding ItensCriticos, FallbackValue='0'}"
                                       FontSize="28"
                                       FontWeight="Bold"
                                       Foreground="#000000"
                                       Margin="0,8,0,0"/>
                        </StackPanel>
                    </Border>

                    <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">

                        <Button Content="Sair"
                                Background="#1C3E72" Foreground="White"
                                Margin="12" Padding="12,6" BorderThickness="0" Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                                          TextElement.Foreground="{TemplateBinding Foreground}"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="border" Property="Background" Value="#2A52A0"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                    </StackPanel>

                </StackPanel>
            </Border>

        </Grid>
    </ScrollViewer>

</UserControl>