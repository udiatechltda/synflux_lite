<UserControl x:Class="PDV.Views.ColaboradorListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vm="clr-namespace:PDV.ViewModels"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:ColaboradorListViewModel}"
             d:DesignHeight="600" d:DesignWidth="1200">

    <UserControl.Resources>
        <Style x:Key="ColHeaderStyle" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#F7FAFC"/>
            <Setter Property="Foreground" Value="#4A5568"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="8,10"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
        </Style>
        <Style x:Key="ColCellStyle" TargetType="DataGridCell">
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#2D3748"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#EBF4FF"/>
                    <Setter Property="Foreground" Value="#1C3E72"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid Background="Transparent">
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- HEADER AZUL -->
        <Border Grid.Row="0" Background="#2B4C95" Padding="20,0">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Button Background="Transparent" BorderThickness="0" Foreground="White" Cursor="Hand"
                        Command="{Binding VoltarCommand}" Margin="0,0,15,0" Padding="4">
                    <TextBlock Text="←" FontSize="16"/>
                </Button>
                <TextBlock Text="Cadastro - Colaborador" Foreground="White" FontSize="18"
                           FontWeight="Bold" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- CONTEÚDO -->
        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <TextBlock Grid.Row="0" Text="Relação - Colaborador" FontSize="16" FontWeight="SemiBold"
                       Foreground="#2D3748" Margin="20,15,20,10"/>
            <Border Grid.Row="1" Background="White" ClipToBounds="True" Margin="20,0,20,0">
                <DataGrid ItemsSource="{Binding Items}" SelectedItem="{Binding SelectedItem}"
                          AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True"
                          BorderThickness="1" BorderBrush="#E2E8F0"
                          Background="White" RowBackground="White" AlternatingRowBackground="#FAFBFC"
                          ColumnHeaderStyle="{StaticResource ColHeaderStyle}"
                          CellStyle="{StaticResource ColCellStyle}"
                          GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#EDF2F7"
                          VerticalScrollBarVisibility="Auto" RowHeight="40">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Id"               Binding="{Binding Id}"               Width="60"/>
                        <DataGridTextColumn Header="Nome"             Binding="{Binding Nome}"             Width="180"/>
                        <DataGridTextColumn Header="CPF"              Binding="{Binding Cpf}"              Width="120"/>
                        <DataGridTextColumn Header="Telefone"         Binding="{Binding Telefone}"         Width="110"/>
                        <DataGridTextColumn Header="Email"            Binding="{Binding Email}"            Width="150"/>
                        <DataGridTextColumn Header="Com. Vista (%)"   Binding="{Binding ComissaoVista, StringFormat='N2'}"  Width="110"/>
                        <DataGridTextColumn Header="Com. Prazo (%)"   Binding="{Binding ComissaoPrazo, StringFormat='N2'}"  Width="110"/>
                        <DataGridTextColumn Header="Nível Autorização" Binding="{Binding NivelAutorizacao}" Width="120"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </Grid>

        <!-- BARRA INFERIOR -->
        <Border Grid.Row="2" Background="White" BorderBrush="#E2E8F0" BorderThickness="0,1,0,0" Padding="20,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Style="{StaticResource DefaultButtonStyle}" Margin="0,0,10,0" Padding="12,6" FontSize="12">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🔍 Filtro" Margin="0,0,5,0"/>
                        <TextBlock Text="[F11]" Foreground="#A0AEC0" FontSize="10"/>
                    </StackPanel>
                </Button>
                <Button Grid.Column="1" Style="{StaticResource DefaultButtonStyle}" Margin="0,0,10,0" Padding="12,6" FontSize="12">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="📊 Relatório" Margin="0,0,5,0"/>
                        <TextBlock Text="[F8]" Foreground="#A0AEC0" FontSize="10"/>
                    </StackPanel>
                </Button>
                <Border Grid.Column="2"/>
                <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,12,0">
                    <TextBlock Text="Linhas por página:" VerticalAlignment="Center" Margin="0,0,8,0" FontSize="12"/>
                    <ComboBox Width="50" VerticalAlignment="Center">
                        <ComboBoxItem>10</ComboBoxItem>
                        <ComboBoxItem IsSelected="True">20</ComboBoxItem>
                        <ComboBoxItem>50</ComboBoxItem>
                    </ComboBox>
                    <Button Background="Transparent" BorderThickness="0" Foreground="#A0AEC0" Cursor="Hand"
                            Padding="5" FontSize="14" Margin="8,0,5,0">◀</Button>
                    <Button Background="Transparent" BorderThickness="0" Foreground="#A0AEC0" Cursor="Hand"
                            Padding="5" FontSize="14">▶</Button>
                </StackPanel>
                <Button Grid.Column="4" Style="{StaticResource FabButtonStyle}"
                        Command="{Binding NovoCommand}" ToolTip="Novo (Ins)">
                    <TextBlock Text="+" FontSize="26" FontWeight="Light" Foreground="White"
                               VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,-2,0,0"/>
                </Button>
            </Grid>
        </Border>
    </Grid>
</UserControl>
