<UserControl x:Class="PDV.Views.MenuView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d" d:DesignWidth="250">

    <UserControl.Resources>
        <Style x:Key="SideMenuItemStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="#1C3E72"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}"
                                Margin="8,2"
                                CornerRadius="8">
                            <ContentPresenter x:Name="content"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#F3F4F6"/>
                                <Setter Property="Foreground" Value="#1A202C"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="MenuSectionStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="8"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#8A94A6"/>
            <Setter Property="Margin" Value="20,8,0,4"/>
        </Style>
    </UserControl.Resources>

    <Border Background="#ffff">

        <ScrollViewer VerticalScrollBarVisibility="Hidden">

            <StackPanel>

                <!-- TÍTULO -->
                <Border Background="White"
                        BorderBrush="#E5E7EB"
                        BorderThickness="0,0,0,1"
                        Height="65"
                        Padding="0,0">

                    <Grid>
                        <TextBlock Text="PDV"
                                   FontSize="25"
                                   FontWeight="SemiBold"
                                   Foreground="#1565C0"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Grid>

                </Border>


                <!-- OPÇÕES DE CAIXA -->
                <StackPanel x:Name="OpcoesCaixaPanel" Visibility="Visible">

                    <TextBlock Text="OPÇÕES DE CAIXA"
                               Style="{StaticResource MenuSectionStyle}"/>

                    <Button Style="{StaticResource SideMenuItemStyle}"
                            Command="{Binding SelectSideMenuItemCommand}"
                            CommandParameter="AberturaCaixa">
                        <StackPanel Orientation="Horizontal">
                            <Image Source="{StaticResource MovimentoIcon}" Width="20" Height="20" Margin="0,0,12,0"/>
                            <TextBlock Text="{Binding CashActionText}" FontSize="15" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource SideMenuItemStyle}"
                            Command="{Binding SelectSideMenuItemCommand}"
                            CommandParameter="Home"
                            Visibility="{Binding IsCashOpen, Converter={StaticResource BoolToVisibility}}">
                        <StackPanel Orientation="Horizontal">
                            <Image Source="{StaticResource MovimentoIcon}" Width="20" Height="20" Margin="0,0,12,0"/>
                            <TextBlock Text="Caixa / Venda" FontSize="15" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource SideMenuItemStyle}"
                            Command="{Binding SelectSideMenuItemCommand}"
                            CommandParameter="Movimento">
                        <StackPanel Orientation="Horizontal">
                            <Image Source="{StaticResource MovimentoIcon}" Width="20" Height="20" Margin="0,0,12,0"/>
                            <TextBlock Text="Movimento" FontSize="15" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>

                    </Button>

                    <Button Style="{StaticResource SideMenuItemStyle}"
                            Command="{Binding SelectSideMenuItemCommand}"
                            CommandParameter="Suprimento">
                        <StackPanel Orientation="Horizontal">
                            <Image Source="{StaticResource SuprimentoIcon}" Width="20" Height="20" Margin="0,0,12,0"/>
                            <TextBlock Text="Suprimento" FontSize="15" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource SideMenuItemStyle}"
                            Command="{Binding SelectSideMenuItemCommand}"
                            CommandParameter="Sangria">
                        <StackPanel Orientation="Horizontal">
                            <Image Source="{StaticResource DollarIcon}" Width="20" Height="20" Margin="0,0,12,0"/>
                            <TextBlock Text="Sangria" FontSize="15" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                </StackPanel>


                <!-- MÓDULOS -->
                <StackPanel x:Name="ModulosPanel" Visibility="Collapsed">

                    <TextBlock Text="MÓDULOS"
                               Style="{StaticResource MenuSectionStyle}"/>

                    <Button Style="{StaticResource SideMenuItemStyle}"
                            Command="{Binding SelectSideMenuItemCommand}"
                            CommandParameter="Cadastros">
                        <StackPanel Orientation="Horizontal">
                            <Image Source="{StaticResource CadastroIcon}" Width="20" Height="20" Margin="0,0,12,0"/>
                            <TextBlock Text="Cadastros" FontSize="15" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource SideMenuItemStyle}"
                            Command="{Binding SelectSideMenuItemCommand}"
                            CommandParameter="CadastrosPlus">
                        <StackPanel Orientation="Horizontal">
                            <Image Source="{StaticResource CadastroIcon}" Width="20" Height="20" Margin="0,0,12,0"/>
                            <TextBlock Text="Cadastros +" FontSize="15" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    
                    <Button Style="{StaticResource SideMenuItemStyle}"
                            Command="{Binding SelectSideMenuItemCommand}"
                            CommandParameter="Compras">
                        <StackPanel Orientation="Horizontal">
                            <Image Source="{StaticResource ComprasIcon}" Width="20" Height="20" Margin="0,0,12,0"/>
                            <TextBlock Text="Compras" FontSize="15" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    
                    <Button Style="{StaticResource SideMenuItemStyle}"
                            Command="{Binding SelectSideMenuItemCommand}"
                            CommandParameter="Estoque">
                        <StackPanel Orientation="Horizontal">
                            <Image Source="{StaticResource EstoqueIcon}" Width="20" Height="20" Margin="0,0,12,0"/>
                            <TextBlock Text="Estoque" FontSize="15" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource SideMenuItemStyle}"
                            Command="{Binding SelectSideMenuItemCommand}"
                            CommandParameter="Financeiro">
                        <StackPanel Orientation="Horizontal">
                            <Image Source="{StaticResource DinheiroIcon}" Width="20" Height="20" Margin="0,0,12,0"/>
                            <TextBlock Text="Financeiro" FontSize="15" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource SideMenuItemStyle}"
                            Command="{Binding SelectSideMenuItemCommand}"
                            CommandParameter="Dashboard">
                        <StackPanel Orientation="Horizontal">
                            <Image Source="{StaticResource ArrowUpIcon}" Width="20" Height="20" Margin="0,0,12,0"/>
                            <TextBlock Text="Dashboard" FontSize="15" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource SideMenuItemStyle}"
                            Command="{Binding SelectSideMenuItemCommand}"
                            CommandParameter="Vendas">
                        <StackPanel Orientation="Horizontal">
                            <Image Source="{StaticResource ShoppingCartIcon}" Width="20" Height="20" Margin="0,0,12,0"/>
                            <TextBlock Text="Vendas" FontSize="15" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource SideMenuItemStyle}"
                            Command="{Binding SelectSideMenuItemCommand}"
                            CommandParameter="PdvPlus">
                        <StackPanel Orientation="Horizontal">
                            <Image Source="{StaticResource ShoppingCartIcon}" Width="20" Height="20" Margin="0,0,12,0"/>
                            <TextBlock Text="PDV Auxiliar" FontSize="15" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource SideMenuItemStyle}"
                            Command="{Binding SelectSideMenuItemCommand}"
                            CommandParameter="Fiscal">
                        <StackPanel Orientation="Horizontal">
                            <Image Source="{StaticResource DinheiroIcon}" Width="20" Height="20" Margin="0,0,12,0"/>
                            <TextBlock Text="Fiscal / NFC-e" FontSize="15" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource SideMenuItemStyle}"
                            Command="{Binding SelectSideMenuItemCommand}"
                            CommandParameter="Tributacao">
                        <StackPanel Orientation="Horizontal">
                            <Image Source="{StaticResource CadastroIcon}" Width="20" Height="20" Margin="0,0,12,0"/>
                            <TextBlock Text="Tributação" FontSize="15" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource SideMenuItemStyle}"
                            Command="{Binding SelectSideMenuItemCommand}"
                            CommandParameter="Food">
                        <StackPanel Orientation="Horizontal">
                            <Image Source="{StaticResource ComprasIcon}" Width="20" Height="20" Margin="0,0,12,0"/>
                            <TextBlock Text="Food / Comandas" FontSize="15" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource SideMenuItemStyle}"
                            Command="{Binding SelectSideMenuItemCommand}"
                            CommandParameter="Delivery">
                        <StackPanel Orientation="Horizontal">
                            <Image Source="{StaticResource EstoqueIcon}" Width="20" Height="20" Margin="0,0,12,0"/>
                            <TextBlock Text="Delivery" FontSize="15" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource SideMenuItemStyle}"
                            Command="{Binding SelectSideMenuItemCommand}"
                            CommandParameter="Relatorios">
                        <StackPanel Orientation="Horizontal">
                            <Image Source="{StaticResource ArrowUpIcon}" Width="20" Height="20" Margin="0,0,12,0"/>
                            <TextBlock Text="Relatórios" FontSize="15" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                </StackPanel>


                <!-- OUTROS -->
                <StackPanel x:Name="OutrosPanel" Visibility="Collapsed">

                    <TextBlock Text="OUTROS"
                               Style="{StaticResource MenuSectionStyle}"/>

                    <Button Style="{StaticResource SideMenuItemStyle}"
                            Command="{Binding SelectSideMenuItemCommand}"
                            CommandParameter="Configuracoes">
                        <StackPanel Orientation="Horizontal">
                            <Image Source="{StaticResource SettingsIcon}" Width="20" Height="20" Margin="0,0,12,0"/>
                            <TextBlock Text="Configurações" FontSize="15" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource SideMenuItemStyle}"
                            Command="{Binding SelectSideMenuItemCommand}"
                            CommandParameter="ConfiguracoesPlus">
                        <StackPanel Orientation="Horizontal">
                            <Image Source="{StaticResource SettingsIcon}" Width="20" Height="20" Margin="0,0,12,0"/>
                            <TextBlock Text="Configurações +" FontSize="15" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource SideMenuItemStyle}"
                            Command="{Binding SelectSideMenuItemCommand}"
                            CommandParameter="Ajuda">
                        <StackPanel Orientation="Horizontal">
                            <Image Source="{StaticResource HelpIcon}" Width="20" Height="20" Margin="0,0,12,0"/>
                            <TextBlock Text="Ajuda" FontSize="15" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource SideMenuItemStyle}"
                            Command="{Binding SelectSideMenuItemCommand}"
                            CommandParameter="Contato">
                        <StackPanel Orientation="Horizontal">
                            <Image Source="{StaticResource ContatoIcon}" Width="20" Height="20" Margin="0,0,12,0"/>
                            <TextBlock Text="Contato" FontSize="15" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource SideMenuItemStyle}"
                            Command="{Binding SelectSideMenuItemCommand}"
                            CommandParameter="Sair">
                        <StackPanel Orientation="Horizontal">
                            <Image Source="{StaticResource LogoutIcon}" Width="20" Height="20" Margin="0,0,12,0"/>
                            <TextBlock Text="Sair" FontSize="15" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                </StackPanel>

            </StackPanel>

        </ScrollViewer>
    </Border>

</UserControl>
