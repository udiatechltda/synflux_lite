<UserControl x:Class="PDV.Views.LoadingView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="1024">

    <Grid Background="#CC000000">
        <!-- Container dos quadrados -->
        <Grid Width="60" Height="20" HorizontalAlignment="Center" VerticalAlignment="Center">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Quadrado 1 -->
            <Rectangle x:Name="Square1" 
                      Grid.Column="0"
                      Width="20" 
                      Height="20" 
                      Fill="{StaticResource PrimaryBrush}"
                      RadiusX="2" 
                      RadiusY="2">
                <Rectangle.RenderTransform>
                    <ScaleTransform x:Name="Scale1" ScaleX="1" ScaleY="1"/>
                </Rectangle.RenderTransform>
            </Rectangle>

            <!-- Quadrado 2 -->
            <Rectangle x:Name="Square2" 
                      Grid.Column="2"
                      Width="20" 
                      Height="20" 
                      Fill="{StaticResource PrimaryBrush}"
                      RadiusX="2" 
                      RadiusY="2">
                <Rectangle.RenderTransform>
                    <ScaleTransform x:Name="Scale2" ScaleX="1" ScaleY="1"/>
                </Rectangle.RenderTransform>
            </Rectangle>

            <!-- Quadrado 3 -->
            <Rectangle x:Name="Square3" 
                      Grid.Column="4"
                      Width="20" 
                      Height="20" 
                      Fill="{StaticResource PrimaryBrush}"
                      RadiusX="2" 
                      RadiusY="2">
                <Rectangle.RenderTransform>
                    <ScaleTransform x:Name="Scale3" ScaleX="1" ScaleY="1"/>
                </Rectangle.RenderTransform>
            </Rectangle>
        </Grid>
    </Grid>

    <UserControl.Resources>
        <Storyboard x:Key="LoadingAnimation" RepeatBehavior="Forever">
            <!-- Animação do primeiro quadrado -->
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="Scale1" Storyboard.TargetProperty="ScaleX">
                <LinearDoubleKeyFrame KeyTime="0:0:0.0" Value="1"/>
                <LinearDoubleKeyFrame KeyTime="0:0:0.2" Value="1.3"/>
                <LinearDoubleKeyFrame KeyTime="0:0:0.4" Value="1"/>
                <LinearDoubleKeyFrame KeyTime="0:0:0.8" Value="1"/>
                <LinearDoubleKeyFrame KeyTime="0:0:1.0" Value="1.3"/>
                <LinearDoubleKeyFrame KeyTime="0:0:1.2" Value="1"/>
            </DoubleAnimationUsingKeyFrames>
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="Scale1" Storyboard.TargetProperty="ScaleY">
                <LinearDoubleKeyFrame KeyTime="0:0:0.0" Value="1"/>
                <LinearDoubleKeyFrame KeyTime="0:0:0.2" Value="1.3"/>
                <LinearDoubleKeyFrame KeyTime="0:0:0.4" Value="1"/>
                <LinearDoubleKeyFrame KeyTime="0:0:0.8" Value="1"/>
                <LinearDoubleKeyFrame KeyTime="0:0:1.0" Value="1.3"/>
                <LinearDoubleKeyFrame KeyTime="0:0:1.2" Value="1"/>
            </DoubleAnimationUsingKeyFrames>

            <!-- Animação do segundo quadrado -->
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="Scale2" Storyboard.TargetProperty="ScaleX">
                <LinearDoubleKeyFrame KeyTime="0:0:0.2" Value="1"/>
                <LinearDoubleKeyFrame KeyTime="0:0:0.4" Value="1.3"/>
                <LinearDoubleKeyFrame KeyTime="0:0:0.6" Value="1"/>
                <LinearDoubleKeyFrame KeyTime="0:0:1.0" Value="1"/>
                <LinearDoubleKeyFrame KeyTime="0:0:1.2" Value="1.3"/>
                <LinearDoubleKeyFrame KeyTime="0:0:1.4" Value="1"/>
            </DoubleAnimationUsingKeyFrames>
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="Scale2" Storyboard.TargetProperty="ScaleY">
                <LinearDoubleKeyFrame KeyTime="0:0:0.2" Value="1"/>
                <LinearDoubleKeyFrame KeyTime="0:0:0.4" Value="1.3"/>
                <LinearDoubleKeyFrame KeyTime="0:0:0.6" Value="1"/>
                <LinearDoubleKeyFrame KeyTime="0:0:1.0" Value="1"/>
                <LinearDoubleKeyFrame KeyTime="0:0:1.2" Value="1.3"/>
                <LinearDoubleKeyFrame KeyTime="0:0:1.4" Value="1"/>
            </DoubleAnimationUsingKeyFrames>

            <!-- Animação do terceiro quadrado -->
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="Scale3" Storyboard.TargetProperty="ScaleX">
                <LinearDoubleKeyFrame KeyTime="0:0:0.4" Value="1"/>
                <LinearDoubleKeyFrame KeyTime="0:0:0.6" Value="1.3"/>
                <LinearDoubleKeyFrame KeyTime="0:0:0.8" Value="1"/>
                <LinearDoubleKeyFrame KeyTime="0:0:1.2" Value="1"/>
                <LinearDoubleKeyFrame KeyTime="0:0:1.4" Value="1.3"/>
                <LinearDoubleKeyFrame KeyTime="0:0:1.6" Value="1"/>
            </DoubleAnimationUsingKeyFrames>
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="Scale3" Storyboard.TargetProperty="ScaleY">
                <LinearDoubleKeyFrame KeyTime="0:0:0.4" Value="1"/>
                <LinearDoubleKeyFrame KeyTime="0:0:0.6" Value="1.3"/>
                <LinearDoubleKeyFrame KeyTime="0:0:0.8" Value="1"/>
                <LinearDoubleKeyFrame KeyTime="0:0:1.2" Value="1"/>
                <LinearDoubleKeyFrame KeyTime="0:0:1.4" Value="1.3"/>
                <LinearDoubleKeyFrame KeyTime="0:0:1.6" Value="1"/>
            </DoubleAnimationUsingKeyFrames>
        </Storyboard>
    </UserControl.Resources>

    <UserControl.Triggers>
        <EventTrigger RoutedEvent="Loaded">
            <BeginStoryboard Storyboard="{StaticResource LoadingAnimation}"/>
        </EventTrigger>
    </UserControl.Triggers>
</UserControl>