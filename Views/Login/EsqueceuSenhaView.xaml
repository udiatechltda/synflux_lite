<UserControl x:Class="PDV.Views.EsqueceuSenhaView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:behaviors="clr-namespace:PDV.Utilities.Behaviors"
             Background="{StaticResource BackgroundDefaulBrush}"
             mc:Ignorable="d"
             d:DesignWidth="1024"
             d:DesignHeight="600">

    <UserControl.Resources>
        <Style x:Key="RecuperacaoInputBorderStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#D0D5DD"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Height" Value="48"/>
        </Style>

        <Style x:Key="RecuperacaoTextBoxStyle" TargetType="TextBox">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Foreground" Value="#111827"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
    </UserControl.Resources>

    <Grid Background="{StaticResource BackgroundDefaulBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="3*"/>
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0">
            <Grid.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#1DB8FF" Offset="0"/>
                    <GradientStop Color="#0089E0" Offset="0.6"/>
                    <GradientStop Color="#0055A4" Offset="1"/>
                </LinearGradientBrush>
            </Grid.Background>

            <Image Source="/Assets/Images/Png/bg_login.png"
                   Stretch="Uniform"
                   VerticalAlignment="Bottom"
                   HorizontalAlignment="Center"
                   Width="554"
                   Height="588"
                   Margin="0,45,0,0"/>

            <StackPanel Margin="20" VerticalAlignment="Top">
                <TextBlock Text="Sistema PDV" FontSize="35" FontWeight="Bold" Foreground="White" Margin="0,20,0,0"/>
                <TextBlock Text="Para gerenciar seu negócio" FontSize="16" Foreground="White"/>
            </StackPanel>
        </Grid>

        <Grid Grid.Column="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition Width="24*"/>
                <ColumnDefinition Width="520"/>
                <ColumnDefinition Width="25*"/>
            </Grid.ColumnDefinitions>

            <ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <Border Background="White"
                        CornerRadius="12"
                        Padding="36"
                        Width="520"
                        MinHeight="560"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                    <Border.Effect>
                        <DropShadowEffect Color="Black" BlurRadius="16" ShadowDepth="2" Opacity="0.08"/>
                    </Border.Effect>

                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Esqueci minha senha"
                                   FontSize="28"
                                   FontWeight="SemiBold"
                                   Foreground="#1A202C"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,6"/>

                        <TextBlock Text="Informe o e-mail cadastrado para gerar uma senha temporária. Depois, volte ao login e use a nova senha informada."
                                   FontSize="13"
                                   Foreground="#999999"
                                   TextWrapping="Wrap"
                                   TextAlignment="Center"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,34"/>

                        <TextBlock Text="E-mail" FontSize="13" Foreground="#8A94A6" Margin="0,0,0,6"/>

                        <Border Style="{StaticResource RecuperacaoInputBorderStyle}" Margin="0,0,0,18">
                            <TextBox x:Name="EmailUsuarioInput"
                                     Text="{Binding EmailUsuario, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource RecuperacaoTextBoxStyle}"
                                     KeyDown="EmailUsuarioInput_KeyDown"/>
                        </Border>

                        <Border Background="#EEF1F5"
                                CornerRadius="6"
                                Margin="0,0,0,18"
                                Padding="12"
                                Visibility="{Binding HasMensagem, Converter={StaticResource BoolToVisibility}}">
                            <TextBlock Text="{Binding Mensagem}" FontSize="12" Foreground="#1A202C" TextWrapping="Wrap"/>
                        </Border>

                        <Button Command="{Binding ProximoCommand}"
                                behaviors:ButtonLoading.IsEnabled="True"
                                IsEnabled="{Binding IsNotLoading}"
                                Height="48"
                                Margin="0,0,0,12"
                                BorderThickness="0"
                                Cursor="Hand"
                                FocusVisualStyle="{x:Null}">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="border" Background="#1C3E72" CornerRadius="8">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="border" Property="Background" Value="#2A52A0"/>
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter TargetName="border" Property="Background" Value="#152D56"/>
                                        </Trigger>
                                        <Trigger Property="IsEnabled" Value="False">
                                            <Setter TargetName="border" Property="Background" Value="#9CA3AF"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                            <TextBlock Text="Gerar senha temporária" FontSize="15" FontWeight="SemiBold" Foreground="White"/>
                        </Button>

                        <Button Height="48"
                                BorderThickness="0"
                                Cursor="Hand"
                                Command="{Binding CancelarCommand}">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="border"
                                            Background="White"
                                            BorderBrush="#1C3E72"
                                            BorderThickness="1"
                                            CornerRadius="8">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="border" Property="Background" Value="#EEF3FA"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                            <TextBlock Text="Voltar" FontSize="15" FontWeight="SemiBold" Foreground="#1C3E72"/>
                        </Button>
                    </StackPanel>
                </Border>
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>
