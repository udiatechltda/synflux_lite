<UserControl x:Class="PDV.Views.Cadastros.FornecedorListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vm="clr-namespace:PDV.ViewModels.Cadastros"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:FornecedorListViewModel}"
             Background="#ECEFF1">

    <UserControl.InputBindings>
        <KeyBinding Key="Insert" Command="{Binding NovoCommand}"/>
        <KeyBinding Key="F9" Command="{Binding EditarCommand}"/>
        <KeyBinding Key="F10" Command="{Binding ExcluirCommand}"/>
    </UserControl.InputBindings>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Background="White" CornerRadius="12" Padding="20,14" Margin="20,20,20,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Background="Transparent" BorderThickness="0"
                        Command="{Binding VoltarCommand}" Cursor="Hand" Margin="0,0,12,0" Padding="6,4">
                    <TextBlock Text="← Voltar" FontSize="13" Foreground="#1C3E72" FontWeight="SemiBold"/>
                </Button>
                <TextBlock Grid.Column="1" Text="Relação - Fornecedores"
                           FontSize="18" FontWeight="SemiBold" Foreground="#1A202C" VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- DATAGRID -->
        <Border Grid.Row="1" Background="White" CornerRadius="12" Margin="20,0,20,10">
            <DataGrid Style="{StaticResource ListViewDataGridStyle}"
                      ItemsSource="{Binding Items}" SelectedItem="{Binding SelectedItem, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                      HorizontalAlignment="Stretch"
                      ScrollViewer.HorizontalScrollBarVisibility="Auto"
                      Margin="0">
                <DataGrid.InputBindings>
                    <KeyBinding Key="Insert" Command="{Binding NovoCommand}"/>
                    <KeyBinding Key="F9" Command="{Binding EditarCommand}"/>
                    <KeyBinding Key="F10" Command="{Binding ExcluirCommand}"/>
                    <MouseBinding Gesture="LeftDoubleClick" Command="{Binding EditarCommand}" CommandParameter="{Binding SelectedItem, RelativeSource={RelativeSource AncestorType=DataGrid}}"/>
                </DataGrid.InputBindings>
                <DataGrid.Columns>
                    <!-- Identificação -->
                    <DataGridTextColumn Header="Id"                  Binding="{Binding Id}"                                              Width="55"/>
                    <DataGridTextColumn Header="Tipo Pessoa"         Binding="{Binding TipoPessoa}"                                      Width="90"/>
                    <DataGridTextColumn Header="Nome / Razão Social" Binding="{Binding Nome}"                                            Width="200"/>
                    <DataGridTextColumn Header="Fantasia"            Binding="{Binding Fantasia}"                                        Width="160"/>
                    <DataGridTextColumn Header="CPF / CNPJ"          Binding="{Binding CpfCnpj}"                                        Width="130"/>
                    <DataGridTextColumn Header="RG"                  Binding="{Binding Rg}"                                             Width="100"/>
                    <DataGridTextColumn Header="Órgão RG"            Binding="{Binding OrgaoRg}"                                        Width="90"/>
                    <DataGridTextColumn Header="Data Emissão RG"     Binding="{Binding DataEmissaoRg, StringFormat='dd/MM/yyyy'}"       Width="120"/>
                    <DataGridTextColumn Header="Sexo"                Binding="{Binding Sexo}"                                           Width="55"/>
                    <DataGridTextColumn Header="Insc. Estadual"      Binding="{Binding InscricaoEstadual}"                              Width="120"/>
                    <DataGridTextColumn Header="Insc. Municipal"     Binding="{Binding InscricaoMunicipal}"                             Width="120"/>
                    <!-- Contato -->
                    <DataGridTextColumn Header="Email"               Binding="{Binding Email}"                                          Width="180"/>
                    <DataGridTextColumn Header="URL"                 Binding="{Binding Url}"                                            Width="140"/>
                    <DataGridTextColumn Header="Telefone"            Binding="{Binding Telefone}"                                       Width="110"/>
                    <DataGridTextColumn Header="Celular"             Binding="{Binding Celular}"                                        Width="110"/>
                    <DataGridTextColumn Header="Contato"             Binding="{Binding Contato}"                                        Width="130"/>
                    <!-- Endereço -->
                    <DataGridTextColumn Header="CEP"                 Binding="{Binding Cep}"                                            Width="85"/>
                    <DataGridTextColumn Header="Logradouro"          Binding="{Binding Logradouro}"                                     Width="180"/>
                    <DataGridTextColumn Header="Número"              Binding="{Binding Numero}"                                         Width="70"/>
                    <DataGridTextColumn Header="Complemento"         Binding="{Binding Complemento}"                                    Width="130"/>
                    <DataGridTextColumn Header="Bairro"              Binding="{Binding Bairro}"                                         Width="120"/>
                    <DataGridTextColumn Header="Cidade"              Binding="{Binding Cidade}"                                         Width="130"/>
                    <DataGridTextColumn Header="UF"                  Binding="{Binding Uf}"                                             Width="45"/>
                    <DataGridTextColumn Header="Cód. IBGE Cidade"    Binding="{Binding CodigoIbgeCidade}"                               Width="120"/>
                    <DataGridTextColumn Header="Cód. IBGE UF"        Binding="{Binding CodigoIbgeUf}"                                   Width="100"/>
                    <!-- Datas -->
                    <DataGridTextColumn Header="Data Cadastro"       Binding="{Binding DataCadastro, StringFormat='dd/MM/yyyy HH:mm'}" Width="130"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- RODAPÉ -->
        <Grid Grid.Row="2" Margin="20,0,20,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Border Background="White" CornerRadius="10" Padding="16,8"
                    HorizontalAlignment="Left" VerticalAlignment="Center">
                <TextBlock Text="{Binding Items.Count, StringFormat='Total: {0} registro(s)'}"
                           FontSize="12" Foreground="#4A5568" VerticalAlignment="Center"/>
            </Border>

            <!-- PAGINAÇÃO -->
            <Border Grid.Column="1" Background="White" CornerRadius="10"
                    Padding="16,8" Margin="10,0" VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Linhas por página:" FontSize="12" Foreground="#4A5568"
                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <ComboBox Width="55" Height="28" FontSize="12" SelectedIndex="0"
                              VerticalContentAlignment="Center" BorderBrush="#E2E8F0">
                        <ComboBoxItem Content="10"/>
                        <ComboBoxItem Content="25"/>
                        <ComboBoxItem Content="50"/>
                    </ComboBox>
                    <Button Content="❮" Width="28" Height="28" Background="Transparent"
                            BorderThickness="0" FontSize="14" Foreground="#4A5568" Cursor="Hand" Margin="8,0,0,0"/>
                    <Button Content="❯" Width="28" Height="28" Background="Transparent"
                            BorderThickness="0" FontSize="14" Foreground="#4A5568" Cursor="Hand"/>
                </StackPanel>
            </Border>

            <!-- BOTÃO + -->
            <Button Grid.Column="2" Style="{StaticResource DefaultButtonStyle}"
                    Command="{Binding EditarCommand}" CommandParameter="{Binding SelectedItem}" Width="110" Height="40"
                    Margin="0,0,10,0" VerticalAlignment="Center"
                    ToolTip="Editar selecionado (F9)">
                <TextBlock Text="Editar [F9]" FontSize="12" FontWeight="SemiBold"/>
            </Button>

            <Button Grid.Column="3" Style="{StaticResource DefaultButtonStyle}"
                    Command="{Binding ExcluirCommand}" CommandParameter="{Binding SelectedItem}" Width="120" Height="40"
                    Margin="0,0,10,0" VerticalAlignment="Center"
                    ToolTip="Excluir selecionado (F10)">
                <TextBlock Text="Excluir [F10]" FontSize="12" FontWeight="SemiBold"/>
            </Button>

            <Button Grid.Column="4" Style="{StaticResource AddButtonStyle}"
                    Command="{Binding NovoCommand}" VerticalAlignment="Center" ToolTip="Novo Fornecedor">
                <TextBlock Text="+" FontSize="28" Margin="0,-2,0,0"/>
            </Button>
        </Grid>
    </Grid>
</UserControl>
