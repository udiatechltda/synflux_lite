<UserControl x:Class="PDV.Views.Cadastros.ProdutoListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vm="clr-namespace:PDV.ViewModels.Cadastros"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:ProdutoListViewModel}"
             Background="#ECEFF1">

    <UserControl.InputBindings>
        <KeyBinding Key="Insert" Command="{Binding NovoCommand}"/>
        <KeyBinding Key="F9" Command="{Binding EditarCommand}"/>
        <KeyBinding Key="F10" Command="{Binding ExcluirCommand}"/>
    </UserControl.InputBindings>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Background="White" CornerRadius="12" Padding="20,14" Margin="20,20,20,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Background="Transparent" BorderThickness="0"
                        Command="{Binding VoltarCommand}" Cursor="Hand" Margin="0,0,12,0" Padding="6,4">
                    <TextBlock Text="← Voltar" FontSize="13" Foreground="#1C3E72" FontWeight="SemiBold"/>
                </Button>
                <TextBlock Grid.Column="1" Text="Relação - Produtos"
                           FontSize="18" FontWeight="SemiBold" Foreground="#1A202C" VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- DATAGRID -->
        <Border Grid.Row="1" Background="White" CornerRadius="12" Margin="20,0,20,10">
            <DataGrid Style="{StaticResource ListViewDataGridStyle}"
                      ItemsSource="{Binding Items}" SelectedItem="{Binding SelectedItem, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                      HorizontalAlignment="Stretch"
                      ScrollViewer.HorizontalScrollBarVisibility="Auto"
                      Margin="0">
                <DataGrid.InputBindings>
                    <KeyBinding Key="Insert" Command="{Binding NovoCommand}"/>
                    <KeyBinding Key="F9" Command="{Binding EditarCommand}"/>
                    <KeyBinding Key="F10" Command="{Binding ExcluirCommand}"/>
                    <MouseBinding Gesture="LeftDoubleClick" Command="{Binding EditarCommand}" CommandParameter="{Binding SelectedItem, RelativeSource={RelativeSource AncestorType=DataGrid}}"/>
                </DataGrid.InputBindings>
                <DataGrid.Columns>
                    <!-- Identificação -->
                    <DataGridTextColumn Header="Id"               Binding="{Binding Id}"                                              Width="55"/>
                    <DataGridTextColumn Header="Nome"             Binding="{Binding Nome}"                                            Width="200"/>
                    <DataGridTextColumn Header="GTIN / EAN"       Binding="{Binding Gtin}"                                            Width="130"/>
                    <DataGridTextColumn Header="Cód. Interno"     Binding="{Binding CodigoInterno}"                                   Width="100"/>
                    <DataGridTextColumn Header="Situação"         Binding="{Binding Situacao}"                                        Width="90"/>
                    <!-- Valores -->
                    <DataGridTextColumn Header="Preço Compra"     Binding="{Binding ValorCompra, StringFormat='N2'}"                  Width="110"/>
                    <DataGridTextColumn Header="Preço Venda"      Binding="{Binding ValorVenda, StringFormat='N2'}"                   Width="110"/>
                    <DataGridTextColumn Header="Custo"            Binding="{Binding ValorCusto, StringFormat='N2'}"                   Width="100"/>
                    <!-- Estoque -->
                    <DataGridTextColumn Header="Estoque"          Binding="{Binding QuantidadeEstoque, StringFormat='N3'}"            Width="90"/>
                    <DataGridTextColumn Header="Est. Mínimo"      Binding="{Binding EstoqueMinimo, StringFormat='N3'}"                Width="90"/>
                    <DataGridTextColumn Header="Est. Máximo"      Binding="{Binding EstoqueMaximo, StringFormat='N3'}"                Width="90"/>
                    <!-- Fiscal -->
                    <DataGridTextColumn Header="NCM"              Binding="{Binding CodigoNcm}"                                      Width="90"/>
                    <DataGridTextColumn Header="CEST"             Binding="{Binding CodigoCest}"                                     Width="90"/>
                    <DataGridTextColumn Header="CST"              Binding="{Binding Cst}"                                            Width="70"/>
                    <DataGridTextColumn Header="CSOSN"            Binding="{Binding Csosn}"                                         Width="75"/>
                    <DataGridTextColumn Header="IAT"              Binding="{Binding Iat}"                                            Width="60"/>
                    <DataGridTextColumn Header="IPPT"             Binding="{Binding Ippt}"                                           Width="60"/>
                    <DataGridTextColumn Header="Tipo SPED"        Binding="{Binding TipoItemSped}"                                   Width="90"/>
                    <!-- Alíquotas -->
                    <DataGridTextColumn Header="ICMS (%)"         Binding="{Binding TaxaIcms, StringFormat='N2'}"                    Width="80"/>
                    <DataGridTextColumn Header="IPI (%)"          Binding="{Binding TaxaIpi, StringFormat='N2'}"                     Width="75"/>
                    <DataGridTextColumn Header="PIS (%)"          Binding="{Binding TaxaPis, StringFormat='N2'}"                     Width="75"/>
                    <DataGridTextColumn Header="COFINS (%)"       Binding="{Binding TaxaCofins, StringFormat='N2'}"                  Width="85"/>
                    <DataGridTextColumn Header="ISSQN (%)"        Binding="{Binding TaxaIssqn, StringFormat='N2'}"                   Width="85"/>
                    <!-- Outros -->
                    <DataGridTextColumn Header="Totalizador"      Binding="{Binding TotalizadorParcial}"                             Width="100"/>
                    <DataGridTextColumn Header="ECF ICMS ST"      Binding="{Binding EcfIcmsSt}"                                     Width="90"/>
                    <DataGridTextColumn Header="Cód. Balança"     Binding="{Binding CodigoBalanca}"                                  Width="100"/>
                    <DataGridTextColumn Header="PAF-P ST"         Binding="{Binding PafPSt}"                                        Width="80"/>
                    <DataGridTextColumn Header="Id Unidade"       Binding="{Binding IdProdutoUnidade}"                               Width="90"/>
                    <DataGridTextColumn Header="Id Tipo"          Binding="{Binding IdProdutoTipo}"                                  Width="80"/>
                    <DataGridTextColumn Header="Id Subgrupo"      Binding="{Binding IdProdutoSubgrupo}"                              Width="95"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- RODAPÉ -->
        <Grid Grid.Row="2" Margin="20,0,20,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Border Background="White" CornerRadius="10" Padding="16,8"
                    HorizontalAlignment="Left" VerticalAlignment="Center">
                <TextBlock Text="{Binding Items.Count, StringFormat='Total: {0} registro(s)'}"
                           FontSize="12" Foreground="#4A5568" VerticalAlignment="Center"/>
            </Border>

            <!-- PAGINAÇÃO -->
            <Border Grid.Column="1" Background="White" CornerRadius="10"
                    Padding="16,8" Margin="10,0" VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Linhas por página:" FontSize="12" Foreground="#4A5568"
                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <ComboBox Width="55" Height="28" FontSize="12" SelectedIndex="0"
                              VerticalContentAlignment="Center" BorderBrush="#E2E8F0">
                        <ComboBoxItem Content="10"/>
                        <ComboBoxItem Content="25"/>
                        <ComboBoxItem Content="50"/>
                    </ComboBox>
                    <Button Content="❮" Width="28" Height="28" Background="Transparent"
                            BorderThickness="0" FontSize="14" Foreground="#4A5568" Cursor="Hand" Margin="8,0,0,0"/>
                    <Button Content="❯" Width="28" Height="28" Background="Transparent"
                            BorderThickness="0" FontSize="14" Foreground="#4A5568" Cursor="Hand"/>
                </StackPanel>
            </Border>

            <!-- BOTÃO + -->
            <Button Grid.Column="2" Style="{StaticResource DefaultButtonStyle}"
                    Command="{Binding EditarCommand}" CommandParameter="{Binding SelectedItem}" Width="110" Height="40"
                    Margin="0,0,10,0" VerticalAlignment="Center"
                    ToolTip="Editar selecionado (F9)">
                <TextBlock Text="Editar [F9]" FontSize="12" FontWeight="SemiBold"/>
            </Button>

            <Button Grid.Column="3" Style="{StaticResource DefaultButtonStyle}"
                    Command="{Binding ExcluirCommand}" CommandParameter="{Binding SelectedItem}" Width="120" Height="40"
                    Margin="0,0,10,0" VerticalAlignment="Center"
                    ToolTip="Excluir selecionado (F10)">
                <TextBlock Text="Excluir [F10]" FontSize="12" FontWeight="SemiBold"/>
            </Button>

            <Button Grid.Column="4" Style="{StaticResource AddButtonStyle}"
                    Command="{Binding NovoCommand}" VerticalAlignment="Center" ToolTip="Novo Produto">
                <TextBlock Text="+" FontSize="28" Margin="0,-2,0,0"/>
            </Button>
        </Grid>
    </Grid>
</UserControl>
