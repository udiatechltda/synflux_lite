<UserControl x:Class="PDV.Views.Cadastros.ColaboradorListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vm="clr-namespace:PDV.ViewModels.Cadastros"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:ColaboradorListViewModel}"
             Background="#ECEFF1">

    <UserControl.InputBindings>
        <KeyBinding Key="Insert" Command="{Binding NovoCommand}"/>
        <KeyBinding Key="F9" Command="{Binding EditarCommand}"/>
        <KeyBinding Key="F10" Command="{Binding ExcluirCommand}"/>
    </UserControl.InputBindings>

    <UserControl.Resources>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#F9FAFB"/>
            <Setter Property="Foreground" Value="#6B7280"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="BorderBrush" Value="#E5E7EB"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#EFF6FF"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#DBEAFE"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#1A202C"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border Padding="{TemplateBinding Padding}" Background="{TemplateBinding Background}">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Foreground" Value="#1A202C"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ComboBoxDashStyle" TargetType="ComboBox">
            <Setter Property="Height" Value="32"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#111827"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="border" Background="{TemplateBinding Background}"
                                    CornerRadius="6" BorderBrush="#D1D5DB" BorderThickness="1" Padding="10,0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <ContentPresenter Grid.Column="0"
                                                      Content="{TemplateBinding SelectionBoxItem}"
                                                      ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                      VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="∨" FontSize="10"
                                               Foreground="#6B7280" VerticalAlignment="Center" Margin="8,0,0,0"/>
                                </Grid>
                            </Border>
                            <ToggleButton Opacity="0"
                                          IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                          Focusable="False"/>
                            <Popup IsOpen="{TemplateBinding IsDropDownOpen}" Placement="Bottom"
                                   AllowsTransparency="True" Focusable="False">
                                <Border Background="White" CornerRadius="8"
                                        BorderBrush="#E5E7EB" BorderThickness="1" Margin="0,4,0,0">
                                    <ScrollViewer>
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#9CA3AF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="36"/>
            <Setter Property="Background" Value="#1C3E72"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <ContentPresenter/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#2A52A0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ScrollArrowButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="28"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E5E7EB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#EFF6FF"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#BFDBFE"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#DBEAFE"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </UserControl.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Grid.Row="0" Background="White" CornerRadius="12" Padding="20" Margin="0,0,0,15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" Background="Transparent" BorderThickness="0"
                        Command="{Binding VoltarCommand}" Cursor="Hand"
                        Margin="0,0,12,0" Padding="6,4">
                    <TextBlock Text="←" FontSize="20" Foreground="#1C3E72" FontWeight="SemiBold"/>
                </Button>

                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="Relação - Colaboradores"
                               FontSize="18" FontWeight="SemiBold" Foreground="#1A202C"/>
                    <TextBlock Text="PDV - Cadastros" FontSize="11" Foreground="#999999"/>
                </StackPanel>

                <Button Grid.Column="2" Content="+" FontSize="22" Margin="5,0"
                        Width="40" Height="40" Background="#1C3E72" Foreground="White"
                        BorderThickness="0" Cursor="Hand"
                        Command="{Binding NovoCommand}" ToolTip="Novo Colaborador">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="border" Background="{TemplateBinding Background}"
                                    CornerRadius="6" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="border" Property="Background" Value="#2A52A0"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </Border>

        <!-- BUSCA -->
        <Border Grid.Row="1" Background="White" CornerRadius="12" Padding="20" Margin="0,0,0,15">
            <StackPanel>
                <TextBlock Text="Pesquisar Colaborador" FontSize="12" Foreground="#8A94A6" Margin="0,0,0,5"/>
                <Border CornerRadius="8" BorderBrush="#D0D5DD" BorderThickness="1" Background="White" Height="40">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Path Grid.Column="0" Width="14" Height="14" Margin="12,0,8,0"
                              VerticalAlignment="Center" Stroke="#8A94A6" StrokeThickness="1.5"
                              Data="M11 11 L16 16 M13 7 A6 6 0 1 1 1 7 A6 6 0 1 1 13 7"/>
                        <TextBox Grid.Column="1" FontSize="14" Background="Transparent"
                                 BorderThickness="0" VerticalContentAlignment="Center"
                                 Foreground="#000" Padding="0"
                                 Text="{Binding TermoBusca, UpdateSourceTrigger=PropertyChanged}">
                            <TextBox.InputBindings>
                                <KeyBinding Key="Return" Command="{Binding PesquisarCommand}"/>
                            </TextBox.InputBindings>
                        </TextBox>
                    </Grid>
                </Border>
            </StackPanel>
        </Border>

        <!-- DATAGRID -->
        <Border Grid.Row="2" Background="White" CornerRadius="12" Padding="10" Margin="0,0,0,15">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="{Binding InfoResultado}"
                           FontSize="12" Foreground="#6B7280"
                           HorizontalAlignment="Center"/>

                <ScrollViewer Grid.Row="1"
                              x:Name="svDataGrid"
                              HorizontalScrollBarVisibility="Hidden"
                              VerticalScrollBarVisibility="Disabled">
                    <DataGrid x:Name="dgColaboradores"
                              ItemsSource="{Binding Items}"
                              SelectedItem="{Binding SelectedItem, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              IsReadOnly="True"
                              Background="White"
                              BorderThickness="0"
                              HeadersVisibility="Column"
                              RowBackground="White"
                              AlternatingRowBackground="#F9FAFB"
                              SelectionMode="Single"
                              SelectionUnit="FullRow"
                              CanUserResizeRows="False"
                              GridLinesVisibility="Horizontal"
                              HorizontalGridLinesBrush="#F3F4F6"
                              ScrollViewer.HorizontalScrollBarVisibility="Hidden"
                              ScrollViewer.VerticalScrollBarVisibility="Auto">

                        <DataGrid.InputBindings>
                            <KeyBinding Key="Insert" Command="{Binding NovoCommand}"/>
                            <KeyBinding Key="F9" Command="{Binding EditarCommand}"/>
                            <KeyBinding Key="F10" Command="{Binding ExcluirCommand}"/>
                            <MouseBinding Gesture="LeftDoubleClick" Command="{Binding EditarCommand}" CommandParameter="{Binding SelectedItem, RelativeSource={RelativeSource AncestorType=DataGrid}}"/>
                        </DataGrid.InputBindings>

                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Id"                Binding="{Binding Id}"                                         Width="55"/>
                            <DataGridTextColumn Header="Nome"              Binding="{Binding Nome}"                                        Width="200"/>
                            <DataGridTextColumn Header="CPF"               Binding="{Binding Cpf}"                                         Width="120"/>
                            <DataGridTextColumn Header="Telefone"          Binding="{Binding Telefone}"                                     Width="120"/>
                            <DataGridTextColumn Header="Celular"           Binding="{Binding Celular}"                                      Width="120"/>
                            <DataGridTextColumn Header="Email"             Binding="{Binding Email}"                                        Width="180"/>
                            <DataGridTextColumn Header="Comissão Vista"    Binding="{Binding ComissaoVista, StringFormat={}{0:N2}%}"         Width="120"/>
                            <DataGridTextColumn Header="Comissão Prazo"    Binding="{Binding ComissaoPrazo, StringFormat={}{0:N2}%}"         Width="120"/>
                            <DataGridTextColumn Header="Nível Autorização" Binding="{Binding NivelAutorizacao}"                             Width="200"/>
                            <DataGridTextColumn Header="Veículo Entrega"   Binding="{Binding EntregadorVeiculo}"                            Width="130"/>
                        </DataGrid.Columns>

                        <DataGrid.Style>
                            <Style TargetType="DataGrid">
                                <Style.Triggers>
                                    <Trigger Property="HasItems" Value="False">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="DataGrid">
                                                    <Border Background="White">
                                                        <Grid>
                                                            <Grid.RowDefinitions>
                                                                <RowDefinition Height="Auto"/>
                                                                <RowDefinition Height="*"/>
                                                            </Grid.RowDefinitions>
                                                            <DataGridColumnHeadersPresenter Grid.Row="0"/>
                                                            <StackPanel Grid.Row="1" HorizontalAlignment="Center"
                                                                        VerticalAlignment="Center" Margin="0,40">
                                                                <TextBlock Text="Nenhum registro encontrado"
                                                                           FontSize="14" Foreground="#8A94A6"
                                                                           HorizontalAlignment="Center"/>
                                                            </StackPanel>
                                                        </Grid>
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.Style>

                    </DataGrid>
                </ScrollViewer>

                <!-- SETAS DE SCROLL HORIZONTAL -->
                <Border Grid.Row="2" Background="White" Padding="0,6,0,0">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button Style="{StaticResource ScrollArrowButtonStyle}"
                                Margin="0,0,6,0"
                                Click="BtnScrollEsquerda_Click">
                            <TextBlock Text="‹" FontSize="16" Foreground="#4A5568"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       Margin="0,-1,0,0"/>
                        </Button>
                        <Button Style="{StaticResource ScrollArrowButtonStyle}"
                                Click="BtnScrollDireita_Click">
                            <TextBlock Text="›" FontSize="16" Foreground="#4A5568"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       Margin="0,-1,0,0"/>
                        </Button>
                    </StackPanel>
                </Border>

            </Grid>
        </Border>

        <!-- RODAPÉ -->
        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- BOTÃO FILTRO -->
            <Button Grid.Column="0"
                    Style="{StaticResource ActionButtonStyle}"
                    Command="{Binding FiltroCommand}"
                    ToolTip="Filtro [F11]"
                    VerticalAlignment="Center">
                <TextBlock Text="Filtro" FontSize="12" FontWeight="SemiBold"/>
            </Button>

            <!-- BOTÃO RELATÓRIO -->
            <Button Grid.Column="1"
                    Style="{StaticResource ActionButtonStyle}"
                    Command="{Binding RelatorioCommand}"
                    ToolTip="Relatório [F8]"
                    VerticalAlignment="Center"
                    Margin="10,0,0,0">
                <TextBlock Text="Relatório" FontSize="12" FontWeight="SemiBold"/>
            </Button>

            <!-- PAGINAÇÃO -->
            <Button Grid.Column="2"
                    Style="{StaticResource ActionButtonStyle}"
                    Command="{Binding EditarCommand}"
                    CommandParameter="{Binding SelectedItem}"
                    ToolTip="Editar selecionado (F9)"
                    VerticalAlignment="Center"
                    Margin="10,0,0,0">
                <TextBlock Text="Editar [F9]" FontSize="12" FontWeight="SemiBold"/>
            </Button>

            <Button Grid.Column="3"
                    Style="{StaticResource ActionButtonStyle}"
                    Command="{Binding ExcluirCommand}"
                    CommandParameter="{Binding SelectedItem}"
                    ToolTip="Excluir selecionado (F10)"
                    VerticalAlignment="Center"
                    Margin="10,0,0,0">
                <TextBlock Text="Excluir [F10]" FontSize="12" FontWeight="SemiBold"/>
            </Button>

            <Border Grid.Column="5" Background="White" CornerRadius="10"
                    Padding="16,8" Margin="10,0,0,0" VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Linhas por página:"
                               FontSize="12" Foreground="#4A5568"
                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <ComboBox x:Name="cbLinhas"
                              Style="{StaticResource ComboBoxDashStyle}"
                              Width="65" Height="32" SelectedIndex="0">
                        <ComboBoxItem Content="10"/>
                        <ComboBoxItem Content="25"/>
                        <ComboBoxItem Content="50"/>
                        <ComboBoxItem Content="100"/>
                    </ComboBox>
                    <TextBlock x:Name="txtPaginacao"
                               Text="1 a 10 de 0"
                               FontSize="12" Foreground="#4A5568"
                               VerticalAlignment="Center" Margin="16,0"/>
                    <Button Content="❮" Width="28" Height="28" Background="Transparent"
                            BorderThickness="0" FontSize="14" Foreground="#4A5568" Cursor="Hand"/>
                    <Button Content="❯" Width="28" Height="28" Background="Transparent"
                            BorderThickness="0" FontSize="14" Foreground="#4A5568" Cursor="Hand"/>
                </StackPanel>
            </Border>

        </Grid>

    </Grid>
</UserControl>
