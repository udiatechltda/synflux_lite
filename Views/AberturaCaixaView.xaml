<UserControl x:Class="PDV.Views.AberturaCaixaView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#ECEFF1">

    <UserControl.Resources>
        <Style x:Key="CaixaButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#1C3E72"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#2A52A0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="White" CornerRadius="12" Padding="20,14" Margin="0,0,0,15">
            <StackPanel>
                <TextBlock Text="{Binding TituloTela}"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Foreground="#1A202C"/>
                <TextBlock Text="{Binding DescricaoTela}"
                           FontSize="12"
                           Foreground="#6B7280"
                           Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Background="White" CornerRadius="12" Padding="28" Margin="0,0,0,15">
            <Grid MaxWidth="760" HorizontalAlignment="Center" VerticalAlignment="Top">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,28">
                    <StackPanel Orientation="Horizontal" Margin="0,0,50,0">
                        <Image Source="{StaticResource CalendarIcon}" Width="16" Height="16" Margin="0,0,14,0"/>
                        <StackPanel>
                            <TextBlock Text="Data da Abertura" FontSize="13" Foreground="#111827"/>
                            <TextBlock Text="{Binding DataAbertura, StringFormat=dd/MM/yyyy}" FontSize="12" FontWeight="SemiBold" Foreground="#6B7280"/>
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal">
                        <Image Source="{StaticResource ClockIcon}" Width="16" Height="16" Margin="0,0,14,0"/>
                        <StackPanel>
                            <TextBlock Text="Hora da Abertura" FontSize="13" Foreground="#111827"/>
                            <TextBlock Text="{Binding HoraAbertura}" FontSize="12" FontWeight="SemiBold" Foreground="#1C3E72"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Row="1" Margin="0,0,0,20">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="IsEnabled" Value="True"/>
                            <Setter Property="Visibility" Value="Visible"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsCaixaAberto}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <TextBlock Text="Fundo de Troco" FontSize="12" Foreground="#8A94A6" Margin="0,0,0,6"/>
                    <Border CornerRadius="8" BorderBrush="#D0D5DD" BorderThickness="1" Background="White">
                        <TextBox Height="44"
                                 FontSize="18"
                                 FontWeight="SemiBold"
                                 Padding="12,0"
                                 HorizontalContentAlignment="Right"
                                 VerticalContentAlignment="Center"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Text="{Binding FundoTrocoTexto, UpdateSourceTrigger=PropertyChanged}"/>
                    </Border>
                </StackPanel>

                <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,28">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="IsEnabled" Value="True"/>
                            <Setter Property="Visibility" Value="Visible"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsCaixaAberto}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <Button Content="+ R$ 50" Command="{Binding Somar50Command}" Style="{StaticResource CaixaButtonStyle}" Margin="6"/>
                    <Button Content="+ R$ 100" Command="{Binding Somar100Command}" Style="{StaticResource CaixaButtonStyle}" Margin="6"/>
                    <Button Content="+ R$ 200" Command="{Binding Somar200Command}" Style="{StaticResource CaixaButtonStyle}" Margin="6"/>
                    <Button Content="Limpar" Command="{Binding LimparCommand}" Style="{StaticResource CaixaButtonStyle}" Margin="6"/>
                </StackPanel>

                <StackPanel Grid.Row="1" Grid.RowSpan="2" Margin="0,0,0,24">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsCaixaAberto}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>

                    <UniformGrid Columns="3" Margin="0,0,0,18">
                        <Border Background="#F8FAFC" CornerRadius="10" Padding="14" Margin="6">
                            <StackPanel>
                                <TextBlock Text="Total do caixa" Foreground="#64748B" FontSize="12"/>
                                <TextBlock Text="{Binding TotalCaixaTexto}" Foreground="#1C3E72" FontSize="20" FontWeight="Bold" Margin="0,6,0,0"/>
                            </StackPanel>
                        </Border>
                        <Border Background="#F8FAFC" CornerRadius="10" Padding="14" Margin="6">
                            <StackPanel>
                                <TextBlock Text="Total dinheiro" Foreground="#64748B" FontSize="12"/>
                                <TextBlock Text="{Binding TotalDinheiroTexto}" Foreground="#047857" FontSize="20" FontWeight="Bold" Margin="0,6,0,0"/>
                            </StackPanel>
                        </Border>
                        <Border Background="#F8FAFC" CornerRadius="10" Padding="14" Margin="6">
                            <StackPanel>
                                <TextBlock Text="Total débito" Foreground="#64748B" FontSize="12"/>
                                <TextBlock Text="{Binding TotalDebitoTexto}" Foreground="#1C3E72" FontSize="20" FontWeight="Bold" Margin="0,6,0,0"/>
                            </StackPanel>
                        </Border>
                        <Border Background="#F8FAFC" CornerRadius="10" Padding="14" Margin="6">
                            <StackPanel>
                                <TextBlock Text="Total crédito" Foreground="#64748B" FontSize="12"/>
                                <TextBlock Text="{Binding TotalCreditoTexto}" Foreground="#1C3E72" FontSize="20" FontWeight="Bold" Margin="0,6,0,0"/>
                            </StackPanel>
                        </Border>
                        <Border Background="#F8FAFC" CornerRadius="10" Padding="14" Margin="6">
                            <StackPanel>
                                <TextBlock Text="Total Pix" Foreground="#64748B" FontSize="12"/>
                                <TextBlock Text="{Binding TotalPixTexto}" Foreground="#1C3E72" FontSize="20" FontWeight="Bold" Margin="0,6,0,0"/>
                            </StackPanel>
                        </Border>
                        <Border Background="#F8FAFC" CornerRadius="10" Padding="14" Margin="6">
                            <StackPanel>
                                <TextBlock Text="Outros pagamentos" Foreground="#64748B" FontSize="12"/>
                                <TextBlock Text="{Binding TotalOutrosTexto}" Foreground="#1C3E72" FontSize="20" FontWeight="Bold" Margin="0,6,0,0"/>
                            </StackPanel>
                        </Border>
                    </UniformGrid>

                    <DataGrid ItemsSource="{Binding TotaisPagamento}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              IsReadOnly="True"
                              HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal"
                              BorderThickness="0"
                              Height="160">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Forma de pagamento" Binding="{Binding FormaPagamento}" Width="*"/>
                            <DataGridTextColumn Header="Valor esperado" Binding="{Binding ValorTexto}" Width="160"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <Grid Margin="0,18,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{Binding TotalVendasTexto, StringFormat=Vendas: {0}}" Foreground="#334155" FontWeight="SemiBold"/>
                        <TextBlock Grid.Column="1" Text="{Binding TotalSuprimentosTexto, StringFormat=Suprimentos: {0}}" Foreground="#334155" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                        <TextBlock Grid.Column="2" Text="{Binding TotalSangriasTexto, StringFormat=Sangrias: {0}}" Foreground="#334155" FontWeight="SemiBold" HorizontalAlignment="Right"/>
                    </Grid>
                </StackPanel>

                <Border Grid.Row="3" Background="#F8FAFC" CornerRadius="10" Padding="18">
                    <DockPanel>
                        <TextBlock Text="{Binding TextoTotalInicial}" FontWeight="SemiBold" Foreground="#111827" DockPanel.Dock="Left"/>
                        <TextBlock Foreground="#1C3E72" FontWeight="Bold" HorizontalAlignment="Right">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="{Binding FundoTroco, StringFormat=R$ {0:N2}}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsCaixaAberto}" Value="True">
                                            <Setter Property="Text" Value="{Binding TotalCaixaTexto}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </DockPanel>
                </Border>
            </Grid>
        </Border>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center">
            <Button Content="Cancelar"
                    Background="#6B7280"
                    Foreground="White"
                    Margin="12"
                    Padding="18,8"
                    BorderThickness="0"
                    Cursor="Hand"
                    Command="{Binding CancelarCommand}"/>
            <Button Content="{Binding TextoAcaoCaixa}"
                    Background="#1C3E72"
                    Foreground="White"
                    Margin="12"
                    Padding="22,8"
                    BorderThickness="0"
                    Cursor="Hand"
                    Command="{Binding ConfirmarCommand}"/>
        </StackPanel>
    </Grid>
</UserControl>
