<UserControl x:Class="PDV.Views.HomeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:utilities="clr-namespace:PDV.Utilities"
             mc:Ignorable="d"
             d:DesignHeight="800" d:DesignWidth="1200"
             Background="#ECEFF1">

    <UserControl.Resources>
        <utilities:ImagePathToBitmapConverter x:Key="ImagePathToBitmapConverter"/>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#F9FAFB"/>
            <Setter Property="Foreground" Value="#6B7280"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="BorderBrush" Value="#E5E7EB"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#EFF6FF"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#DBEAFE"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#1A202C"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border Padding="{TemplateBinding Padding}" Background="{TemplateBinding Background}">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Foreground" Value="#1A202C"/>
                </Trigger>
            </Style.Triggers>
        </Style>

    </UserControl.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Background="White" CornerRadius="12" Padding="20" Margin="0,0,0,15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="Caixa Aberto" FontSize="18" FontWeight="SemiBold" Foreground="#000"/>
                    <TextBlock Text="PDV - Gratuito" FontSize="11" Foreground="#999999"/>
                </StackPanel>

                <!-- Botoes do cabecalho do Caixa Aberto removidos visualmente para possivel retorno futuro.
                <Button Grid.Column="1" Content="+" FontSize="20" Width="40" Height="40"
                        Margin="5" Background="#1C3E72" Foreground="White"
                        BorderThickness="0" Cursor="Hand"
                        Command="{Binding AbrirImportarProdutoCommand}">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="border" Background="{TemplateBinding Background}"
                                    CornerRadius="6" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="border" Property="Background" Value="#2A52A0"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <Button Grid.Column="2" Content="☰" Width="40" Height="40"
                        Margin="5" Background="#1C3E72" Foreground="White"
                        BorderThickness="0" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="border" Background="{TemplateBinding Background}"
                                    CornerRadius="6" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="border" Property="Background" Value="#2A52A0"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                -->
            </Grid>
        </Border>

        <!-- BUSCA -->
        <Border Grid.Row="1" Background="White" CornerRadius="12" Padding="20" Margin="0,0,0,15">
            <StackPanel>
                <TextBlock Text="Pesquisar Produto" FontSize="12" Foreground="#8A94A6" Margin="0,0,0,5"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                <Border Grid.Column="0" CornerRadius="8" BorderBrush="#D0D5DD" BorderThickness="1" Background="White" Height="40">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Path Grid.Column="0" Width="14" Height="14" Margin="12,0,8,0"
                              VerticalAlignment="Center" Stroke="#8A94A6" StrokeThickness="1.5"
                              Data="M11 11 L16 16 M13 7 A6 6 0 1 1 1 7 A6 6 0 1 1 13 7"/>
                        <TextBox Grid.Column="1" FontSize="14" Background="Transparent"
                                 BorderThickness="0" VerticalContentAlignment="Center"
                                 Foreground="#000" Padding="0"
                                 Text="{Binding TermoBusca, UpdateSourceTrigger=PropertyChanged}">
                            <TextBox.InputBindings>
                                <KeyBinding Key="Return" Command="{Binding PesquisarCommand}"/>
                            </TextBox.InputBindings>
                        </TextBox>
                    </Grid>
                </Border>
                    <Button Grid.Column="1"
                            Content="Pesquisar"
                            Margin="10,0,0,0"
                            Padding="14,0"
                            Height="40"
                            Background="#1C3E72"
                            Foreground="White"
                            BorderThickness="0"
                            Cursor="Hand"
                            Command="{Binding PesquisarCommand}"/>
                    <Button Grid.Column="2"
                            Content="Adicionar"
                            Margin="10,0,0,0"
                            Padding="14,0"
                            Height="40"
                            Background="#1C3E72"
                            Foreground="White"
                            BorderThickness="0"
                            Cursor="Hand"
                            Command="{Binding AdicionarProdutoCommand}"/>
                </Grid>
                <Grid Margin="0,10,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="220"/>
                    </Grid.ColumnDefinitions>

                    <ListBox Grid.Column="0"
                             ItemsSource="{Binding ProdutosEncontrados}"
                             SelectedItem="{Binding ProdutoSelecionado}"
                             MaxHeight="170"
                             BorderBrush="#E5E7EB"
                             BorderThickness="1"
                             Background="#F9FAFB">
                        <ListBox.InputBindings>
                            <MouseBinding MouseAction="LeftDoubleClick" Command="{Binding AdicionarProdutoCommand}"/>
                        </ListBox.InputBindings>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="6,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="78"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="110"/>
                                        <ColumnDefinition Width="110"/>
                                    </Grid.ColumnDefinitions>

                                    <Border Width="68"
                                            Height="68"
                                            BorderBrush="#E5E7EB"
                                            BorderThickness="1"
                                            Background="White"
                                            CornerRadius="6"
                                            Margin="0,0,10,0">
                                        <Grid>
                                            <TextBlock Text="Sem imagem"
                                                       TextWrapping="Wrap"
                                                       TextAlignment="Center"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       Foreground="#9CA3AF"
                                                       FontSize="10"/>
                                            <Image Source="{Binding ImagemLocalPath, Converter={StaticResource ImagePathToBitmapConverter}}"
                                                   Stretch="UniformToFill"/>
                                        </Grid>
                                    </Border>

                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Descricao}" FontSize="13" Foreground="#1A202C"/>
                                        <TextBlock Text="{Binding Gtin}" FontSize="11" Foreground="#6B7280"/>
                                    </StackPanel>
                                    <TextBlock Grid.Column="2"
                                               Text="{Binding ValorUnitario, StringFormat=R$ {0:N2}}"
                                               HorizontalAlignment="Right"
                                               VerticalAlignment="Center"
                                               Foreground="#1C3E72"
                                               FontWeight="SemiBold"/>
                                    <TextBlock Grid.Column="3"
                                               Text="{Binding QuantidadeEstoque, StringFormat=Estoque {0:N3}}"
                                               HorizontalAlignment="Right"
                                               VerticalAlignment="Center"
                                               Foreground="#6B7280"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <Border Grid.Column="1"
                            Margin="12,0,0,0"
                            BorderBrush="#E5E7EB"
                            BorderThickness="1"
                            Background="#F9FAFB"
                            CornerRadius="8"
                            Height="170">
                        <Grid>
                            <TextBlock Text="Imagem do produto"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Foreground="#9CA3AF"
                                       FontSize="12"/>
                            <Image Source="{Binding ProdutoSelecionadoImagemPath, Converter={StaticResource ImagePathToBitmapConverter}}"
                                   Stretch="Uniform"
                                   Margin="8"/>
                        </Grid>
                    </Border>
                </Grid>
            </StackPanel>
        </Border>

        <!-- DATAGRID -->
        <Border Grid.Row="2"
                Background="White"
                CornerRadius="12"
                Padding="10"
                Margin="0,0,0,15"
                Visibility="{Binding MostrarMontagemVenda, Converter={StaticResource BoolToVisibility}}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="{Binding InfoResultado}"
                           FontSize="12" Foreground="#6B7280"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,0"/>

                <DataGrid Grid.Row="1"
                          x:Name="dgItens"
                          ItemsSource="{Binding Itens}"
                          SelectedItem="{Binding ItemSelecionado}"
                          AutoGenerateColumns="False"
                          Background="White"
                          BorderThickness="0"
                          HeadersVisibility="Column"
                          RowBackground="White"
                          AlternatingRowBackground="#F9FAFB"
                          SelectionMode="Single"
                          SelectionUnit="FullRow"
                          CanUserResizeRows="False"
                          CanUserAddRows="False"
                          GridLinesVisibility="Horizontal"
                          HorizontalGridLinesBrush="#F3F4F6"
                          ScrollViewer.HorizontalScrollBarVisibility="Auto"
                          ScrollViewer.VerticalScrollBarVisibility="Auto"
                          ScrollViewer.CanContentScroll="True">
                    <DataGrid.InputBindings>
                        <MouseBinding MouseAction="LeftDoubleClick" Command="{Binding AdicionarProdutoCommand}"/>
                    </DataGrid.InputBindings>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Item"      Binding="{Binding Item}"                                    Width="60"  IsReadOnly="True"/>
                        <DataGridTextColumn Header="GTIN"      Binding="{Binding Gtin}"                                    Width="140" IsReadOnly="True"/>
                        <DataGridTextColumn Header="Descrição" Binding="{Binding Descricao}"                               Width="*"   IsReadOnly="True"/>
                        <DataGridTextColumn Header="Vlr. Unit." Binding="{Binding ValorUnitario, StringFormat={}{0:N2}}"   Width="110" IsReadOnly="True"/>
                        <DataGridTextColumn Header="Qtde"      Binding="{Binding Quantidade}"                              Width="80"  IsReadOnly="True"/>
                        <DataGridTextColumn Header="Desconto"  Binding="{Binding Desconto, StringFormat={}{0:N2}}"         Width="100" IsReadOnly="True"/>
                        <DataGridTextColumn Header="Vlr. Total" Binding="{Binding ValorTotal, StringFormat={}{0:N2}}"      Width="110" IsReadOnly="True"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <!-- RODAPÉ -->
        <Border Grid.Row="3"
                Background="White"
                CornerRadius="12"
                Padding="20"
                Margin="0,0,0,15"
                Visibility="{Binding MostrarMontagemVenda, Converter={StaticResource BoolToVisibility}}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock FontSize="12" Foreground="#8A94A6">
                         <Run Text="Itens: "/>
                         <Run Text="{Binding TotalItens}"/>
                    </TextBlock>
                    <TextBlock Text="{Binding TotalVenda, StringFormat={}{0:N2}}"
                               FontSize="22" FontWeight="Bold" Foreground="#1C3E72"/>
                </StackPanel>
                <Button Grid.Column="1" Content="Concluir venda" Margin="10"
                        Padding="15,8" Background="#1C3E72" Foreground="White"
                        BorderThickness="0" Cursor="Hand"
                        Command="{Binding ConcluirVendaCommand}">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="border" Background="{TemplateBinding Background}"
                                    CornerRadius="6" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="border" Property="Background" Value="#2A52A0"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </Border>

        <!-- PAGAMENTO -->
        <Border Grid.Row="3"
                Background="White"
                CornerRadius="12"
                Padding="20"
                Margin="0,0,0,15"
                Visibility="{Binding MostrarPagamento, Converter={StaticResource BoolToVisibility}}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="0,0,0,16">
                    <TextBlock Text="Pagamento"
                               FontSize="20"
                               FontWeight="Bold"
                               Foreground="#1C3E72"/>
                    <TextBlock Text="Escolha a forma de pagamento, informe o valor recebido e confirme a venda."
                               FontSize="12"
                               Foreground="#6B7280"
                               Margin="0,4,0,0"/>
                </StackPanel>

                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="190"/>
                        <ColumnDefinition Width="170"/>
                        <ColumnDefinition Width="170"/>
                        <ColumnDefinition Width="170"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,12,0">
                        <TextBlock Text="Forma de pagamento" FontSize="11" Foreground="#8A94A6" Margin="0,0,0,4"/>
                        <ComboBox Height="36"
                                  ItemsSource="{Binding TiposPagamento}"
                                  SelectedItem="{Binding TipoPagamentoSelecionado}"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="0,0,12,0">
                        <TextBlock Text="Total da venda" FontSize="11" Foreground="#8A94A6" Margin="0,0,0,4"/>
                        <TextBlock Text="{Binding ValorAReceberTexto}"
                                   Height="36"
                                   Padding="10,8,10,0"
                                   Background="#F7FAFC"
                                   Foreground="#1C3E72"
                                   FontWeight="Bold"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2" Margin="0,0,12,0">
                        <TextBlock Text="Valor recebido" FontSize="11" Foreground="#8A94A6" Margin="0,0,0,4"/>
                        <TextBox Height="36"
                                 Padding="10,0"
                                 HorizontalContentAlignment="Right"
                                 VerticalContentAlignment="Center"
                                 Text="{Binding ValorRecebidoTexto, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>

                    <StackPanel Grid.Column="3" Margin="0,0,12,0">
                        <TextBlock Text="Troco" FontSize="11" Foreground="#8A94A6" Margin="0,0,0,4"/>
                        <TextBlock Text="{Binding TrocoTexto}"
                                   Height="36"
                                   Padding="10,8,10,0"
                                   Background="#ECFDF5"
                                   Foreground="#047857"
                                   FontWeight="Bold"/>
                    </StackPanel>

                    <StackPanel Grid.Column="4"
                                Visibility="{Binding MostrarVencimentoFiadoPrazo, Converter={StaticResource BoolToVisibility}}">
                        <TextBlock Text="Vencimento fiado/prazo" FontSize="11" Foreground="#8A94A6" Margin="0,0,0,4"/>
                        <DatePicker Height="36"
                                    SelectedDate="{Binding DataVencimento}"/>
                    </StackPanel>
                </Grid>

                <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
                    <Button Content="Voltar"
                            Padding="16,8"
                            Margin="0,0,8,0"
                            Background="#E5E7EB"
                            Foreground="#1F2937"
                            BorderThickness="0"
                            Cursor="Hand"
                            Command="{Binding VoltarPagamentoCommand}"/>
                    <Button Content="Confirmar pagamento"
                            Padding="16,8"
                            Background="#1C3E72"
                            Foreground="White"
                            BorderThickness="0"
                            Cursor="Hand"
                            Command="{Binding ConfirmarPagamentoCommand}"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
