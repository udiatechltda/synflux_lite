<UserControl x:Class="PDV.Views.ClienteListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:vm="clr-namespace:PDV.ViewModels"
             mc:Ignorable="d" 
             d:DataContext="{d:DesignInstance Type=vm:ClienteListViewModel}"
             d:DesignHeight="600" d:DesignWidth="1200">

    <UserControl.Resources>
        <Style x:Key="ColHeaderStyle" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#F7FAFC"/>
            <Setter Property="Foreground" Value="#4A5568"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="8,10"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
        </Style>

        <Style x:Key="ColCellStyle" TargetType="DataGridCell">
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#2D3748"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#EBF4FF"/>
                    <Setter Property="Foreground" Value="#1C3E72"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Estilo para botão "Fiados" -->
        <Style x:Key="FiadosButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#48BB78"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" 
                                            Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Background="Transparent">
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>  <!-- Header Azul -->
            <RowDefinition Height="*"/>   <!-- Tabela -->
            <RowDefinition Height="Auto"/> <!-- Barra inferior -->
        </Grid.RowDefinitions>

        <!-- HEADER AZUL COM TÍTULO -->
        <Border Grid.Row="0" Background="#2B4C95" Padding="20,0">
            <Grid VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal">
                    <Button Background="Transparent" BorderThickness="0" Foreground="White" Cursor="Hand"
                            Command="{Binding VoltarCommand}" Margin="0,0,15,0">
                        <TextBlock Text="←" FontSize="16"/>
                    </Button>
                    <TextBlock Text="Cadastro - Cliente" Foreground="White" FontSize="18" FontWeight="Bold" 
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- CONTEÚDO PRINCIPAL -->
        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>  <!-- Subtítulo -->
                <RowDefinition Height="*"/>     <!-- DataGrid -->
            </Grid.RowDefinitions>

            <!-- SUBTÍTULO -->
            <TextBlock Grid.Row="0" Text="Relação - Cliente" FontSize="16" FontWeight="SemiBold" 
                       Foreground="#2D3748" Margin="20,15,20,10"/>

            <!-- TABELA DE DADOS -->
            <Border Grid.Row="1" Background="White" ClipToBounds="True" Margin="20,0,20,0">
                <DataGrid ItemsSource="{Binding Items}"
                          SelectedItem="{Binding SelectedItem}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          IsReadOnly="True"
                          BorderThickness="1"
                          BorderBrush="#E2E8F0"
                          Background="White"
                          RowBackground="White"
                          AlternatingRowBackground="#FAFBFC"
                          ColumnHeaderStyle="{StaticResource ColHeaderStyle}"
                          CellStyle="{StaticResource ColCellStyle}"
                          GridLinesVisibility="Horizontal"
                          HorizontalGridLinesBrush="#EDF2F7"
                          VerticalScrollBarVisibility="Auto"
                          RowHeight="40">
                    
                    <DataGrid.Columns>
                        <!-- Coluna Fiados -->
                        <DataGridTemplateColumn Header="Fiados" Width="90">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Style="{StaticResource FiadosButtonStyle}" Content="Fiados" 
                                            HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTextColumn Header="Id" Binding="{Binding Id}" Width="60"/>
                        <DataGridTextColumn Header="Tipo Pessoa" Binding="{Binding TipoPessoa}" Width="90"/>
                        <DataGridTextColumn Header="Nome" Binding="{Binding Nome}" Width="150"/>
                        <DataGridTextColumn Header="Fantasia" Binding="{Binding Fantasia}" Width="120"/>
                        <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="140"/>
                        <DataGridTextColumn Header="Url" Binding="{Binding Url}" Width="100"/>
                        <DataGridTextColumn Header="Cpf Cnpj" Binding="{Binding CpfCnpj}" Width="120"/>
                        <DataGridTextColumn Header="Rg" Binding="{Binding Rg}" Width="90"/>
                        <DataGridTextColumn Header="Orgao Rg" Binding="{Binding OrgaoRg}" Width="85"/>
                        <DataGridTextColumn Header="Data" Binding="{Binding DataCadastro, StringFormat='dd/MM/yyyy'}" Width="90"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </Grid>

        <!-- BARRA INFERIOR COM BOTÃO + GRANDE, FILTRO, RELATÓRIO, PAGINAÇÃO -->
        <Border Grid.Row="2" Background="White" BorderBrush="#E2E8F0" BorderThickness="0,1,0,0" Padding="20,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Botão Filtro -->
                <Button Grid.Column="0" Style="{StaticResource DefaultButtonStyle}" Margin="0,0,10,0" 
                        Padding="12,6" FontSize="12">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🔍 Filtro" Margin="0,0,5,0"/>
                        <TextBlock Text="[F11]" Foreground="#A0AEC0" FontSize="10"/>
                    </StackPanel>
                </Button>

                <!-- Botão Relatório -->
                <Button Grid.Column="1" Style="{StaticResource DefaultButtonStyle}" Margin="0,0,10,0" 
                        Padding="12,6" FontSize="12">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="📊 Relatório" Margin="0,0,5,0"/>
                        <TextBlock Text="[F8]" Foreground="#A0AEC0" FontSize="10"/>
                    </StackPanel>
                </Button>

                <!-- Espaço -->
                <Border Grid.Column="2"/>

                <!-- Paginação -->
                <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,20,0">
                    <TextBlock Text="Linhas por página:" VerticalAlignment="Center" Margin="0,0,8,0" FontSize="12"/>
                    <ComboBox Width="50" VerticalAlignment="Center">
                        <ComboBoxItem>10</ComboBoxItem>
                        <ComboBoxItem IsSelected="True">20</ComboBoxItem>
                        <ComboBoxItem>50</ComboBoxItem>
                    </ComboBox>
                </StackPanel>

                <!-- Info e Navegação -->
                <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,12,0">
                    <TextBlock Text="1 - 4 de 4" VerticalAlignment="Center" Margin="0,0,10,0" FontSize="12"
                               Foreground="#718096"/>
                    <Button Background="Transparent" BorderThickness="0" Foreground="#A0AEC0" Cursor="Hand"
                            Padding="5" FontSize="14" Margin="0,0,5,0">◀</Button>
                    <Button Background="Transparent" BorderThickness="0" Foreground="#A0AEC0" Cursor="Hand"
                            Padding="5" FontSize="14">▶</Button>
                </StackPanel>

                <!-- Botão + Novo -->
                <Button Grid.Column="4" Style="{StaticResource FabButtonStyle}"
                        Command="{Binding NovoCommand}" ToolTip="Novo (Ins)">
                    <TextBlock Text="+" FontSize="26" FontWeight="Light" Foreground="White"
                               VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,-2,0,0"/>
                </Button>
            </Grid>
        </Border>
    </Grid>
</UserControl>
