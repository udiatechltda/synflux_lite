<UserControl x:Class="PDV.Views.ProdutoFormView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:vm="clr-namespace:PDV.ViewModels"
             xmlns:utilities="clr-namespace:PDV.Utilities"
             mc:Ignorable="d" 
             d:DataContext="{d:DesignInstance Type=vm:ProdutoFormViewModel}"
             d:DesignHeight="800" d:DesignWidth="1000">

    <UserControl.Resources>
        <utilities:ImagePathToBitmapConverter x:Key="ImagePathToBitmapConverter"/>
    </UserControl.Resources>

    <Grid Background="#F7FAFC">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Padding="20" Background="White" BorderBrush="#E2E8F0" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="{Binding Titulo}" FontSize="24" FontWeight="Bold" Foreground="{StaticResource TitleBrush}"/>
                    <TextBlock Text="{Binding Subtitulo}" FontSize="14" Foreground="#718096" Margin="0,4,0,0"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Style="{StaticResource DefaultButtonStyle}" Command="{Binding SalvarCommand}" Content="Salvar" Width="120" Height="40" Margin="0,0,10,0"/>
                    <Button Content="Cancelar" Command="{Binding CancelarCommand}" Background="Transparent" BorderBrush="#E2E8F0" BorderThickness="1" Width="100" Height="40"/>
                </StackPanel>
            </Grid>
        </Border>

        <TabControl Grid.Row="1" Margin="20" Background="Transparent" BorderThickness="0">
            <!-- DADOS BÁSICOS -->
            <TabItem Header="Dados Básicos">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="0,20,0,0">
                        <GroupBox Header="Identificação e Valores" Padding="15" Margin="0,0,0,20">
                            <Grid>
                                <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="2*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>

                                <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,10,15">
                                    <TextBlock Text="Nome do Produto *" Style="{StaticResource LabelStyle}" Margin="0,0,0,5"/>
                                    <TextBox Text="{Binding Model.Nome}" Style="{StaticResource TextBoxStyle}"/>
                                </StackPanel>
                                <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,10,15">
                                    <TextBlock Text="GTIN / EAN *" Style="{StaticResource LabelStyle}" Margin="0,0,0,5"/>
                                    <TextBox Text="{Binding Model.Gtin}" Style="{StaticResource TextBoxStyle}"/>
                                </StackPanel>
                                <StackPanel Grid.Row="0" Grid.Column="2" Margin="0,0,0,15">
                                    <TextBlock Text="Cód. Interno" Style="{StaticResource LabelStyle}" Margin="0,0,0,5"/>
                                    <TextBox Text="{Binding Model.CodigoInterno}" Style="{StaticResource TextBoxStyle}"/>
                                </StackPanel>

                                <UniformGrid Grid.Row="1" Grid.ColumnSpan="3" Columns="4">
                                    <StackPanel Margin="0,0,10,15"><TextBlock Text="Id Unidade" Style="{StaticResource LabelStyle}"/><TextBox Text="{Binding Model.IdProdutoUnidade}" Style="{StaticResource TextBoxStyle}"/></StackPanel>
                                    <StackPanel Margin="0,0,10,15"><TextBlock Text="Valor Compra" Style="{StaticResource LabelStyle}"/><TextBox Text="{Binding Model.ValorCompra}" utilities:DecimalTextBoxBehavior.Format="N2" Style="{StaticResource TextBoxStyle}"/></StackPanel>
                                    <StackPanel Margin="0,0,10,15"><TextBlock Text="Valor Venda *" Style="{StaticResource LabelStyle}"/><TextBox Text="{Binding Model.ValorVenda}" utilities:DecimalTextBoxBehavior.Format="N2" Style="{StaticResource TextBoxStyle}"/></StackPanel>
                                    <StackPanel><TextBlock Text="Estoque Atual" Style="{StaticResource LabelStyle}"/><TextBox Text="{Binding Model.QuantidadeEstoque}" Style="{StaticResource TextBoxStyle}"/></StackPanel>
                                </UniformGrid>
                            </Grid>
                        </GroupBox>
                        <GroupBox Header="Imagem do Produto" Padding="15" Margin="0,0,0,20">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="180"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Border Width="160"
                                        Height="160"
                                        BorderBrush="#D1D5DB"
                                        BorderThickness="1"
                                        Background="#F9FAFB"
                                        CornerRadius="8">
                                    <Grid>
                                        <TextBlock Text="Sem imagem"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   Foreground="#8A94A6"
                                                   FontSize="13"/>
                                        <Image Source="{Binding ImagemProdutoPath, Converter={StaticResource ImagePathToBitmapConverter}}"
                                               Stretch="UniformToFill"
                                               Width="158"
                                               Height="158"/>
                                    </Grid>
                                </Border>

                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="20,0,0,0">
                                    <TextBlock Text="Use uma foto clara do item para facilitar a identificacao no caixa e na venda."
                                               Foreground="#4A5568"
                                               FontSize="13"
                                               TextWrapping="Wrap"
                                               Margin="0,0,0,12"/>
                                    <StackPanel Orientation="Horizontal">
                                        <Button Content="Selecionar imagem"
                                                Command="{Binding SelecionarImagemCommand}"
                                                Style="{StaticResource DefaultButtonStyle}"
                                                Width="150"
                                                Height="36"
                                                Margin="0,0,10,0"/>
                                        <Button Content="Remover"
                                                Command="{Binding RemoverImagemCommand}"
                                                Background="Transparent"
                                                BorderBrush="#E2E8F0"
                                                BorderThickness="1"
                                                Width="100"
                                                Height="36"/>
                                    </StackPanel>
                                </StackPanel>
                            </Grid>
                        </GroupBox>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- DADOS FISCAIS -->
            <TabItem Header="Fiscal">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="0,20,0,0">
                        <GroupBox Header="Classificação Fiscal" Padding="15" Margin="0,0,0,20">
                            <Grid>
                                <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>

                                <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,10,15"><TextBlock Text="NCM" Style="{StaticResource LabelStyle}"/><TextBox Text="{Binding Model.CodigoNcm}" Style="{StaticResource TextBoxStyle}"/></StackPanel>
                                <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,10,15"><TextBlock Text="CEST" Style="{StaticResource LabelStyle}"/><TextBox Text="{Binding Model.CodigoCest}" Style="{StaticResource TextBoxStyle}"/></StackPanel>
                                <StackPanel Grid.Row="0" Grid.Column="2" Margin="0,0,0,15"><TextBlock Text="Tipo Item SPED" Style="{StaticResource LabelStyle}"/><TextBox Text="{Binding Model.TipoItemSped}" Style="{StaticResource TextBoxStyle}"/></StackPanel>

                                <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,10,15"><TextBlock Text="CST" Style="{StaticResource LabelStyle}"/><TextBox Text="{Binding Model.Cst}" Style="{StaticResource TextBoxStyle}"/></StackPanel>
                                <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,0,10,15"><TextBlock Text="CSOSN" Style="{StaticResource LabelStyle}"/><TextBox Text="{Binding Model.Csosn}" Style="{StaticResource TextBoxStyle}"/></StackPanel>
                                <StackPanel Grid.Row="1" Grid.Column="2" Margin="0,0,0,15"><TextBlock Text="Totalizador Parcial" Style="{StaticResource LabelStyle}"/><TextBox Text="{Binding Model.TotalizadorParcial}" Style="{StaticResource TextBoxStyle}"/></StackPanel>

                                <UniformGrid Grid.Row="2" Grid.ColumnSpan="3" Columns="3">
                                    <StackPanel Margin="0,0,10,0"><TextBlock Text="IAT" Style="{StaticResource LabelStyle}"/><TextBox Text="{Binding Model.Iat}" Style="{StaticResource TextBoxStyle}"/></StackPanel>
                                    <StackPanel Margin="0,0,10,0"><TextBlock Text="IPPT" Style="{StaticResource LabelStyle}"/><TextBox Text="{Binding Model.Ippt}" Style="{StaticResource TextBoxStyle}"/></StackPanel>
                                    <StackPanel><TextBlock Text="ECF ICMS ST" Style="{StaticResource LabelStyle}"/><TextBox Text="{Binding Model.EcfIcmsSt}" Style="{StaticResource TextBoxStyle}"/></StackPanel>
                                </UniformGrid>
                            </Grid>
                        </GroupBox>

                        <GroupBox Header="Alíquotas de Impostos (%)" Padding="15">
                            <UniformGrid Columns="4">
                                <StackPanel Margin="0,0,10,0"><TextBlock Text="ICMS (%)" Style="{StaticResource LabelStyle}"/><TextBox Text="{Binding Model.TaxaIcms}" utilities:DecimalTextBoxBehavior.Format="N2" Style="{StaticResource TextBoxStyle}"/></StackPanel>
                                <StackPanel Margin="0,0,10,0"><TextBlock Text="PIS (%)" Style="{StaticResource LabelStyle}"/><TextBox Text="{Binding Model.TaxaPis}" utilities:DecimalTextBoxBehavior.Format="N2" Style="{StaticResource TextBoxStyle}"/></StackPanel>
                                <StackPanel Margin="0,0,10,0"><TextBlock Text="COFINS (%)" Style="{StaticResource LabelStyle}"/><TextBox Text="{Binding Model.TaxaCofins}" utilities:DecimalTextBoxBehavior.Format="N2" Style="{StaticResource TextBoxStyle}"/></StackPanel>
                                <StackPanel><TextBlock Text="IPI (%)" Style="{StaticResource LabelStyle}"/><TextBox Text="{Binding Model.TaxaIpi}" utilities:DecimalTextBoxBehavior.Format="N2" Style="{StaticResource TextBoxStyle}"/></StackPanel>
                                <StackPanel Margin="0,10,10,0"><TextBlock Text="ISSQN (%)" Style="{StaticResource LabelStyle}"/><TextBox Text="{Binding Model.TaxaIssqn}" utilities:DecimalTextBoxBehavior.Format="N2" Style="{StaticResource TextBoxStyle}"/></StackPanel>
                            </UniformGrid>
                        </GroupBox>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ESTOQUE -->
            <TabItem Header="Estoque">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="0,20,0,0">
                        <GroupBox Padding="15" Margin="0,0,0,20">
                            <GroupBox.Header>
                                <StackPanel Orientation="Horizontal">
                                    <Image Source="{StaticResource EstoqueIcon}" Width="14" Height="14" Margin="0,0,6,0"/>
                                    <TextBlock Text="Localização Física no Estoque" Foreground="{StaticResource PrimaryBrush}" FontWeight="SemiBold"/>
                                </StackPanel>
                            </GroupBox.Header>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,10,15">
                                    <TextBlock Text="Depósito *" Style="{StaticResource LabelStyle}" Margin="0,0,0,5"/>
                                    <Grid>
                                        <TextBox x:Name="DepositoTextBox" Text="{Binding Deposito, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource TextBoxStyle}"/>
                                        <TextBlock Text="Ex.: Principal" Foreground="#A0AEC0" FontSize="13" Margin="12,0,0,0" VerticalAlignment="Center" IsHitTestVisible="False">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Text, ElementName=DepositoTextBox}" Value="">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Grid>
                                </StackPanel>
                                <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,10,15">
                                    <TextBlock Text="Corredor *" Style="{StaticResource LabelStyle}" Margin="0,0,0,5"/>
                                    <Grid>
                                        <TextBox x:Name="CorredorTextBox" Text="{Binding Corredor, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource TextBoxStyle}"/>
                                        <TextBlock Text="Ex.: A" Foreground="#A0AEC0" FontSize="13" Margin="12,0,0,0" VerticalAlignment="Center" IsHitTestVisible="False">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Text, ElementName=CorredorTextBox}" Value="">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Grid>
                                </StackPanel>
                                <StackPanel Grid.Row="0" Grid.Column="2" Margin="0,0,10,15">
                                    <TextBlock Text="Prateleira *" Style="{StaticResource LabelStyle}" Margin="0,0,0,5"/>
                                    <Grid>
                                        <TextBox x:Name="PrateleiraTextBox" Text="{Binding Prateleira, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource TextBoxStyle}"/>
                                        <TextBlock Text="Ex.: 03" Foreground="#A0AEC0" FontSize="13" Margin="12,0,0,0" VerticalAlignment="Center" IsHitTestVisible="False">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Text, ElementName=PrateleiraTextBox}" Value="">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Grid>
                                </StackPanel>
                                <StackPanel Grid.Row="0" Grid.Column="3" Margin="0,0,10,15">
                                    <TextBlock Text="Nível *" Style="{StaticResource LabelStyle}" Margin="0,0,0,5"/>
                                    <Grid>
                                        <TextBox x:Name="NivelTextBox" Text="{Binding Nivel, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource TextBoxStyle}"/>
                                        <TextBlock Text="Ex.: 02" Foreground="#A0AEC0" FontSize="13" Margin="12,0,0,0" VerticalAlignment="Center" IsHitTestVisible="False">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Text, ElementName=NivelTextBox}" Value="">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Grid>
                                </StackPanel>
                                <StackPanel Grid.Row="0" Grid.Column="4" Margin="0,0,0,15">
                                    <TextBlock Text="Posição *" Style="{StaticResource LabelStyle}" Margin="0,0,0,5"/>
                                    <Grid>
                                        <TextBox x:Name="PosicaoTextBox" Text="{Binding Posicao, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource TextBoxStyle}"/>
                                        <TextBlock Text="Ex.: 05" Foreground="#A0AEC0" FontSize="13" Margin="12,0,0,0" VerticalAlignment="Center" IsHitTestVisible="False">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Text, ElementName=PosicaoTextBox}" Value="">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Grid>
                                </StackPanel>

                                <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3" Margin="0,0,10,0">
                                    <TextBlock Text="Endereço Completo (Localização Estoque) *" Style="{StaticResource LabelStyle}" Margin="0,0,0,5"/>
                                    <Grid>
                                        <TextBox x:Name="EnderecoCompletoTextBox" Text="{Binding EnderecoCompleto, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource TextBoxStyle}"/>
                                        <TextBlock Text="Ex.: A-03-02-05" Foreground="#A0AEC0" FontSize="13" Margin="12,0,0,0" VerticalAlignment="Center" IsHitTestVisible="False">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Text, ElementName=EnderecoCompletoTextBox}" Value="">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Grid>
                                </StackPanel>
                                <StackPanel Grid.Row="1" Grid.Column="3" Grid.ColumnSpan="2">
                                    <TextBlock Text="Observação de Armazenagem" Style="{StaticResource LabelStyle}" Margin="0,0,0,5"/>
                                    <Grid>
                                        <TextBox x:Name="ObservacaoArmazenagemTextBox" Text="{Binding ObservacaoArmazenagem, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource TextBoxStyle}"/>
                                        <TextBlock Text="Ex.: Caixa superior da prateleira" Foreground="#A0AEC0" FontSize="13" Margin="12,0,0,0" VerticalAlignment="Center" IsHitTestVisible="False">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Text, ElementName=ObservacaoArmazenagemTextBox}" Value="">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Grid>
                                </StackPanel>
                            </Grid>
                        </GroupBox>

                        <GroupBox Padding="15" Margin="0,0,0,20">
                            <GroupBox.Header>
                                <StackPanel Orientation="Horizontal">
                                    <Image Source="{StaticResource EstoqueIcon}" Width="14" Height="14" Margin="0,0,6,0"/>
                                    <TextBlock Text="Controle de Estoque" Foreground="{StaticResource PrimaryBrush}" FontWeight="SemiBold"/>
                                </StackPanel>
                            </GroupBox.Header>
                            <UniformGrid Columns="5">
                                <StackPanel Margin="0,0,10,0">
                                    <TextBlock Text="Estoque Atual" Style="{StaticResource LabelStyle}" Margin="0,0,0,5"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="42"/></Grid.ColumnDefinitions>
                                        <TextBox x:Name="EstoqueAtualTextBox" Text="{Binding Model.QuantidadeEstoque, UpdateSourceTrigger=PropertyChanged}" utilities:DecimalTextBoxBehavior.Format="N2" Style="{StaticResource TextBoxStyle}"/>
                                        <TextBlock Text="Ex.: 120,00" Foreground="#A0AEC0" FontSize="13" Margin="12,0,0,0" VerticalAlignment="Center" IsHitTestVisible="False">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Text, ElementName=EstoqueAtualTextBox}" Value="">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <Border Grid.Column="1" Background="#EDF2F7" BorderBrush="#CBD5E0" BorderThickness="0,1,1,1" CornerRadius="0,6,6,0">
                                            <TextBlock Text="UN" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#4A5568" FontSize="12"/>
                                        </Border>
                                    </Grid>
                                    <TextBlock Text="Quantidade disponível no momento" FontSize="11" Foreground="#718096" Margin="0,6,0,0"/>
                                </StackPanel>
                                <StackPanel Margin="0,0,10,0">
                                    <TextBlock Text="Estoque Mínimo" Style="{StaticResource LabelStyle}" Margin="0,0,0,5"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="42"/></Grid.ColumnDefinitions>
                                        <TextBox x:Name="EstoqueMinimoTextBox" Text="{Binding Model.EstoqueMinimo, UpdateSourceTrigger=PropertyChanged}" utilities:DecimalTextBoxBehavior.Format="N2" Style="{StaticResource TextBoxStyle}"/>
                                        <TextBlock Text="Ex.: 20,00" Foreground="#A0AEC0" FontSize="13" Margin="12,0,0,0" VerticalAlignment="Center" IsHitTestVisible="False">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Text, ElementName=EstoqueMinimoTextBox}" Value="">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <Border Grid.Column="1" Background="#EDF2F7" BorderBrush="#CBD5E0" BorderThickness="0,1,1,1" CornerRadius="0,6,6,0">
                                            <TextBlock Text="UN" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#4A5568" FontSize="12"/>
                                        </Border>
                                    </Grid>
                                    <TextBlock Text="Quantidade mínima desejada" FontSize="11" Foreground="#718096" Margin="0,6,0,0"/>
                                </StackPanel>
                                <StackPanel Margin="0,0,10,0">
                                    <TextBlock Text="Ponto de Reposição" Style="{StaticResource LabelStyle}" Margin="0,0,0,5"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="42"/></Grid.ColumnDefinitions>
                                        <TextBox x:Name="PontoReposicaoTextBox" Text="{Binding PontoReposicao, UpdateSourceTrigger=PropertyChanged}" utilities:DecimalTextBoxBehavior.Format="N2" Style="{StaticResource TextBoxStyle}"/>
                                        <TextBlock Text="Ex.: 30,00" Foreground="#A0AEC0" FontSize="13" Margin="12,0,0,0" VerticalAlignment="Center" IsHitTestVisible="False">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Text, ElementName=PontoReposicaoTextBox}" Value="">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <Border Grid.Column="1" Background="#EDF2F7" BorderBrush="#CBD5E0" BorderThickness="0,1,1,1" CornerRadius="0,6,6,0">
                                            <TextBlock Text="UN" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#4A5568" FontSize="12"/>
                                        </Border>
                                    </Grid>
                                    <TextBlock Text="Quantidade para novo pedido" FontSize="11" Foreground="#718096" Margin="0,6,0,0"/>
                                </StackPanel>
                                <StackPanel Margin="0,0,10,0">
                                    <TextBlock Text="Estoque Máximo" Style="{StaticResource LabelStyle}" Margin="0,0,0,5"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="42"/></Grid.ColumnDefinitions>
                                        <TextBox x:Name="EstoqueMaximoTextBox" Text="{Binding Model.EstoqueMaximo, UpdateSourceTrigger=PropertyChanged}" utilities:DecimalTextBoxBehavior.Format="N2" Style="{StaticResource TextBoxStyle}"/>
                                        <TextBlock Text="Ex.: 300,00" Foreground="#A0AEC0" FontSize="13" Margin="12,0,0,0" VerticalAlignment="Center" IsHitTestVisible="False">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Text, ElementName=EstoqueMaximoTextBox}" Value="">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <Border Grid.Column="1" Background="#EDF2F7" BorderBrush="#CBD5E0" BorderThickness="0,1,1,1" CornerRadius="0,6,6,0">
                                            <TextBlock Text="UN" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#4A5568" FontSize="12"/>
                                        </Border>
                                    </Grid>
                                    <TextBlock Text="Quantidade máxima desejada" FontSize="11" Foreground="#718096" Margin="0,6,0,0"/>
                                </StackPanel>
                                <StackPanel>
                                    <TextBlock Text="Estoque Reservado" Style="{StaticResource LabelStyle}" Margin="0,0,0,5"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="42"/></Grid.ColumnDefinitions>
                                        <TextBox x:Name="EstoqueReservadoTextBox" Text="{Binding EstoqueReservado, UpdateSourceTrigger=PropertyChanged}" utilities:DecimalTextBoxBehavior.Format="N2" Style="{StaticResource TextBoxStyle}"/>
                                        <TextBlock Text="Ex.: 5,00" Foreground="#A0AEC0" FontSize="13" Margin="12,0,0,0" VerticalAlignment="Center" IsHitTestVisible="False">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Text, ElementName=EstoqueReservadoTextBox}" Value="">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <Border Grid.Column="1" Background="#EDF2F7" BorderBrush="#CBD5E0" BorderThickness="0,1,1,1" CornerRadius="0,6,6,0">
                                            <TextBlock Text="UN" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#4A5568" FontSize="12"/>
                                        </Border>
                                    </Grid>
                                    <TextBlock Text="Quantidade reservada para vendas" FontSize="11" Foreground="#718096" Margin="0,6,0,0"/>
                                </StackPanel>
                            </UniformGrid>
                        </GroupBox>

                        <GroupBox Padding="15">
                            <GroupBox.Header>
                                <StackPanel Orientation="Horizontal">
                                    <Image Source="{StaticResource EstoqueIcon}" Width="14" Height="14" Margin="0,0,6,0"/>
                                    <TextBlock Text="Informações Adicionais de Estoque" Foreground="{StaticResource PrimaryBrush}" FontWeight="SemiBold"/>
                                </StackPanel>
                            </GroupBox.Header>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1.2*"/>
                                    <ColumnDefinition Width="3*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                    <TextBlock Text="Tipo de Armazenagem" Style="{StaticResource LabelStyle}" Margin="0,0,0,5"/>
                                    <Grid>
                                        <TextBox x:Name="TipoArmazenagemTextBox" Text="{Binding TipoArmazenagem, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource TextBoxStyle}"/>
                                        <TextBlock Text="Ex.: Caixa / Gaveteiro" Foreground="#A0AEC0" FontSize="13" Margin="12,0,0,0" VerticalAlignment="Center" IsHitTestVisible="False">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Text, ElementName=TipoArmazenagemTextBox}" Value="">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Grid>
                                </StackPanel>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="Observações" Style="{StaticResource LabelStyle}" Margin="0,0,0,5"/>
                                    <Grid>
                                        <TextBox x:Name="ObservacoesEstoqueTextBox" Text="{Binding ObservacoesEstoque, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource TextBoxStyle}"/>
                                        <TextBlock Text="Ex.: Material pequeno armazenado em gaveteiro identificado." Foreground="#A0AEC0" FontSize="13" Margin="12,0,0,0" VerticalAlignment="Center" IsHitTestVisible="False">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Text, ElementName=ObservacoesEstoqueTextBox}" Value="">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Grid>
                                </StackPanel>
                            </Grid>
                        </GroupBox>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- OUTROS -->
            <TabItem Header="Outros">
                <StackPanel Margin="0,20,0,0">
                    <GroupBox Header="Detalhes Adicionais" Padding="15">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <StackPanel Grid.Row="0" Margin="0,0,0,15"><TextBlock Text="Descrição PDV (Cupom)" Style="{StaticResource LabelStyle}"/><TextBox Text="{Binding Model.DescricaoPdv}" Style="{StaticResource TextBoxStyle}"/></StackPanel>
                            <UniformGrid Grid.Row="1" Columns="4" Margin="0,0,0,15">
                                <StackPanel Margin="0,0,10,0"><TextBlock Text="Estoque Mínimo" Style="{StaticResource LabelStyle}"/><TextBox Text="{Binding Model.EstoqueMinimo}" Style="{StaticResource TextBoxStyle}"/></StackPanel>
                                <StackPanel Margin="0,0,10,0"><TextBlock Text="Estoque Máximo" Style="{StaticResource LabelStyle}"/><TextBox Text="{Binding Model.EstoqueMaximo}" Style="{StaticResource TextBoxStyle}"/></StackPanel>
                                <StackPanel Margin="0,0,10,0"><TextBlock Text="Valor Custo" Style="{StaticResource LabelStyle}"/><TextBox Text="{Binding Model.ValorCusto}" utilities:DecimalTextBoxBehavior.Format="N2" Style="{StaticResource TextBoxStyle}"/></StackPanel>
                                <StackPanel>
                                    <TextBlock Text="Situação" Style="{StaticResource LabelStyle}"/>
                                    <ComboBox SelectedValue="{Binding Model.Situacao}" SelectedValuePath="Tag">
                                        <ComboBoxItem Content="Ativo" Tag="A" IsSelected="True"/>
                                        <ComboBoxItem Content="Inativo" Tag="I"/>
                                    </ComboBox>
                                </StackPanel>
                            </UniformGrid>
                            <UniformGrid Grid.Row="2" Columns="2">
                                <StackPanel Margin="0,0,10,0"><TextBlock Text="Código Balança" Style="{StaticResource LabelStyle}"/><TextBox Text="{Binding Model.CodigoBalanca}" Style="{StaticResource TextBoxStyle}"/></StackPanel>
                                <StackPanel><TextBlock Text="PAF-P ST" Style="{StaticResource LabelStyle}"/><TextBox Text="{Binding Model.PafPSt}" Style="{StaticResource TextBoxStyle}"/></StackPanel>
                            </UniformGrid>
                        </Grid>
                    </GroupBox>
                </StackPanel>
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>
