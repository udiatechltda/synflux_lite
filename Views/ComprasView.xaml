<UserControl x:Class="PDV.Views.ComprasView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             Background="#ECEFF1">

    <UserControl.Resources>

        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#F9FAFB"/>
            <Setter Property="Foreground" Value="#6B7280"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="BorderBrush" Value="#E5E7EB"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#EFF6FF"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#DBEAFE"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#1A202C"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border Padding="{TemplateBinding Padding}" Background="{TemplateBinding Background}">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Foreground" Value="#1A202C"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="IconButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="40"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Background" Value="#1C3E72"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#2A52A0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="AddButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="50"/>
            <Setter Property="Height" Value="50"/>
            <Setter Property="Background" Value="#1C3E72"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                CornerRadius="25" Width="50" Height="50">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#2A52A0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ComboBoxDashStyle" TargetType="ComboBox">
            <Setter Property="Height" Value="32"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#111827"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="border" Background="{TemplateBinding Background}"
                                    CornerRadius="6" BorderBrush="#D1D5DB" BorderThickness="1" Padding="10,0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <ContentPresenter Grid.Column="0"
                                                      Content="{TemplateBinding SelectionBoxItem}"
                                                      ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                      VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="∨" FontSize="10"
                                               Foreground="#6B7280" VerticalAlignment="Center" Margin="8,0,0,0"/>
                                </Grid>
                            </Border>
                            <ToggleButton Opacity="0"
                                          IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                          Focusable="False"/>
                            <Popup IsOpen="{TemplateBinding IsDropDownOpen}" Placement="Bottom"
                                   AllowsTransparency="True" Focusable="False">
                                <Border Background="White" CornerRadius="8"
                                        BorderBrush="#E5E7EB" BorderThickness="1" Margin="0,4,0,0">
                                    <ScrollViewer>
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#9CA3AF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </UserControl.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Grid.Row="0" Background="White" CornerRadius="12" Padding="20" Margin="0,0,0,15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" Background="Transparent" BorderThickness="0"
                        Command="{Binding VoltarCommand}" Cursor="Hand"
                        Margin="0,0,12,0" Padding="6,4">
                    <TextBlock Text="←" FontSize="20" Foreground="#1C3E72" FontWeight="SemiBold"/>
                </Button>

                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="Relação - Pedido de Compra"
                               FontSize="18" FontWeight="SemiBold" Foreground="#1A202C"/>
                    <TextBlock Text="PDV - Compras" FontSize="11" Foreground="#999999"/>
                </StackPanel>

                <Button Grid.Column="2" Content="+" FontSize="22" Margin="5,0"
                        Style="{StaticResource IconButtonStyle}"
                        ToolTip="Novo Pedido de Compra"
                        Command="{Binding NovoPedidoCommand}"/>
            </Grid>
        </Border>

        <!-- BUSCA -->
        <Border Grid.Row="1" Background="White" CornerRadius="12" Padding="20" Margin="0,0,0,15">
            <StackPanel>
                <TextBlock Text="Pesquisar Pedido" FontSize="12" Foreground="#8A94A6" Margin="0,0,0,5"/>
                <Border CornerRadius="8" BorderBrush="#D0D5DD" BorderThickness="1" Background="White" Height="40">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Path Grid.Column="0" Width="14" Height="14" Margin="12,0,8,0"
                              VerticalAlignment="Center" Stroke="#8A94A6" StrokeThickness="1.5"
                              Data="M11 11 L16 16 M13 7 A6 6 0 1 1 1 7 A6 6 0 1 1 13 7"/>
                        <TextBox Grid.Column="1" FontSize="14" Background="Transparent"
                                 BorderThickness="0" VerticalContentAlignment="Center"
                                 Foreground="#000" Padding="0"
                                 Text="{Binding TermoBusca, UpdateSourceTrigger=PropertyChanged}">
                            <TextBox.InputBindings>
                                <KeyBinding Key="Return" Command="{Binding PesquisarCommand}"/>
                            </TextBox.InputBindings>
                        </TextBox>
                    </Grid>
                </Border>
            </StackPanel>
        </Border>

        <!-- DATAGRID -->
        <Border Grid.Row="2" Background="White" CornerRadius="12" Padding="10" Margin="0,0,0,15">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="{Binding InfoResultado}"
                           FontSize="12" Foreground="#6B7280"
                           HorizontalAlignment="Center"/>

                <Grid Grid.Row="1">
                    <DataGrid x:Name="dgCompras"
                              ItemsSource="{Binding Compras}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              IsReadOnly="True"
                              Background="White"
                              BorderThickness="0"
                              HeadersVisibility="Column"
                              RowBackground="White"
                              AlternatingRowBackground="#F9FAFB"
                              SelectionMode="Single"
                              SelectionUnit="FullRow"
                              CanUserResizeRows="False"
                              GridLinesVisibility="Horizontal"
                              HorizontalGridLinesBrush="#F3F4F6"
                              ScrollViewer.HorizontalScrollBarVisibility="Auto"
                              ScrollViewer.VerticalScrollBarVisibility="Auto">

                        <DataGrid.Columns>
                            <!-- Grupo 1 -->
                            <DataGridTextColumn Header="Id"                          Binding="{Binding Id}"                                                    Width="60"/>
                            <DataGridTextColumn Header="Colaborador"                 Binding="{Binding Colaborador}"                                           Width="120"/>
                            <DataGridTextColumn Header="Fornecedor"                  Binding="{Binding Fornecedor}"                                            Width="120"/>
                            <DataGridTextColumn Header="Data do Pedido"              Binding="{Binding DataPedido, StringFormat=dd/MM/yyyy}"                   Width="120"/>
                            <DataGridTextColumn Header="Data Prevista para Entrega"  Binding="{Binding DataPrevistaEntrega, StringFormat=dd/MM/yyyy}"          Width="170"/>
                            <DataGridTextColumn Header="Data Previsão Pagamento"     Binding="{Binding DataPrevisaoPagamento, StringFormat=dd/MM/yyyy}"        Width="160"/>
                            <DataGridTextColumn Header="Local de Entrega"            Binding="{Binding LocalEntrega}"                                          Width="130"/>
                            <DataGridTextColumn Header="Local de Cobrança"           Binding="{Binding LocalCobranca}"                                         Width="130"/>
                            <!-- Grupo 2 -->
                            <DataGridTextColumn Header="Nome do Contato"             Binding="{Binding NomeContato}"                                           Width="140"/>
                            <DataGridTextColumn Header="Valor Subtotal"              Binding="{Binding ValorSubtotal, StringFormat={}{0:N2}}"                  Width="120"/>
                            <DataGridTextColumn Header="Taxa Desconto"               Binding="{Binding TaxaDesconto, StringFormat={}{0:N2}}"                   Width="110"/>
                            <DataGridTextColumn Header="Valor Desconto"              Binding="{Binding ValorDesconto, StringFormat={}{0:N2}}"                  Width="120"/>
                            <DataGridTextColumn Header="Valor Total"                 Binding="{Binding ValorTotal, StringFormat={}{0:N2}}"                     Width="110"/>
                            <DataGridTextColumn Header="Forma de Pagamento"          Binding="{Binding FormaPagamento}"                                        Width="140"/>
                            <DataGridTextColumn Header="Gera Financeiro"             Binding="{Binding GeraFinanceiro}"                                        Width="120"/>
                            <DataGridTextColumn Header="Quantidade de Parcelas"      Binding="{Binding QuantidadeParcelas}"                                    Width="160"/>
                            <!-- Grupo 3 -->
                            <DataGridTextColumn Header="Dia Primeiro Vencimento"     Binding="{Binding DiaPrimeiroVencimento}"                                 Width="170"/>
                            <DataGridTextColumn Header="Intervalo entre Parcelas"    Binding="{Binding IntervaloEntreParcelas}"                                Width="170"/>
                            <DataGridTextColumn Header="Dia Fixo da Parcela"         Binding="{Binding DiaFixoParcela}"                                        Width="140"/>
                            <DataGridTextColumn Header="Data Recebimento Itens"      Binding="{Binding DataRecebimentoItens, StringFormat=dd/MM/yyyy}"         Width="170"/>
                            <DataGridTextColumn Header="Hora Recebimento Itens"      Binding="{Binding HoraRecebimentoItens}"                                  Width="160"/>
                            <DataGridTextColumn Header="Atualizou Estoque"           Binding="{Binding AtualizouEstoque}"                                      Width="140"/>
                            <DataGridTextColumn Header="Numero Documento Entrada"    Binding="{Binding NumeroDocumentoEntrada}"                                Width="180"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- Estado vazio: cabeçalhos ficam visíveis, texto aparece abaixo deles -->
                    <StackPanel HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Margin="0,40"
                                Visibility="{Binding SemPedidos, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="Nenhum pedido encontrado"
                                   FontSize="14" Foreground="#8A94A6"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>

        <!-- RODAPÉ -->
        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- SELETOR DE MÊS -->
            <Border Grid.Column="0" Background="White" CornerRadius="10" Padding="12,8" VerticalAlignment="Center">
                <StackPanel Orientation="Vertical">
                    <TextBlock Text="Selecione um dia dentro do mês desejado"
                               FontSize="11" Foreground="#8A94A6" Margin="0,0,0,4"/>
                    <DatePicker x:Name="dpMes"
                                SelectedDateFormat="Short"
                                FontSize="13" Foreground="#1C3E72" FontWeight="SemiBold"
                                BorderThickness="0" Background="Transparent" Width="160"/>
                </StackPanel>
            </Border>

            <!-- PAGINAÇÃO -->
            <Border Grid.Column="2" Background="White" CornerRadius="10"
                    Padding="16,8" Margin="10,0" VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Linhas por página:"
                               FontSize="12" Foreground="#4A5568"
                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <ComboBox x:Name="cbLinhas"
                              Style="{StaticResource ComboBoxDashStyle}"
                              Width="65" Height="32" SelectedIndex="0">
                        <ComboBoxItem Content="10"/>
                        <ComboBoxItem Content="25"/>
                        <ComboBoxItem Content="50"/>
                    </ComboBox>
                    <TextBlock x:Name="txtPaginacao"
                               Text="1 a 10 de 0"
                               FontSize="12" Foreground="#4A5568"
                               VerticalAlignment="Center" Margin="16,0"/>
                    <Button Content="❮" Width="28" Height="28" Background="Transparent"
                            BorderThickness="0" FontSize="14" Foreground="#4A5568" Cursor="Hand"/>
                    <Button Content="❯" Width="28" Height="28" Background="Transparent"
                            BorderThickness="0" FontSize="14" Foreground="#4A5568" Cursor="Hand"/>
                </StackPanel>
            </Border>

        </Grid>

    </Grid>
</UserControl>