<UserControl x:Class="PDV.Views.ContasReceberView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             Background="#ECEFF1">

    <UserControl.Resources>

        <Style x:Key="ColHeaderStyle" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#F7FAFC"/>
            <Setter Property="Foreground" Value="#4A5568"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
        </Style>

        <Style x:Key="ColCellStyle" TargetType="DataGridCell">
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#2D3748"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#EBF4FF"/>
                    <Setter Property="Foreground" Value="#1C3E72"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Height" Value="32"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#111827"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="border"
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="6"
                                    BorderBrush="#D1D5DB"
                                    BorderThickness="1"
                                    Padding="10,0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <ContentPresenter Grid.Column="0"
                                                      Content="{TemplateBinding SelectionBoxItem}"
                                                      ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                      VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="∨" FontSize="10"
                                               Foreground="#6B7280" VerticalAlignment="Center" Margin="8,0,0,0"/>
                                </Grid>
                            </Border>
                            <ToggleButton Opacity="0"
                                          IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                          Focusable="False"/>
                            <Popup IsOpen="{TemplateBinding IsDropDownOpen}"
                                   Placement="Top" AllowsTransparency="True" Focusable="False">
                                <Border Background="White" CornerRadius="8"
                                        BorderBrush="#E5E7EB" BorderThickness="1" Margin="0,0,0,4">
                                    <ScrollViewer>
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="FontSize" Value="13"/>
                        <Setter Property="Foreground" Value="#111827"/>
                        <Setter Property="Padding" Value="14,8"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ComboBoxItem">
                                    <Border x:Name="itemBorder" Background="Transparent" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="itemBorder" Property="Background" Value="#F3F4F6"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="itemBorder" Property="Background" Value="#EBF4FF"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>

    </UserControl.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- HEADER AZUL -->
        <Border Grid.Row="0"
                Background="#1C3E72"
                CornerRadius="12,12,0,0"
                Padding="20,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                        x:Name="BtnVoltar"
                        Click="BtnVoltar_Click"
                        Background="Transparent"
                        BorderThickness="0"
                        Cursor="Hand"
                        VerticalAlignment="Center"
                        Margin="0,0,12,0">
                    <TextBlock Text="←" FontSize="18" Foreground="White" VerticalAlignment="Center"/>
                </Button>

                <TextBlock Grid.Column="1"
                           Text="Contas a Receber"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Foreground="White"
                           VerticalAlignment="Center"/>

                <Button Grid.Column="2"
                        x:Name="BtnNovo"
                        Width="36" Height="36"
                        Background="White"
                        BorderThickness="0"
                        Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="border"
                                    Background="White"
                                    CornerRadius="18"
                                    Width="36" Height="36">
                                <TextBlock Text="+"
                                           FontSize="22"
                                           FontWeight="Bold"
                                           Foreground="#1C3E72"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="border" Property="Background" Value="#E8EEF8"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </Border>

        <!-- BARRA MÊS/STATUS -->
        <Border Grid.Row="1"
                Background="#2A52A0"
                Padding="20,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           x:Name="TxtFiltroAtivo"
                           Text="Mês/Ano: 04/2026  |  Status: Todos"
                           FontSize="13"
                           FontWeight="SemiBold"
                           Foreground="White"
                           VerticalAlignment="Center"/>

                <Button Grid.Column="2"
                        x:Name="BtnToggleTotais"
                        Background="Transparent"
                        BorderThickness="0"
                        Cursor="Hand"
                        Click="BtnToggleTotais_Click">
                    <TextBlock Text="☰" FontSize="16" Foreground="White"/>
                </Button>
            </Grid>
        </Border>

        <!-- CARDS TOTAIS -->
        <Border Grid.Row="2"
                x:Name="PanelTotais"
                Background="White"
                Visibility="Collapsed"
                Padding="16,12"
                Margin="0,0,0,2">
            <StackPanel>

                <Border Background="#DBEAFE" CornerRadius="8" Padding="16,10" Margin="0,0,0,6">
                    <Grid>
                        <TextBlock Text="Total a Receber:"
                                   FontSize="13" FontWeight="SemiBold" Foreground="#1C3E72"/>
                        <TextBlock x:Name="TxtTotalReceber"
                                   Text="R$ 0,00"
                                   FontSize="13" FontWeight="SemiBold" Foreground="#1C3E72"
                                   HorizontalAlignment="Right"/>
                    </Grid>
                </Border>

                <Border Background="#FCE4EC" CornerRadius="8" Padding="16,10" Margin="0,0,0,6">
                    <Grid>
                        <TextBlock Text="Total Recebido:"
                                   FontSize="13" FontWeight="SemiBold" Foreground="#880E4F"/>
                        <TextBlock x:Name="TxtTotalRecebido"
                                   Text="R$ 0,00"
                                   FontSize="13" FontWeight="SemiBold" Foreground="#880E4F"
                                   HorizontalAlignment="Right"/>
                    </Grid>
                </Border>

                <Border Background="#E8F5E9" CornerRadius="8" Padding="16,10">
                    <Grid>
                        <TextBlock Text="Total Geral:"
                                   FontSize="13" FontWeight="SemiBold" Foreground="#1B5E20"/>
                        <TextBlock x:Name="TxtTotalGeral"
                                   Text="R$ 0,00"
                                   FontSize="13" FontWeight="SemiBold" Foreground="#1B5E20"
                                   HorizontalAlignment="Right"/>
                    </Grid>
                </Border>

            </StackPanel>
        </Border>

        <!-- DATAGRID -->
        <Border Grid.Row="3" Background="White" Margin="0,0,0,10">
            <DataGrid x:Name="dgContasReceber"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      IsReadOnly="True"
                      GridLinesVisibility="Horizontal"
                      HorizontalGridLinesBrush="#F0F0F0"
                      BorderThickness="0"
                      Background="White"
                      RowBackground="White"
                      AlternatingRowBackground="#FAFAFA"
                      ColumnHeaderStyle="{StaticResource ColHeaderStyle}"
                      CellStyle="{StaticResource ColCellStyle}"
                      SelectionMode="Single"
                      SelectionUnit="FullRow"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Auto">

                <DataGrid.Columns>
                    <DataGridTextColumn Header="Cliente"
                                        Binding="{Binding Cliente}"
                                        Width="*"/>
                    <DataGridTextColumn Header="Status"
                                        Binding="{Binding Status}"
                                        Width="100"/>
                    <DataGridTextColumn Header="Data de Lançamento"
                                        Binding="{Binding DataLancamento, StringFormat=dd/MM/yyyy}"
                                        Width="150"/>
                    <DataGridTextColumn Header="Data de Vencimento"
                                        Binding="{Binding DataVencimento, StringFormat=dd/MM/yyyy}"
                                        Width="150"/>
                    <DataGridTextColumn Header="Data de Recebimento"
                                        Binding="{Binding DataRecebimento, StringFormat=dd/MM/yyyy}"
                                        Width="155"/>
                    <DataGridTextColumn Header="Valor a Receber"
                                        Binding="{Binding ValorAReceber, StringFormat=R$ {0:N2}}"
                                        Width="130"/>
                    <DataGridTextColumn Header="Taxa Juros"
                                        Binding="{Binding TaxaJuros, StringFormat={}{0:N2}%}"
                                        Width="100"/>
                    <DataGridTextColumn Header="Valor Juros"
                                        Binding="{Binding ValorJuros, StringFormat=R$ {0:N2}}"
                                        Width="110"/>
                    <DataGridTextColumn Header="Valor Recebido"
                                        Binding="{Binding ValorRecebido, StringFormat=R$ {0:N2}}"
                                        Width="120"/>
                </DataGrid.Columns>

                <DataGrid.Style>
                    <Style TargetType="DataGrid">
                        <Style.Triggers>
                            <Trigger Property="HasItems" Value="False">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate>
                                            <StackPanel HorizontalAlignment="Center"
                                                        VerticalAlignment="Center"
                                                        Margin="0,40">
                                                <TextBlock Text="Nenhum registro encontrado!"
                                                           FontSize="14"
                                                           Foreground="#8A94A6"
                                                           HorizontalAlignment="Center"/>
                                            </StackPanel>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.Style>

            </DataGrid>
        </Border>

        <!-- RODAPÉ -->
        <Border Grid.Row="4"
                Background="White"
                CornerRadius="0,0,12,12"
                Padding="12,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="15"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Vertical">
                    <TextBlock Text="Mês/Ano para o Filtro"
                               FontSize="11" Foreground="#8A94A6" Margin="0,0,0,4"/>
                    <DatePicker x:Name="dpMesAno"
                                SelectedDateFormat="Short"
                                FontSize="13"
                                Foreground="#1C3E72"
                                FontWeight="SemiBold"
                                BorderThickness="0"
                                Background="Transparent"
                                Width="160"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Vertical">
                    <TextBlock Text="Selecione o Status do Recebimento"
                               FontSize="11" Foreground="#8A94A6" Margin="0,0,0,4"/>
                    <ComboBox x:Name="cbStatus"
                              Style="{StaticResource ComboBoxStyle}"
                              Width="180"
                              SelectedIndex="0">
                        <ComboBoxItem Content="Todos"/>
                        <ComboBoxItem Content="A Receber"/>
                        <ComboBoxItem Content="Recebido"/>
                    </ComboBox>
                </StackPanel>

                <StackPanel Grid.Column="4"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <TextBlock Text="Linhas por página:"
                               FontSize="12" Foreground="#4A5568"
                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <ComboBox x:Name="cbLinhas"
                              Style="{StaticResource ComboBoxStyle}"
                              Width="70" SelectedIndex="0">
                        <ComboBoxItem Content="10"/>
                        <ComboBoxItem Content="25"/>
                        <ComboBoxItem Content="50"/>
                        <ComboBoxItem Content="100"/>
                    </ComboBox>
                    <TextBlock x:Name="txtPaginacao"
                               Text="1 a 10 de 0"
                               FontSize="12" Foreground="#4A5568"
                               VerticalAlignment="Center" Margin="16,0"/>
                    <Button Content="⏮" Width="28" Height="28" Background="Transparent"
                            BorderThickness="0" FontSize="13" Foreground="#4A5568" Cursor="Hand"/>
                    <Button Content="◀" Width="28" Height="28" Background="Transparent"
                            BorderThickness="0" FontSize="13" Foreground="#4A5568" Cursor="Hand"/>
                    <Button Content="▶" Width="28" Height="28" Background="Transparent"
                            BorderThickness="0" FontSize="13" Foreground="#4A5568" Cursor="Hand"/>
                    <Button Content="⏭" Width="28" Height="28" Background="Transparent"
                            BorderThickness="0" FontSize="13" Foreground="#4A5568" Cursor="Hand"/>
                    
                </StackPanel>

            </Grid>
        </Border>

    </Grid>
</UserControl>