<UserControl x:Class="PDV.Views.MainView"
             x:Name="MainViewRoot"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:PDV.Views"
             xmlns:localCadastros="clr-namespace:PDV.Views.Cadastros"
             xmlns:localImportar="clr-namespace:PDV.Views.ImportarProduto"
             xmlns:localNovoProduto="clr-namespace:PDV.Views.NovoProduto"
             xmlns:vm="clr-namespace:PDV.ViewModels"
             xmlns:vmNovoProduto="clr-namespace:PDV.ViewModels.NovoProduto"
             xmlns:vmCadastros="clr-namespace:PDV.ViewModels.Cadastros"
             mc:Ignorable="d"
             HorizontalAlignment="Stretch"
             VerticalAlignment="Stretch">

    <UserControl.Resources>

        <!-- HOME -->
        <DataTemplate DataType="{x:Type vm:HomeViewModel}">
            <local:HomeView />
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:AberturaCaixaViewModel}">
            <local:AberturaCaixaView />
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:MovimentoViewModel}">
            <local:MovimentoView />
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:MovimentoPlusViewModel}">
            <local:PdvFeatureView />
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:SuprimentoViewModel}">
            <local:SuprimentoView />
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:SangriaViewModel}">
            <local:SangriaView />
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:ComprasViewModel}">
            <local:ComprasView />
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:ComprasFormViewModel}">
            <local:ComprasFormView />
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:EstoqueViewModel}">
            <local:EstoqueView />
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:FinanceiroViewModel}">
            <local:FinanceiroView />
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:DashboardViewModel}">
            <local:DashboardView />
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:VendasViewModel}">
            <local:VendasView />
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:ConfiguracoesViewModel}">
            <local:ConfiguracoesView />
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:CadastrosPlusViewModel}">
            <local:PdvFeatureView />
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:PdvPlusViewModel}">
            <local:PdvFeatureView />
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:FiscalViewModel}">
            <local:PdvFeatureView />
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:TributacaoViewModel}">
            <local:PdvFeatureView />
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:FoodViewModel}">
            <local:PdvFeatureView />
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:DeliveryViewModel}">
            <local:PdvFeatureView />
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:RelatoriosViewModel}">
            <local:PdvFeatureView />
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:ConfiguracoesPlusViewModel}">
            <local:PdvFeatureView />
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:AjudaViewModel}">
            <local:AjudaView />
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:ContatoViewModel}">
            <local:ContatoView />
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:SairViewModel}">
            <local:SairView />
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:CadastrosPanelViewModel}">
            <local:CadastrosPanelUserControl />
        </DataTemplate>
        <!-- Cadastros - List Views (implementação real em PDV.Views.Cadastros / PDV.ViewModels.Cadastros) -->
        <DataTemplate DataType="{x:Type vmCadastros:ClienteListViewModel}">
            <localCadastros:ClienteListView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vmCadastros:FornecedorListViewModel}">
            <localCadastros:FornecedorListView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vmCadastros:ColaboradorListViewModel}">
            <localCadastros:ColaboradorListView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vmCadastros:EmpresaListViewModel}">
            <localCadastros:EmpresaListView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vmCadastros:FormaPagamentoListViewModel}">
            <localCadastros:FormaPagamentoListView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vmCadastros:UnidadeListViewModel}">
            <localCadastros:UnidadeListView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vmCadastros:ProdutoListViewModel}">
            <localCadastros:ProdutoListView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ContasPagarViewModel}">
            <local:ContasPagarView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ContasReceberViewModel}">
            <local:ContasReceberView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ImportarProdutoViewModel}">
            <local:ImportarProdutoView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:NovoProdutoViewModel}">
            <localImportar:NovoProdutoView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vmNovoProduto:ProdutoInserindoViewModel}">
            <localNovoProduto:ProdutoInserindoView/>
        </DataTemplate>

        <!-- Cadastros - Form Views (Form ViewModels/Views estão no namespace raiz PDV.ViewModels / PDV.Views) -->
        <DataTemplate DataType="{x:Type vm:ClienteFormViewModel}">
            <local:ClienteFormView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:FornecedorFormViewModel}">
            <local:FornecedorFormView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ColaboradorFormViewModel}">
            <local:ColaboradorFormView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:EmpresaFormViewModel}">
            <local:EmpresaFormView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:FormaPagamentoFormViewModel}">
            <local:FormaPagamentoFormView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:UnidadeFormViewModel}">
            <local:UnidadeFormView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ProdutoFormViewModel}">
            <local:ProdutoFormView/>
        </DataTemplate>

        <!-- ÍCONES AZUIS (versão selecionada) -->
        <DrawingImage x:Key="DownloadIconAzul">
            <DrawingImage.Drawing>
                <DrawingGroup>
                    <GeometryDrawing Brush="Transparent">
                        <GeometryDrawing.Pen>
                            <Pen Brush="#1C3E72" Thickness="1.4"/>
                        </GeometryDrawing.Pen>
                        <GeometryDrawing.Geometry>
                            <RectangleGeometry Rect="4,6,16,12" RadiusX="2" RadiusY="2"/>
                        </GeometryDrawing.Geometry>
                    </GeometryDrawing>
                    <GeometryDrawing Brush="#1C3E72">
                        <GeometryDrawing.Geometry>
                            <RectangleGeometry Rect="7,8,10,1"/>
                        </GeometryDrawing.Geometry>
                    </GeometryDrawing>
                    <GeometryDrawing Brush="#1C3E72">
                        <GeometryDrawing.Geometry>
                            <PathGeometry Figures="M12,4 L12,11 M9,8 L12,11 L15,8"/>
                        </GeometryDrawing.Geometry>
                    </GeometryDrawing>
                </DrawingGroup>
            </DrawingImage.Drawing>
        </DrawingImage>

        <DrawingImage x:Key="BoxIconAzul">
            <DrawingImage.Drawing>
                <DrawingGroup>
                    <GeometryDrawing Brush="Transparent">
                        <GeometryDrawing.Pen>
                            <Pen Brush="#1C3E72" Thickness="1.4"/>
                        </GeometryDrawing.Pen>
                        <GeometryDrawing.Geometry>
                            <PathGeometry Figures="M12,2 L20,6 L20,16 L12,20 L4,16 L4,6 Z"/>
                        </GeometryDrawing.Geometry>
                    </GeometryDrawing>
                    <GeometryDrawing Brush="Transparent">
                        <GeometryDrawing.Pen>
                            <Pen Brush="#1C3E72" Thickness="1.4"/>
                        </GeometryDrawing.Pen>
                        <GeometryDrawing.Geometry>
                            <PathGeometry Figures="M12,7 L16,9 L12,11 L8,9 Z M8,9 L8,13 L12,15 L12,11 M16,9 L16,13 L12,15"/>
                        </GeometryDrawing.Geometry>
                    </GeometryDrawing>
                </DrawingGroup>
            </DrawingImage.Drawing>
        </DrawingImage>

        <DrawingImage x:Key="ShuffleIconAzul">
            <DrawingImage.Drawing>
                <DrawingGroup>
                    <GeometryDrawing Brush="Transparent">
                        <GeometryDrawing.Pen>
                            <Pen Brush="#1C3E72" Thickness="1.4"/>
                        </GeometryDrawing.Pen>
                        <GeometryDrawing.Geometry>
                            <EllipseGeometry Center="12,12" RadiusX="10" RadiusY="10"/>
                        </GeometryDrawing.Geometry>
                    </GeometryDrawing>
                    <GeometryDrawing Brush="#1C3E72">
                        <GeometryDrawing.Geometry>
                            <PathGeometry Figures="M7,10 C9,10 10,9 11,8 L13,8 L11,6 L16,9 L11,12 L13,10 L11,10 C10,11 9,12 7,12"/>
                        </GeometryDrawing.Geometry>
                    </GeometryDrawing>
                    <GeometryDrawing Brush="#1C3E72">
                        <GeometryDrawing.Geometry>
                            <PathGeometry Figures="M7,14 C9,14 10,15 11,16 L13,16 L11,18 L16,15 L11,12 L13,14 L11,14 C10,13 9,12 7,12"/>
                        </GeometryDrawing.Geometry>
                    </GeometryDrawing>
                </DrawingGroup>
            </DrawingImage.Drawing>
        </DrawingImage>

        <!-- STYLE DOS BOTÕES -->
        <Style x:Key="SideMenuIconButton" TargetType="RadioButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="border"
                                Background="Transparent"
                                CornerRadius="10"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <!-- Hover -->
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border"
                                        Property="Background"
                                        Value="#40FFFFFF"/>
                            </Trigger>
                            <!-- Selecionado -->
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="border"
                                        Property="Background"
                                        Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </UserControl.Resources>

    <Grid>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="60"/>
            <ColumnDefinition x:Name="MenuColumn" Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- FAIXA AZUL -->
        <Border Grid.Column="0"
                Grid.Row="0"
                Grid.RowSpan="2"
                Background="#1C3E72">

            <StackPanel VerticalAlignment="Top"
                        HorizontalAlignment="Center">

                <Image Source="/Assets/Images/Png/Circle_branco.png"
                       Width="36"
                       Height="36"
                       Margin="0,15,0,20"/>

                <!-- BOTÃO CAIXA -->
                <RadioButton GroupName="Menu"
                             Margin="0,0,0,10"
                             Click="BtnCaixa_Click">
                    <RadioButton.Style>
                        <Style TargetType="RadioButton" BasedOn="{StaticResource SideMenuIconButton}"/>
                    </RadioButton.Style>
                    <Image Width="22" Height="22">
                        <Image.Style>
                            <Style TargetType="Image">
                                <Setter Property="Source" Value="{StaticResource DownloadIcon}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsChecked, RelativeSource={RelativeSource AncestorType=RadioButton}}" Value="True">
                                        <Setter Property="Source" Value="{StaticResource DownloadIconAzul}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Image.Style>
                    </Image>
                </RadioButton>

                <!-- BOTÃO MÓDULOS -->
                <RadioButton GroupName="Menu"
                             Margin="0,0,0,10"
                             Click="BtnModulos_Click">
                    <RadioButton.Style>
                        <Style TargetType="RadioButton" BasedOn="{StaticResource SideMenuIconButton}"/>
                    </RadioButton.Style>
                    <Image Width="22" Height="22">
                        <Image.Style>
                            <Style TargetType="Image">
                                <Setter Property="Source" Value="{StaticResource BoxIcon}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsChecked, RelativeSource={RelativeSource AncestorType=RadioButton}}" Value="True">
                                        <Setter Property="Source" Value="{StaticResource BoxIconAzul}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Image.Style>
                    </Image>
                </RadioButton>

                <!-- BOTÃO OUTROS -->
                <RadioButton GroupName="Menu"
                             Click="BtnOutros_Click">
                    <RadioButton.Style>
                        <Style TargetType="RadioButton" BasedOn="{StaticResource SideMenuIconButton}"/>
                    </RadioButton.Style>
                    <Image Width="22" Height="22">
                        <Image.Style>
                            <Style TargetType="Image">
                                <Setter Property="Source" Value="{StaticResource ShuffleIcon}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsChecked, RelativeSource={RelativeSource AncestorType=RadioButton}}" Value="True">
                                        <Setter Property="Source" Value="{StaticResource ShuffleIconAzul}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Image.Style>
                    </Image>
                </RadioButton>

            </StackPanel>

        </Border>

        <!-- MENU -->
        <local:MenuView x:Name="MenuViewControl"
                        Grid.Column="1"
                        Grid.Row="0"
                        Grid.RowSpan="2"
                        DataContext="{Binding Menu}" Loaded="MenuViewControl_Loaded_1" />

        <!-- HEADER -->
        <local:HeaderView x:Name="HeaderView"
                          Grid.Row="0"
                          Grid.Column="2"
                          DataContext="{Binding Header}"
                          Loaded="HeaderView_Loaded"/>

        <!-- CONTEÚDO DINÂMICO -->
        <ContentControl Grid.Row="1"
                        Grid.Column="2"
                        Content="{Binding CurrentContentView}"/>

    </Grid>

</UserControl>
