<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Cores primárias -->
    <Color x:Key="PrimaryLightColor">#FF90CAF9</Color>
    <Color x:Key="PrimaryColor">#4DA6FF</Color>
    <Color x:Key="PrimaryDarkColor">#1E88E5</Color>
    <Color x:Key="PrimaryDarkerColor">#1565C0</Color>

    <!-- Cores de fundo -->
    <Color x:Key="BackgroundDefaultColor">#F8FAFD</Color>

    <!-- Cores texto -->
    <Color x:Key="TitleColor">#1C3E72</Color>
    <Color x:Key="PlaceholderColor">#999999</Color>
    <Color x:Key="InputBorderColor">#808080</Color>

    <!-- Definindo brushes (pincéis) a partir das cores -->
    <SolidColorBrush x:Key="PrimaryLightBrush" Color="{StaticResource PrimaryLightColor}" />
    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource PrimaryColor}" />
    <SolidColorBrush x:Key="PrimaryDarkBrush" Color="{StaticResource PrimaryDarkColor}" />
    <SolidColorBrush x:Key="PrimaryDarkerBrush" Color="{StaticResource PrimaryDarkerColor}" />
    <SolidColorBrush x:Key="BackgroundDefaulBrush" Color="{StaticResource BackgroundDefaultColor}" />
    <SolidColorBrush x:Key="TitleBrush" Color="{StaticResource TitleColor}" />
    <SolidColorBrush x:Key="PlaceholderBrush" Color="{StaticResource PlaceholderColor}" />
    <SolidColorBrush x:Key="InputBorderBrush" Color="{StaticResource InputBorderColor}" />

</ResourceDictionary>
