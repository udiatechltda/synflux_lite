<Application x:Class="PDV.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:PDV"
             xmlns:views="clr-namespace:PDV.Views"
             xmlns:viewsCadastros="clr-namespace:PDV.Views.Cadastros"
             xmlns:viewsImportar="clr-namespace:PDV.Views.ImportarProduto"
             xmlns:viewsNovoProduto="clr-namespace:PDV.Views.NovoProduto"
             xmlns:vm="clr-namespace:PDV.ViewModels"
             xmlns:vmCadastros="clr-namespace:PDV.ViewModels.Cadastros"
             xmlns:vmNovoProduto="clr-namespace:PDV.ViewModels.NovoProduto"
             xmlns:converters="clr-namespace:PDV.Utilities.Converters">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Assets/Styles/ButtonStyles.xaml"/>
                <ResourceDictionary Source="/Assets/Styles/TextBoxStyles.xaml"/>
                <ResourceDictionary Source="/Assets/Styles/ColorStyles.xaml"/>
                <ResourceDictionary Source="/Assets/Styles/IconStyles.xaml"/>
                <ResourceDictionary Source="/Assets/Styles/DataGridStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <converters:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
            <converters:InverseBoolConverter x:Key="InverseBool"/>
            <converters:StringToVisibilityConverter x:Key="StringToVisibility"/>

            <DataTemplate DataType="{x:Type vm:HomeViewModel}">
                <views:HomeView />
            </DataTemplate>

            <DataTemplate DataType="{x:Type vmCadastros:ClienteListViewModel}">
                <viewsCadastros:ClienteListView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vmCadastros:FornecedorListViewModel}">
                <viewsCadastros:FornecedorListView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vmCadastros:ColaboradorListViewModel}">
                <viewsCadastros:ColaboradorListView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vmCadastros:EmpresaListViewModel}">
                <viewsCadastros:EmpresaListView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vmCadastros:FormaPagamentoListViewModel}">
                <viewsCadastros:FormaPagamentoListView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vmCadastros:ProdutoListViewModel}">
                <viewsCadastros:ProdutoListView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vmCadastros:UnidadeListViewModel}">
                <viewsCadastros:UnidadeListView />
            </DataTemplate>

            <DataTemplate DataType="{x:Type vm:ClienteFormViewModel}">
                <views:ClienteFormView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:FornecedorFormViewModel}">
                <views:FornecedorFormView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:ColaboradorFormViewModel}">
                <views:ColaboradorFormView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:EmpresaFormViewModel}">
                <views:EmpresaFormView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:FormaPagamentoFormViewModel}">
                <views:FormaPagamentoFormView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:ProdutoFormViewModel}">
                <views:ProdutoFormView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:UnidadeFormViewModel}">
                <views:UnidadeFormView />
            </DataTemplate>

            <DataTemplate DataType="{x:Type vm:ComprasFormViewModel}">
                <views:ComprasFormView />
            </DataTemplate>

            <DataTemplate DataType="{x:Type vm:ImportarProdutoViewModel}">
                <views:ImportarProdutoView />
            </DataTemplate>

            <DataTemplate DataType="{x:Type vm:NovoProdutoViewModel}">
                <viewsImportar:NovoProdutoView />
            </DataTemplate>

            <!-- ✅ PRODUTO INSERINDO -->
            <DataTemplate DataType="{x:Type vmNovoProduto:ProdutoInserindoViewModel}">
                <viewsNovoProduto:ProdutoInserindoView />
            </DataTemplate>

            <DataTemplate DataType="{x:Type vm:DashboardViewModel}">
                <views:DashboardView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:VendasViewModel}">
                <views:VendasView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:EstoqueViewModel}">
                <views:EstoqueView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:FinanceiroViewModel}">
                <views:FinanceiroView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:ComprasViewModel}">
                <views:ComprasView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:ContatoViewModel}">
                <views:ContatoView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:AjudaViewModel}">
                <views:AjudaView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:ConfiguracoesViewModel}">
                <views:ConfiguracoesView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:SairViewModel}">
                <views:SairView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:SuprimentoViewModel}">
                <views:SuprimentoView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:SangriaViewModel}">
                <views:SangriaView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:MovimentoViewModel}">
                <views:MovimentoView />
            </DataTemplate>
        </ResourceDictionary>
    </Application.Resources>
</Application>
